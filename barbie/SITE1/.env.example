# ─────────────────────────────────────────────────────────────────────────
# Barbie SITE1 — env template
# Скопируй в .env, заполни секреты. .env в git НЕ коммитится.
# Порты разведены с parent ES (см. barbie/ENTITY.md §5).
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD должен совпадать с паролем в DATABASE_URL (см. ENTITY §6).
# При первой инициализации Docker-том применяет POSTGRES_PASSWORD; смена пароля
# после создания тома НЕ перепишет пароль БД — нужно ALTER USER или recreate vol.
POSTGRES_PASSWORD=barbie_local_pw_change_me
DATABASE_URL=postgresql://postgres:barbie_local_pw_change_me@localhost:5442/barbie_site1

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6389

# ── Auth ──────────────────────────────────────────────────────────────────
# Сгенерируй сильные секреты (напр. `openssl rand -base64 64`).
JWT_SECRET=change_me_to_strong_random_64_byte_secret
JWT_REFRESH_SECRET=change_me_to_strong_random_64_byte_secret_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Ports ─────────────────────────────────────────────────────────────────
API_PORT=3010
WEB_PORT=3011

# ── S3 / MinIO ────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9011
S3_REGION=us-east-1
S3_ACCESS_KEY=barbie_minio_admin
S3_SECRET_KEY=barbie_minio_password
S3_BUCKET=barbie-media
S3_PUBLIC_URL=http://localhost:9011/barbie-media
S3_FORCE_PATH_STYLE=true

# ── Mail (Mailhog в dev) ──────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=8035
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@barbie-site1.local

# ── Multi-tenant ──────────────────────────────────────────────────────────
# Корневой домен для subdomain-резолвинга (см. ARCHITECTURE.md §2).
# В dev можно использовать <slug>.lvh.me (резолвится на 127.0.0.1).
TENANT_ROOT_DOMAIN=lvh.me
TENANT_RESOLVE_FALLBACK_HEADER=x-tenant-slug

# ── Platform admin (создаётся db:bootstrap скриптом) ──────────────────────
PLATFORM_ADMIN_EMAIL=admin@barbie-site1.local
PLATFORM_ADMIN_PASSWORD=Admin123!ChangeMe

# ── Observability ─────────────────────────────────────────────────────────
LOG_LEVEL=debug
# SENTRY_DSN=
