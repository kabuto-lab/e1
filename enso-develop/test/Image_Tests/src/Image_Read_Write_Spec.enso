from Standard.Base import all
import Standard.Base.Errors.Common.Forbidden_Operation
import Standard.Base.Errors.File_Error.File_Error
import Standard.Base.Runtime.Context

from Standard.Image import Image, Read_Flag, Write_Flag

from Standard.Test import all

import enso_dev.Cloud_Tests.Network.Enso_Cloud.Cloud_Tests_Setup.Cloud_Tests_Setup
import enso_dev.Cloud_Tests.Network.Enso_Cloud.Cloud_Tests_Setup.Temporary_Directory
from enso_dev.Cloud_Tests.Network.Enso_Cloud.Cloud_Tests_Setup import create_local_datalink_to

polyglot java import java.lang.System as Java_System
polyglot java import org.enso.base_test_helpers.ImageUtils

with_rgba_file ~action =
    f = File.create_temporary_file "rgba" ".png"
    ImageUtils.createRandomPng f.path 320 160
    action f

with_tmp_file prefix:Text suffix:Text ~action =
    f = File.create_temporary_file prefix suffix
    action f

add_specs suite_builder =
    suite_builder.group "Image.read" group_builder->
        group_builder.specify "should return error when read failed" <|
            result = Image.read (enso_project.root / 'no_such_file.png')
            result . should_fail_with File_Error
            result.catch.should_be_a File_Error.IO_Error

        group_builder.specify "should read a color image" <|
            with_rgba_file \rgba_file ->
                img = Image.read rgba_file
                img.rows.should_equal 160
                img.columns.should_equal 320
                img.channels.should_equal 3

        group_builder.specify "should read an image as grayscale" <|
            with_rgba_file \rgba_file ->
                img = Image.read rgba_file Read_Flag.Grayscale
                img.rows.should_equal 160
                img.columns.should_equal 320
                img.channels.should_equal 1

        group_builder.specify "should read an image with an alpha channel" <|
            with_rgba_file \rgba_file ->
                img = Image.read rgba_file Read_Flag.Alpha_Channel
                img.rows.should_equal 160
                img.columns.should_equal 320
                img.channels.should_equal 4

        group_builder.specify "should return error when write failed" <|
            with_rgba_file \rgba_file ->
                out_file = enso_project.root / "no_such_directory" / "out.png"
                result = Image.read rgba_file . write out_file
                result.should_fail_with File_Error
                result.catch.should_be_a File_Error.IO_Error

        group_builder.specify "should write a PNG file with alpha channel" <|
            with_rgba_file \rgba_file ->
                with_tmp_file "out_alpha" ".png" \out_file ->
                    Image.read rgba_file Read_Flag.Alpha_Channel . write out_file

        group_builder.specify "should write a grayscale PNG file" <|
            with_rgba_file \rgba_file ->
                with_tmp_file "out_gray" ".png" \out_file ->
                    Image.read rgba_file Read_Flag.Grayscale . write out_file

        group_builder.specify "should write a PNG file with compression" <|
            with_rgba_file \rgba_file ->
                with_tmp_file "out" ".png" \out_file ->
                    Image.read rgba_file . write out_file (Write_Flag.PNG_Compression 3) . should_equal out_file

        group_builder.specify "should write a JPEG file with compression" <|
            with_rgba_file \rgba_file ->
                with_tmp_file "out" ".jpeg" \out_file ->
                    flags = [Write_Flag.JPEG_Quality 75, Write_Flag.JPEG_Optimize, Write_Flag.JPEG_Progressive]
                    Image.read rgba_file . write out_file flags . should_equal out_file

    suite_builder.group "Image File_Format" group_builder->
        group_builder.specify "should recognise image files" <|
            assert_image_file_format v =
               t = Meta.type_of v . to_text
               t . should_equal "Image_File_Format"

            assert_image_file_format <| Auto_Detect.get_reading_format (enso_project.data / "data.jpg")
            assert_image_file_format <| Auto_Detect.get_reading_format (enso_project.data / "data.png")
            assert_image_file_format <| Auto_Detect.get_reading_format (enso_project.data / "data.bmp")

        group_builder.specify "should allow reading an Image" <|
            with_rgba_file \rgba_file ->
                img = Data.read rgba_file
                img.rows.should_equal 160
                img.columns.should_equal 320
                img.channels.should_equal 3

    suite_builder.group "Image Write" group_builder->
        group_builder.specify "should write a Bitmap file" <|
            with_rgba_file \rgba_file ->
                with_tmp_file "out_alpha" ".bmp" \out ->
                    img = Image.read rgba_file

                    img.write out
                    out.exists.should_be_true

                    bmp = Image.read out
                    bmp.rows.should_equal 160
                    bmp.columns.should_equal 320


        group_builder.specify "should not write if Context.Output is disabled." <|
            with_rgba_file \rgba_file ->
                with_tmp_file "out_alpha" ".bmp" \out ->
                    # Ensure that `out` does not exist
                    out.delete_if_exists
                    img = Image.read rgba_file

                    Context.Output.with_disabled <|
                        img.write out . should_fail_with Forbidden_Operation
                        out.exists.should_be_false


    cloud_setup = Cloud_Tests_Setup.prepare
    suite_builder.group "Data Links to Images" pending=cloud_setup.real_cloud_pending group_builder->
        subdirectory_for_tests = Temporary_Directory.make "Image"
        group_builder.teardown subdirectory_for_tests.cleanup
        group_builder.specify "should be able to write image data to a data link and read it back" <|
            with_rgba_file \rgba_file ->
                datalink = create_local_datalink_to (subdirectory_for_tests.get / "image.png")
                local_image = Image.read rgba_file

                # Write image data to datalink
                local_image.write datalink . should_equal datalink

                # And read it back
                datalink.read . should_be_a Image

main filter=Nothing =
    suite = Test.build suite_builder->
        add_specs suite_builder
    suite.run_with_filter filter
