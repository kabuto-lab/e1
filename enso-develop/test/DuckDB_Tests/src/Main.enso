from Standard.Base import all

from Standard.Test import Test

import project.DuckDB_In_Memory_Spec
import project.DuckDB_Parquet_Spec
import project.DuckDB_Spec

main filter=Nothing =
    suite = Test.build suite_builder->
        DuckDB_In_Memory_Spec.add_specs suite_builder
        DuckDB_Parquet_Spec.add_specs suite_builder
        DuckDB_Spec.add_specs suite_builder

    suite.run_with_filter filter
