from Standard.Base import all
import Standard.Visualization.Widgets

from Standard.Table.Internal.Widget_Helpers import all
from Standard.Table import Value_Type

from Standard.Test import all
from Standard.Table import Table

import project.Util

main filter=Nothing =
    suite = Test.build suite_builder->
        add_specs suite_builder
    suite.run_with_filter filter


add_specs suite_builder =
    table = Table.new [["X", [1, 2, 3, 4]], ["Y", ["a", "b", "c", "d"]]]
    suite_builder.group "Can run each helper" group_builder->
        group_builder.specify "make_column_name_multi_selector with regex and by_type" <|
            w = make_column_name_multi_selector table add_regex=True add_by_type=True
            j = (Widgets.get_widget_json w) . to_text
            j.should_contain "(Multiple_Choice [(Option '<Regular Expression>' 'regex' [] ''), (Option '<By Type>' '(..By_Type ..Integer)' [] ''), (Option 'X' '\'X\'' [] ''), (Option 'Y' '\'Y\'' [] '')"
        group_builder.specify "make_column_ref_by_name_selector with named_pattern" <|
            w = make_column_ref_by_name_selector table add_named_pattern=True
            j = (Widgets.get_widget_json w) . to_text
            j.should_contain "(Option '<Leading_Whitespace>' 'Named_Pattern.Leading_Whitespace'"
        group_builder.specify "make_column_ref_by_name_selector without named_pattern" <|
            w = make_column_ref_by_name_selector table
            j = (Widgets.get_widget_json w) . to_text
            j.should_not_contain "(Option '<Leading_Whitespace>' 'Named_Pattern.Leading_Whitespace'"
        group_builder.specify "make_filter_condition_selector" <|
            w = make_filter_condition_selector table
            j = (Widgets.get_widget_json w) . to_text
            ## Just testing the start as this is very long...
            j.should_contain "(Single_Choice [(Option '..Equal' '..Equal' [['to', (Single_Choice [(Option '<Text Value>'"
    suite_builder.group "Can run make_column_ref_by_name_selector_for_type" group_builder->
        table2 = Table.new [["Ints1", [1, 2, 3, 4]], ["Ints2", [1, 2, 3, 4]], ["Floats", [1.0, 2.0, 3.0, 4.0]], ["Texts", ["a", "b", "c", "d"]], ["Texts2", ["a", "b", "c", "d"]]]
        group_builder.specify "make_column_ref_by_name_selector_for_type with integer column includes integer columns" <|
            w = make_column_ref_by_name_selector_for_type table2 value_type=Value_Type.Integer
            j = (Widgets.get_widget_json w) . to_text
            j.should_contain "Single_Choice [(Option '<Number Value>' '0' [] ''), (Option '<Expression>' '(expr \'[Ints1]\')' [] ''), (Option 'Ints1' '(..Name \'Ints1\')' [] ''), (Option 'Ints2' '(..Name \'Ints2\')' [] '')]"
        group_builder.specify "make_column_ref_by_name_selector_for_type with Float column includes matching Float column" <|
            w = make_column_ref_by_name_selector_for_type table2 value_type=Value_Type.Float
            j = (Widgets.get_widget_json w) . to_text
            j.should_contain "Single_Choice [(Option '<Number Value>' '0' [] ''), (Option '<Expression>' '(expr \'[Ints1]\')' [] ''), (Option 'Floats' '(..Name \'Floats\')' [] '')]"
        group_builder.specify "make_column_ref_by_name_selector_for_type with numeric column and if_value_type_numeric_include_all_numeric=True includes all nummeric columns" <|
            w = make_column_ref_by_name_selector_for_type table2 value_type=Value_Type.Integer if_value_type_numeric_include_all_numeric=True
            j = (Widgets.get_widget_json w) . to_text
            j.should_contain "Single_Choice [(Option '<Number Value>' '0' [] ''), (Option '<Expression>' '(expr \'[Ints1]\')' [] ''), (Option 'Ints1' '(..Name \'Ints1\')' [] ''), (Option 'Ints2' '(..Name \'Ints2\')' [] ''), (Option 'Floats' '(..Name \'Floats\')' [] '')]"
        group_builder.specify "make_column_ref_by_name_selector_for_type with text column and if_value_type_numeric_include_all_numeric=True just includes Text columns" <|
            w = make_column_ref_by_name_selector_for_type table2 value_type=Value_Type.Char if_value_type_numeric_include_all_numeric=True
            j = (Widgets.get_widget_json w) . to_text
            j.should_contain "(Option '<Expression>' '(expr \'[Ints1]\')' [] ''), (Option 'Texts' '(..Name \'Texts\')' [] ''), (Option 'Texts2' '(..Name \'Texts2\')' [] '')]"


            
