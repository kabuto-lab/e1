from Standard.Base import all
import Standard.Base.Errors.Common.Type_Error

from Standard.Table import all
from Standard.Table.Errors import all

import Standard.Database.Dialects.Feature.Feature

from Standard.Test import all

import project.Common_Table_Operations.Util
from project.Common_Table_Operations.Util import check_column_refinements, run_default_backend
from project.Util import all

type Lazy_Ref
    Value ~get

main filter=Nothing = run_default_backend add_specs filter

add_specs suite_builder setup =
    if setup.is_feature_supported Feature.Column_Operations then (add_numeric_columns_specs suite_builder setup)

add_numeric_columns_specs suite_builder setup =
    prefix = setup.prefix
    table_builder = setup.light_table_builder
    build_sorted_table = Util.build_sorted_table setup
    suite_builder.group prefix+"Numeric_Column" group_builder->
        numeric_column = Lazy_Ref.Value <| build_sorted_table [["X", [-10, 0, Nothing, 1, 12]]] . at "X"

        group_builder.specify "a numeric column can be cast to Numeric_Column" <|
            column = numeric_column.get
            column.value_type.is_numeric . should_be_true
            check_column_refinements column x->
                (x:Numeric_Column)

        group_builder.specify "a text column cannot be cast to Numeric_Column" <|
            column = table_builder [["X", ["txt"]]] . at "X"
            column.value_type.is_numeric . should_be_false
            Test.with_clue "(regular column) " <|
                Test.expect_panic Type_Error (column:Numeric_Column)
            Test.with_clue "(1-value column) " <|
                Test.expect_panic Type_Error (column.sort.take 1 : Numeric_Column)
            Test.with_clue "(1-column table as column) " <|
                Test.expect_panic Type_Error (column.to_table : Numeric_Column)
            Test.with_clue "(1-value 1-column table as column) " <|
                Test.expect_panic Type_Error (column.sort.to_table.take 1 : Numeric_Column)

        add_specific_type_test group_builder "Longs" [-10, 0, Nothing, 1, 12] build_sorted_table
        add_specific_type_test group_builder "Doubles" [-10.5, 0.0, Nothing, 1.2, 12.34] build_sorted_table

        if setup.flagged ..Supports_Decimal_Type then
            add_specific_type_test group_builder "BigIntegers" [-10, 0, Nothing, 1, 12, 2^65, -2^70] build_sorted_table
            add_specific_type_test group_builder "Decimals" [dec "-10.5", dec "0.0", Nothing, dec "1.2", dec "12.34", dec "123454567890.1234567890", dec "-12345678901890.1234567890"] build_sorted_table

add_specific_type_test group_builder type_name values build_sorted_table =
    sorted_table = Lazy_Ref.Value <| build_sorted_table [["X", values], ["E", 0.up_to values.length . map i-> i-3.25]]
    numeric_column = Lazy_Ref.Value <| sorted_table.get . at "X"
    exponential_column = Lazy_Ref.Value <| sorted_table.get . at "E"
    epsilon=0.000000001

    group_builder.specify "a numeric column ("+type_name+") supports abs operation" <|
        column = numeric_column.get
        abs_column = (column:Numeric_Column).abs
        abs_column.to_vector . should_equal (values.map v-> if v==Nothing then Nothing else v.abs)

    group_builder.specify "a numeric column ("+type_name+") supports signum operation" <|
        column = numeric_column.get
        signum_column = (column:Numeric_Column).signum
        signum_column.to_vector . should_equal (values.map v-> if v==Nothing then Nothing else v.signum)

    group_builder.specify "a numeric column ("+type_name+") supports radians operation" <|
        column = numeric_column.get
        radians_column = (column:Numeric_Column).radians
        (radians_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v) * (Math.pi / 180.0)) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports degrees operation" <|
        column = numeric_column.get
        degrees_column = (column:Numeric_Column).degrees
        (degrees_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v) / (Math.pi / 180.0)) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports sin operation" <|
        column = numeric_column.get
        sin_column = (column:Numeric_Column).sin
        (sin_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).sin) epsilon

        asin_column = (sin_column:Numeric_Column).asin
        (asin_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).sin.asin) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports cos operation" <|
        column = numeric_column.get
        cos_column = (column:Numeric_Column).cos
        (cos_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).cos) epsilon

        acos_column = (cos_column:Numeric_Column).acos
        (acos_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).cos.acos) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports tan operation" <|
        column = numeric_column.get
        tan_column = (column:Numeric_Column).tan
        (tan_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).tan) epsilon

        atan_column = (tan_column:Numeric_Column).atan
        (atan_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).tan.atan) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports sinh operation" <|
        column = numeric_column.get
        sinh_column = (column:Numeric_Column).sinh
        (sinh_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).sinh) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports cosh operation" <|
        column = numeric_column.get
        cosh_column = (column:Numeric_Column).cosh
        (cosh_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).cosh) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports tanh operation" <|
        column = numeric_column.get
        tanh_column = (column:Numeric_Column).tanh
        (tanh_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).tanh) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports sqrt operation" <|
        column = numeric_column.get
        sqrt_column = (column:Numeric_Column).sqrt
        (sqrt_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).sqrt) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports power operation" <|
        column = numeric_column.get
        power_column = (column:Numeric_Column).power 2.0
        (power_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v) ^ 2.0) epsilon

        neg_power_column = (column:Numeric_Column).power -1.7
        (neg_power_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v) ^ -1.7) epsilon

        self_power = (column:Numeric_Column).power exponential_column.get
        expected = values.map_with_index i-> v->
            exp_v = exponential_column.get.to_vector . at i
            if v==Nothing then Nothing else (float v) ^ exp_v
        (self_power:Numeric_Column).should_equal expected epsilon

    group_builder.specify "a numeric column ("+type_name+") supports ln operation" <|
        column = numeric_column.get
        ln_column = (column:Numeric_Column).ln
        (ln_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).ln) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports exp operation" <|
        ## Exp function grows very fast, so we only test it on first 5 values
        column = numeric_column.get.take (..First 5)
        exp_column = (column:Numeric_Column).exp
        (exp_column:Numeric_Column).should_equal (values.take (..First 5) . map v-> if v==Nothing then Nothing else (float v).exp) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports log10 operation" <|
        column = numeric_column.get
        log10_column = (column:Numeric_Column).log10
        (log10_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).log base=10) epsilon

    group_builder.specify "a numeric column ("+type_name+") supports log operation" <|
        column = numeric_column.get
        log10_column = (column:Numeric_Column).log
        (log10_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).log base=10) epsilon

        log2_column = (column:Numeric_Column).log 2
        (log2_column:Numeric_Column).should_equal (values.map v-> if v==Nothing then Nothing else (float v).log base=2) epsilon

private float v =
    if v.is_a Decimal then v.to_float else v
