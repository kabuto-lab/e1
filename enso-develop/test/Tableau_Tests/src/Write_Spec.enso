from Standard.Base import all
import Standard.Base.Errors.File_Error.File_Error
import Standard.Base.Runtime.Context
import Standard.Base.Errors.Common.Dry_Run_Operation

from Standard.Table import all
from Standard.Table.Errors import all
from Standard.Tableau import Hyper_File
from Standard.Tableau.Hyper_Errors import all

from Standard.Test import all
import enso_dev.Table_Tests.Util

main filter=Nothing =
    suite = Test.build suite_builder->
        add_specs suite_builder
    suite.run_with_filter filter

add_specs suite_builder = suite_builder.group "Write Tables" group_builder->
    transient = enso_project.data / "transient"

    get_temp_file -> File =
        transient / (Random.uuid + ".hyper")
    
    group_builder.specify "default schema and table name is Extract" <|
        written_file = get_temp_file
        t = Table.input [['A', ['a']]]
        t.write written_file
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.schema.should_equal "Extract"
        written_table_in_hyper.table.should_equal "Extract"
        written_file.delete

    group_builder.specify "returns a readable File" <|
        written_file = get_temp_file
        t = Table.input [['A', ['a']]]
        r = t.write written_file
        r.read.tables.first.read.should_equal t
        written_file.delete

    group_builder.specify "Can set schema name" <|
        written_file = get_temp_file
        t = Table.input [['A', ['a']]]
        t.write written_file (..Hyper_File "MySchemaName")
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.schema.should_equal "MySchemaName"
        written_table_in_hyper.table.should_equal "Extract"
        written_file.delete

    group_builder.specify "Can set schema name and table name" <|
        written_file = get_temp_file
        t = Table.input [['A', ['a']]]
        r = t.write written_file (..Hyper_Table "MySchemaName" "MyTableName")
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.schema.should_equal "MySchemaName"
        written_table_in_hyper.table.should_equal "MyTableName"
        written_table = written_table_in_hyper.read
        written_table.should_equal t
        (r.read.read "MyTableName" "MySchemaName").should_equal t
        Data.read r (..Hyper_Table "MySchemaName" "MyTableName") . should_equal t
        written_file.delete

    can_round_trip table:Table =
        written_file = get_temp_file
        table.write written_file
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table = written_table_in_hyper.read
        written_table.should_equal table
        written_file.delete

    group_builder.specify "should be able to write a text columns" <|
        can_round_trip (Table.input [['A', ['a', 'b', 'c', Nothing]], ['B', [Nothing, 'd', 'e', 'f']]])

    group_builder.specify "should be able to write a integer column" <|
        can_round_trip (Table.input [['ints', [1, 2, Nothing]]])

    group_builder.specify "should be able to write a float column" <|
        can_round_trip (Table.input [['ints', [1.0, Nothing, 2.0]]])
    
    group_builder.specify "should be able to write a bool column" <|
        can_round_trip (Table.input [['bools', [True, False, Nothing]]])

    group_builder.specify "should be able to write a date column" <|
        can_round_trip (Table.input [['dates', [Date.new 2025 1 1, Date.new 2025 2 28, Nothing]]])

    group_builder.specify "should be able to write a time column" <|
        ## hyper only supports down to microsecond precision
        can_round_trip (Table.input [['times', [Time_Of_Day.new 12 1 2 3 4, Time_Of_Day.new 9 50, Nothing]]])

    group_builder.specify "should be able to write a date time column" <|
        ## hyper doesn't support time zone
        can_round_trip (Table.input [['times', [Date_Time.new 2025 1 1 12 1 2 3 4 zone=(Time_Zone.parse 'UTC'), Date_Time.new 1989 12 18 zone=(Time_Zone.parse 'UTC'), Nothing]]])

    group_builder.specify "should be able to write a decimal column" <|
        can_round_trip (Table.input [['decimals', [3.14, -10.66, Nothing, 123456789.123456789], Value_Type.Decimal Nothing Nothing]])

    group_builder.specify "trying to write a mixed column should error" <|
        written_file = get_temp_file
        t = Table.input [['Mixed', ['a', 1]]]
        r = t.write written_file
        r.should_fail_with Hyper_Unsupported_Type
        r.to_display_text.should_equal "Error: Tableau Hyper files do not support columns of type Mixed"
        written_file.exists.should_equal False

    group_builder.specify "should be able to write all the types at once" <|
        t1 = enso_project.data/'all_data_types.csv' . read
        t2 = t1.remove_columns 'appointment_datetime_datetime_withtimezone'
        can_round_trip t2

    group_builder.specify "in dry run mode file should not be written and warns" <|
        Context.Output.with_disabled <|
            written_file = get_temp_file
            t = Table.input [['A', ['a']]]
            result = t.write written_file
            written_file.exists.should_equal False
            Problems.expect_only_warning Dry_Run_Operation result

    group_builder.specify "in dry run mode with existing file should not be overwritten and warns" <|
        written_file = get_temp_file
        t1 = Table.input [['A', ['a']]]
        t1.write written_file
        
        Context.Output.with_disabled <|
            t2 = Table.input [['B', ['b']]]
            t2.write written_file
            result = t2.write written_file
            written_table_in_hyper = Hyper_File.new written_file . tables . first
            written_table_in_hyper.read.should_equal t1
            Problems.expect_only_warning Dry_Run_Operation result
        
        written_file.delete

    group_builder.specify "in dry run mode records are written to a temporary file" <|
        Context.Output.with_disabled <|
            written_file = get_temp_file
            t = Table.input [['A', ['a']]]
            result = t.write written_file
            written_file.exists.should_equal False
            Problems.expect_only_warning Dry_Run_Operation result
            t2 = Hyper_File.new result . tables . first
            t2.read.should_equal t

    group_builder.specify "in dry run mode only first 1000 records are written to a temporary file" <|
        Context.Output.with_disabled <|
            written_file = get_temp_file
            t = 0.up_to 2000 . to_table
            result = t.write written_file
            written_file.exists.should_equal False
            Problems.expect_only_warning Dry_Run_Operation result
            t2 = Hyper_File.new result . tables . first
            t2.read.should_equal (t.take 1000)

    group_builder.specify "not in dry run mode all records are written" <|
        t = 0.up_to 2000 . to_table
        can_round_trip t

    group_builder.specify "by default backup file and overwrite table" <|
        written_file = get_temp_file
        t1 = Table.input [['A', ['a']]]
        t1.write written_file
        t2 = Table.input [['B', ['b']]]
        t2.write written_file
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal t2
        backup_file = File.new (written_file.path + ".bak")
        backup_file_written_table_in_hyper = Hyper_File.new backup_file . tables . first
        backup_file_written_table_in_hyper.read.should_equal t1
        written_file.delete
        backup_file.delete

    group_builder.specify "error on existing file if in on_existing_file=..Error mode" <|
        written_file = get_temp_file
        t1 = Table.input [['A', ['a']]]
        t1.write written_file
        t2 = Table.input [['B', ['b']]]
        r = t2.write written_file on_existing_file=..Error
        r.should_fail_with File_Error
        r.catch.should_be_a File_Error.Already_Exists

        ## Data is still t1 as we didn't overwrite
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal t1

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "appends to existing file simple happy case" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col1', ['b']]]
        t2.write written_file on_existing_file=..Append

        ## Data is t1 and t2
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal (t1.union t2)

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "appends with column name matching" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']], ['Col1', ['a']]]
        t2.write written_file on_existing_file=..Append match_columns=..By_Name

        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal (Table.input [['Col1', ['a', 'a']], ['Col2', ['b', 'b']]])

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "appends with positional matching" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']], ['Col1', ['a']]]
        t2.write written_file on_existing_file=..Append match_columns=..By_Position

        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal (Table.input [['Col1', ['a', 'b']], ['Col2', ['b', 'a']]])

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "additional columns is an error (by name)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']], ['Col1', ['a']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Name
        r.should_fail_with Unmatched_Columns
        r.catch.should_equal (Unmatched_Columns.Error ["Col2"])

        ## Data is still t1 as we didn't append
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal t1

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete
        

    group_builder.specify "additional columns is an error (by position)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']], ['Col1', ['a']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Position
        r.should_fail_with Unmatched_Columns
        r.catch.should_equal (Unmatched_Columns.Error ["Col1"])

        ## Data is still t1 as we didn't append
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal t1

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "not enough columns warns (By_Name)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Name
        Problems.expect_only_warning (Unmatched_Columns.Error ["Col1"]) r

        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal (Table.input [['Col1', ['a', Nothing]], ['Col2', ['b', 'b']]])

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "not enough columns warns (By_Position)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Position
        Problems.expect_only_warning (Unmatched_Columns.Error ["Col2"]) r

        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal (Table.input [['Col1', ['a', 'b']], ['Col2', ['b', Nothing]]])

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "not enough columns can be escalated to error (By_Name)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Name on_problems=..Report_Error
        r.should_fail_with Unmatched_Columns
        r.catch.should_equal (Unmatched_Columns.Error ["Col1"])

        ## Data is still t1 as we didn't append
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal t1

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "not enough columns warning can be ignored (By_Name)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Name on_problems=..Ignore
        Problems.assume_no_problems r

        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal (Table.input [['Col1', ['a', Nothing]], ['Col2', ['b', 'b']]])

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "not enough columns can be escalated to error (By_Position)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Position on_problems=..Report_Error
        r.should_fail_with Unmatched_Columns
        r.catch.should_equal (Unmatched_Columns.Error ["Col2"])

        ## Data is still t1 as we didn't append
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal t1

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "not enough columns warning can be ignored (By_Position)" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']], ['Col2', ['b']]]
        t1.write written_file

        ## Data is still t1 as we didn't append yet
        written_table_in_hyper_before_append = Hyper_File.new written_file . tables . first
        written_table_in_hyper_before_append.read.should_equal t1

        t2 = Table.input [['Col2', ['b']]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Position on_problems=..Ignore
        Problems.assume_no_problems r

        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal (Table.input [['Col1', ['a', 'b']], ['Col2', ['b', Nothing]]])

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "if types don't match then error" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']]]
        t1.write written_file
        t2 = Table.input [['Col1', [2]]]
        r = t2.write written_file on_existing_file=..Append match_columns=..By_Name 
        r.should_fail_with  Column_Type_Mismatch
        r.catch.to_display_text.should_equal 'The column ["Col1"] expects type TEXT but one of the provided tables had type BIG_INT which is not compatible with it.'

        ## Data is still t1 as we didn't overwrite
        written_table_in_hyper = Hyper_File.new written_file . tables . first
        written_table_in_hyper.read.should_equal t1

        ## backup file is not created
        backup_file = File.new (written_file.path + ".bak")
        backup_file.exists.should_equal False

        written_file.delete

    group_builder.specify "writing to 2 different tables" <|
        written_file = get_temp_file
        t1 = Table.input [['Col1', ['a']]]
        t1.write written_file (..Hyper_Table "MySchemaName" "Table1")
        t2 = Table.input [['Col2', [2]]]
        t2.write written_file (..Hyper_Table "MySchemaName" "Table2")

        written_table1_in_hyper = Hyper_File.new written_file . tables . at 0
        written_table1_in_hyper.read.should_equal t1

        written_table2_in_hyper = Hyper_File.new written_file . tables . at 1
        written_table2_in_hyper.read.should_equal t2

        backup_file = File.new (written_file.path + ".bak")
        backup_file_written_table_in_hyper = Hyper_File.new backup_file . tables . first
        backup_file_written_table_in_hyper.read.should_equal t1
        written_file.delete
        backup_file.delete
