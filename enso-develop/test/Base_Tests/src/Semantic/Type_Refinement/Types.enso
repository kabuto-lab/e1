from project.Semantic.Type_Refinement.Hidden_Conversions import all

type A
    A_Ctor x

    a_method self = "A method"
    a_id_unchecked self = self
    a_id self -> A = self

type B
    B_Ctor x

    b_method self = "B method"
    b_id_unchecked self = self
    b_id self -> B = self

type X
    X_Ctor x

    x_method self = "X method"

make_a_and_b field=1 -> A & B =
    a = A.A_Ctor field
    # Relies on the hidden conversion
    (a : A & B)

make_abx -> A & B & X =
    a = A.A_Ctor 1
    # Relies on the hidden conversions
    (a : A & B & X)
