from Standard.Base import all

# Imports of Cloud internals needed for this helper.
import Standard.Base.Enso_Cloud.Internal.Existing_Enso_Asset.Existing_Enso_Asset
import Standard.Base.Enso_Cloud.Internal.Utils

## Standard library does not provide a way to create credentials because this is
   normally done in the Cloud Dashboard.
   Thus we provide a basic version of this functionality in the test suite.
   This file needs `--disable-private-check` as it uses Cloud internals.
create_example_credential parent_directory name =
    parent_directory_asset = Existing_Enso_Asset.get_asset_reference_for parent_directory
    example_scopes = ["https://www.googleapis.com/auth/spreadsheets"]
    nonce = Random.uuid
    input = JS_Object.from_pairs <|
        [["type", "Google"], ["scopes", example_scopes]]
    metadata = JS_Object.from_pairs <|
        [["input", input], ["nonce", nonce]]
    request_payload = JS_Object.from_pairs <|
        [["name", name], ["value", metadata], ["parentDirectoryId", parent_directory_asset.id]]

    Utils.http_request_as_json ..Post ((URI.from Utils.cloud_root_uri) / "secrets") request_payload
    Enso_Secret.get name parent=parent_directory
