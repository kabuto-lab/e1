from Standard.Base import all

from Standard.Test import all

import enso_dev.Cloud_Tests.Network.Enso_Cloud.Cloud_Tests_Setup.Cloud_Tests_Setup
import enso_dev.Cloud_Tests.Network.Enso_Cloud.Cloud_Tests_Setup.Temporary_Directory

from project.Cloud_Helpers.Credentials import create_example_credential

add_specs suite_builder (setup : Cloud_Tests_Setup = Cloud_Tests_Setup.prepare) =
    suite_builder.group "Enso Cloud Credentials" pending=setup.real_cloud_pending group_builder->
        subdirectory_for_tests = Temporary_Directory.make "Secrets"
        group_builder.teardown subdirectory_for_tests.cleanup

        group_builder.specify "should report as credentials" <| setup.with_prepared_environment <|
            credential = create_example_credential subdirectory_for_tests.get "test_google_credential"
            credential.should_be_a Enso_Secret
            Panic.with_finalizer credential.delete <|
                credential.is_credential.should_be_true
                credential.credential_service_name.should_equal "Google"
                credential.to_text . should_contain "credentials for Google"
                credential.to_text . should_contain "waiting for authentication"

main filter=Nothing =
    suite = Test.build suite_builder->
        add_specs suite_builder
    suite.run_with_filter filter
