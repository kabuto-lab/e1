NAME "enso.exe"

;
; Workaround for "too many exported symbols" of OpenJDK25 static libraries
; Based on investigation carried in https://github.com/JaroslavTulach/LaunchJdkViaJni/pull/4#discussion_r2461305126
;
; Use following command to regenerate `enso.exp` and `enso.lib` sibling files:
;
; "c:/Program Files/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/14.44.35207/bin/Hostx64/x64/lib.exe" /DEF:enso.def
;

EXPORTS
    getEncodingFromLangID
    getJavaIDFromLangID
    JDK_LoadSystemLibrary
    jio_snprintf
    JNI_CreateJavaVM
    JNI_GetCreatedJavaVMs
    JNI_GetDefaultJavaVMInitArgs
    JNU_CallMethodByName
    JNU_CallMethodByNameV
    JNU_CallStaticMethodByName
    JNU_ClassString
    JNU_GetEnv
    JNU_GetFieldByName
    JNU_GetStaticFieldByName
    JNU_IsInstanceOfByName
    JNU_NewObjectByName
    JNU_NewStringPlatform
    JNU_SetFieldByName
    JNU_ThrowArrayIndexOutOfBoundsException
    JNU_ThrowByName
    JNU_ThrowIllegalArgumentException
    JNU_ThrowInternalError
    JNU_ThrowIOException
    JNU_ThrowNullPointerException
    JNU_ThrowOutOfMemoryError
    JVM_CurrentTimeMillis
    JVM_IsStaticallyLinked
    JVM_RaiseSignal
