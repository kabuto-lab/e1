from Standard.Base import all
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument

from Standard.Table import Table

import project.DB_Table.DB_Table
import project.Errors.Table_Not_Found
import project.Internal.IR.SQL_IR_Source.SQL_IR_Source
import project.Internal.IR.SQL_IR_Statement.SQL_IR_Statement
import project.SQL.SQL_Statement
from project.DB_Table import make_table

polyglot java import java.util.UUID

type SQL_Query
    ## Query a whole table or view.
    Table_Name (name : Text = Missing_Argument.throw "name")

    ## Raw SQL query statement.
    Raw_SQL (sql : Text = Missing_Argument.throw "sql")

    ## ---
       private: true
       ---
    to_db_table self connection alias:Text = alias.if_not_error <|
        handle_sql_errors = connection.base_connection.jdbc_connection.sql_error_handler
        case self of
            SQL_Query.Table_Name name ->
                table_naming_helper = connection.base_connection.table_naming_helper
                table_naming_helper.verify_table_name name <|
                    make_table_for_name connection name "" alias
            SQL_Query.Raw_SQL raw_sql -> handle_sql_errors <|
                connection.dialect.ensure_query_has_no_holes connection.jdbc_connection raw_sql . if_not_error <|
                    make_table_from_query connection raw_sql alias

## Enhanced SQL_Query that also carries schema information.
type SQL_Query_With_Schema
    ## Query a whole table or view.
    Table_Name (name : Text = Missing_Argument.throw "name") (schema : Text = "")

    ## Raw SQL query statement.
    Raw_SQL (sql : Text = Missing_Argument.throw "sql")

    ## ---
       private: true
       ---
    to_db_table self connection alias:Text = alias.if_not_error <|
        handle_sql_errors = connection.base_connection.jdbc_connection.sql_error_handler
        case self of
            SQL_Query_With_Schema.Table_Name name schema ->
                table_naming_helper = connection.base_connection.table_naming_helper
                table_naming_helper.verify_table_name name <|
                    make_table_for_name connection name schema alias
            SQL_Query_With_Schema.Raw_SQL raw_sql -> handle_sql_errors <|
                connection.dialect.ensure_query_has_no_holes connection.jdbc_connection raw_sql . if_not_error <|
                    make_table_from_query connection raw_sql alias

## ---
   private: true
   ---
SQL_Query.from (that:Text) = SQL_Query.Table_Name that

## ---
   private: true
   ---
SQL_Query_With_Schema.from (that:Text) = SQL_Query_With_Schema.Table_Name that

## ---
   private: true
   ---
SQL_Query_With_Schema.From (that:SQL_Query) = case that of
    SQL_Query.Table_Name name -> SQL_Query_With_Schema.Table_Name name ""
    SQL_Query.Raw_SQL sql -> SQL_Query_With_Schema.Raw_SQL sql

## ---
   private: true
   ---
make_table_for_name connection name schema alias internal_temporary_keep_alive_reference=Nothing =
    handle_sql_errors = connection.base_connection.jdbc_connection.sql_error_handler
    result = handle_sql_errors <|
        ctx = SQL_IR_Source.for_table name schema (if alias == "" then name else alias) internal_temporary_keep_alive_reference
        statement = connection.dialect.generate_sql (SQL_IR_Statement.Select Nothing ctx)
        columns = connection.base_connection.fetch_columns statement
        ## In case of accessing an existing table, we assume that column names
           are distinguishable by the backend, so any issues that are caught
           only affect Enso columns, and just renaming Enso columns is enough to
           fix that - so we are good with just attaching the problems as a
           warning. We do not want to fail, as we do want to allow the user to
           access any table already present in the database.
        make_table connection name columns ctx on_problems=Problem_Behavior.Report_Warning
    if result.is_error then
        Error.throw (Table_Not_Found.Error name)
    result

## ---
   private: true
   ---
make_table_from_query connection query:Text|SQL_Statement alias:Text -> Table & DB_Table & Any =
    columns = connection.base_connection.fetch_columns query
    name = if alias == "" then (UUID.randomUUID.to_text) else alias
    ctx = SQL_IR_Source.for_query query name
    r = make_table connection name columns ctx on_problems=Problem_Behavior.Report_Error

    ## Any problems are treated as errors - e.g. if the query
       contains clashing column names, it may very likely lead to
       data corruption. Our renaming mechanism is used to fix issues
       with existing tables with problematic names, but that
       mechanism will only provide a false-sense of security in case
       of a query, whereas a query like `SELECT 1 AS "A", 2 AS "A"`
       will actually result in both columns `A` and `A 1` containing
       the value 1; and value 2 being lost. That is why such queries
       must fail.
    r.catch Any error->
        Error.throw (Illegal_Argument.Error "The provided custom SQL query is invalid and may suffer data corruption when being processed, especially if it contains aliased column names, it may not be interpreted correctly. Please ensure the names are unique. The original error was: "+error.to_display_text cause=error)
