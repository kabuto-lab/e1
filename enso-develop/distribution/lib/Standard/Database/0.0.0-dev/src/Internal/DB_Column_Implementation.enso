private

from Standard.Base import all
import Standard.Base.Data.Read.Many_Files_List.Many_Files_List
import Standard.Base.Errors.Common.Floating_Point_Equality
import Standard.Base.Errors.Common.Index_Out_Of_Bounds
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument
import Standard.Base.Errors.Illegal_State.Illegal_State
import Standard.Base.Internal.Rounding_Helpers
from Standard.Base.Metadata.Widget import Text_Input
from Standard.Base.Widget_Helpers import make_format_chooser

import Standard.Table.Fill_With.Fill_With
import Standard.Table.Internal.Column_Naming_Helper.Column_Naming_Helper
import Standard.Table.Internal.Date_Time_Helpers
import Standard.Table.Internal.Java_Problems
import Standard.Table.Internal.Problem_Builder.Problem_Builder
import Standard.Table.Internal.Value_Type_Helpers
import Standard.Table.Internal.Widget_Helpers
import Standard.Table.Refined_Types.Text_Column.Text_Column
import Standard.Table.Rows_To_Read.Rows_To_Read
from Standard.Table import Auto, Column, Data_Formatter, Previous_Value, Table, Value_Type
from Standard.Table.Errors import Inexact_Type_Coercion, Invalid_Value_Type
from Standard.Table.Internal.Cast_Helpers import check_cast_compatibility
from Standard.Table.Internal.Column_Type_Helpers import get_underlying_from_column

import project.Connection.Connection.Connection
import project.DB_Column.DB_Column
import project.DB_Table.DB_Table
import project.Internal.Helpers
import project.Internal.IR.Internal_Column.Internal_Column
import project.Internal.IR.SQL_IR_Expression.SQL_IR_Expression
import project.Internal.IR.SQL_IR_Source.SQL_IR_Source
import project.Internal.IR.SQL_IR_Statement.SQL_IR_Statement
import project.Internal.Replace_Params.Replace_Params
import project.Internal.SQL_Type_Reference.SQL_Type_Reference
import project.Internal.Type_Refinements.DB_Column_Refinements
import project.SQL.SQL_Statement
import project.SQL.SQL_Type
from project.Errors import Implicit_DB_Table_Read, Integrity_Error, Unsupported_Database_Operation

type DB_Column_Implementation
    name (this_column : Column & DB_Column) = this_column.internal_name

    dialect_name (this_column : Column & DB_Column) = this_column.connection.dialect.name

    display (this_column : Column & DB_Column) show_rows:Integer format_terminal:Boolean =
        this_column.to_table.display show_rows format_terminal

    to_js_object_implementation (this_column : Column & DB_Column) = this_column.to_sql.to_js_object

    to_table (this_column : Column & DB_Column) =
        DB_Table.new this_column.name this_column.connection [Internal_Column.from this_column] this_column.context

    info (this_column : Column & DB_Column) = this_column.to_table.column_info

    read (this_column : Column & DB_Column) (max_rows : Rows_To_Read) =
        this_column.to_table.read max_rows . at 0

    to_vector (this_column : Column & DB_Column) =
        Warning.attach (Implicit_DB_Table_Read.Warning "DB_Column.to_vector") <|
            this_column.read DB_Column_Implementation.default_row_limit_for_read . to_vector

    at (this_column : Column & DB_Column) index:Integer =
        this_column.get index (Error.throw (Index_Out_Of_Bounds.Error index this_column.row_count))

    get (this_column : Column & DB_Column) index:Integer ~default:Any =
        if index < 0 then Error.throw (Unsupported_Database_Operation.Error "Reading backwards from end") else
            this_column.read (..First index+1) . get index default

    first (this_column : Column & DB_Column) = this_column.at 0

    value_type (this_column : Column & DB_Column) =
        mapping = this_column.connection.type_mapping
        mapping.sql_type_to_value_type this_column.sql_type_reference.get

    inferred_precise_value_type (this_column : Column & DB_Column) =
        this_column.value_type

    should_be_selected_by_type (this_column : Column & DB_Column) (value_type : Value_Type) =
        mapping = this_column.connection.type_mapping
        mapping.is_same_type this_column.value_type value_type

    to_sql (this_column : Column & DB_Column) = this_column.to_table.to_sql

    row_count (this_column : Column & DB_Column) = this_column.to_table.row_count

    count_nothing (this_column : Column & DB_Column) =
        this_column.to_table.filter 0 Filter_Condition.Is_Nothing . row_count

    count (this_column : Column & DB_Column) =
        this_column.to_table.filter 0 Filter_Condition.Not_Nothing . row_count

    equals (this_column : Column & DB_Column) (other : Column | Any) =
        make_equality_check_with_floating_point_handling this_column other "=="

    equals_ignore_case (this_column : Column & DB_Column) (other : Column | Any) locale:Locale =
        Value_Type.expect_text this_column <|
            Value_Type.expect_text other <|
                Helpers.assume_default_locale locale <|
                    new_name = (naming_helper this_column).function_name "equals_ignore_case" [this_column, other]
                    make_binary_op this_column "EQUALS_IGNORE_CASE" other new_name

    not_equals (this_column : Column & DB_Column) (other : Column | Any) =
        make_equality_check_with_floating_point_handling this_column other "!="

    greater_than_eq (this_column : Column & DB_Column) (other : Column | Any) = Value_Type.expect_comparable this_column other <|
        make_binary_op this_column ">=" other

    less_than_eq (this_column : Column & DB_Column) (other : Column | Any) = Value_Type.expect_comparable this_column other <|
        make_binary_op this_column "<=" other

    greater_than (this_column : Column & DB_Column) (other : Column | Any) = Value_Type.expect_comparable this_column other <|
        make_binary_op this_column ">" other

    less_than (this_column : Column & DB_Column) (other : Column | Any) = Value_Type.expect_comparable this_column other <|
        make_binary_op this_column "<" other

    between (this_column : Column & DB_Column) (lower : Column | Any) (upper : Column | Any) =
        Value_Type.expect_comparable this_column lower <|
            Value_Type.expect_comparable this_column upper <|
                new_name = (naming_helper this_column).concat <|
                    [(naming_helper this_column).to_expression_text this_column, "between", (naming_helper this_column).to_expression_text lower, "and", (naming_helper this_column).to_expression_text upper]
                make_op this_column "BETWEEN" [lower, upper] new_name

    add (this_column : Column & DB_Column) (other : Column | Any) =
        new_name = (naming_helper this_column).binary_operation_name "+" this_column other
        case Value_Type_Helpers.resolve_addition_kind this_column other of
            Value_Type_Helpers.Addition_Kind.Numeric_Add ->
                make_binary_op this_column "ADD_NUMBER" other new_name
            Value_Type_Helpers.Addition_Kind.Text_Concat ->
                make_binary_op this_column "ADD_TEXT" other new_name
            Nothing -> this_column.const Nothing

    minus (this_column : Column & DB_Column) (other : Column | Any) =
        case Value_Type_Helpers.resolve_subtraction_kind this_column other of
            Value_Type_Helpers.Subtraction_Kind.Numeric_Subtract ->
                make_binary_op this_column "-" other
            Nothing -> this_column.const Nothing
            _ ->
                Error.throw (Unsupported_Database_Operation.Error "Subtracting date/time value")

    multiply (this_column : Column & DB_Column) (other : Column | Any) =
        Value_Type_Helpers.check_binary_numeric_op this_column other <|
            make_binary_op this_column "*" other

    divide (this_column : Column & DB_Column) (other : Column | Any) =
        Value_Type_Helpers.check_binary_numeric_op this_column other <|
            other_is_decimal = case other of
                _ : Column -> other.value_type.is_decimal
                _ -> False
            either_is_decimal = this_column.value_type.is_decimal || other_is_decimal
            new_name = (naming_helper this_column).binary_operation_name "/" this_column other
            if either_is_decimal then make_binary_op this_column "DECIMAL_DIV" other new_name else
                make_binary_op this_column "/" other new_name

    modulus (this_column : Column & DB_Column) (other : Column | Any) =
        Value_Type_Helpers.check_binary_numeric_op this_column other <|
            other_type = Value_Type_Helpers.find_argument_type other
            # Different implementation may be used for integer types.
            op = if this_column.value_type.is_integer && (other_type.is_nothing || other_type.is_integer) then "%" else "MOD"
            new_name = (naming_helper this_column).binary_operation_name "%" this_column other
            make_binary_op this_column op other new_name

    power (this_column : Column & DB_Column) (other : Column | Any) =
        Value_Type_Helpers.check_binary_numeric_op this_column other <|
            make_binary_op this_column '^' other

    and (this_column : Column & DB_Column) (other : Column | Any) =
        Value_Type_Helpers.check_binary_boolean_op this_column other <|
            new_name = (naming_helper this_column).binary_operation_name "&&" this_column other
            make_binary_op this_column "AND" other new_name

    or (this_column : Column & DB_Column) (other : Column | Any) =
        Value_Type_Helpers.check_binary_boolean_op this_column other <|
            new_name = (naming_helper this_column).binary_operation_name "||" this_column other
            make_binary_op this_column "OR" other new_name

    not (this_column : Column & DB_Column) =
        Value_Type.expect_boolean this_column <|
            new_name = (naming_helper this_column).concat ["not", (naming_helper this_column).to_expression_text this_column]
            make_unary_op this_column "NOT" new_name

    iif (this_column : Column & DB_Column) when_true:Any when_false:Any =
        Value_Type.expect_boolean this_column <|
            common_type = Value_Type_Helpers.find_common_type_for_arguments [when_true, when_false]
            common_type.if_not_error <|
                new_name = (naming_helper this_column).concat <|
                    ["if", (naming_helper this_column).to_expression_text this_column, "then", (naming_helper this_column).to_expression_text when_true, "else", (naming_helper this_column).to_expression_text when_false]
                op_result = make_op this_column "IIF" [when_true, when_false] new_name
                adapt_unified_column op_result common_type

    const (this_column : Column & DB_Column) value = this_column.to_table.make_constant_column value

    round (this_column : Column & DB_Column) decimal_places:Integer (rounding_mode : Rounding_Mode) =
        Rounding_Helpers.check_decimal_places decimal_places <| Value_Type.expect_numeric this_column <|
            if should_use_builtin_round this_column decimal_places rounding_mode then round_builtin this_column decimal_places rounding_mode else
                short_circuit_special_floating_point this_column <|
                    case this_column.value_type of
                        Value_Type.Integer _ -> round_integer this_column decimal_places rounding_mode
                        Value_Type.Float _ -> round_float this_column decimal_places rounding_mode
                        Value_Type.Decimal _ _ -> round_decimal this_column decimal_places rounding_mode
                        _ ->
                            expected = "Decimal, Float, or Integer"
                            Error.throw (Invalid_Value_Type.Column expected this_column.value_type this_column.name)

    truncate (this_column : Column & DB_Column) =
        new_name = (naming_helper this_column).function_name "truncate" [this_column]
        precise_value_type = this_column.inferred_precise_value_type
        case precise_value_type.is_numeric of
            True ->
                short_circuit_special_floating_point this_column <|
                    make_unary_op this_column "TRUNCATE" new_name
            False -> case precise_value_type == Value_Type.Date_Time of
                True ->
                    op = "date_trunc_to_day"
                    case this_column.connection.dialect.is_operation_supported op of
                        True ->
                            make_unary_op this_column op new_name
                        False ->
                            Error.throw (Unsupported_Database_Operation.Error ("`Column.truncate` for `Date_Time`"))
                False -> Error.throw <| Invalid_Value_Type.Column "Numeric or Date_Time" this_column.value_type this_column.name

    ceil (this_column : Column & DB_Column) =
        Value_Type.expect_numeric this_column <| short_circuit_special_floating_point this_column <|
            new_name = (naming_helper this_column).function_name "ceil" [this_column]
            make_unary_op this_column "CEIL" new_name

    floor (this_column : Column & DB_Column) =
        Value_Type.expect_numeric this_column <| short_circuit_special_floating_point this_column <|
            new_name = (naming_helper this_column).function_name "floor" [this_column]
            make_unary_op this_column "FLOOR" new_name

    coalesce (this_column : Column & DB_Column) (values : Any | Vector Any) =
        vec = Vector.unify_vector_or_element values
        args_with_self = [this_column]+vec
        common_type = Value_Type_Helpers.find_common_type_for_arguments args_with_self
        common_type.if_not_error <|
            new_name = (naming_helper this_column).function_name "coalesce" args_with_self
            op_result = make_op this_column "COALESCE" vec new_name
            adapt_unified_column op_result common_type

    min (this_column : Column & DB_Column) (values : Any | Vector Any) =
        Value_Type_Helpers.check_multi_argument_comparable_op this_column values <|
            args = Vector.unify_vector_or_element values
            new_name = (naming_helper this_column).function_name "min" [this_column]+args
            make_op this_column "ROW_MIN" args new_name

    max (this_column : Column & DB_Column) (values : Any | Vector Any) =
        Value_Type_Helpers.check_multi_argument_comparable_op this_column values <|
            args = Vector.unify_vector_or_element values
            new_name = (naming_helper this_column).function_name "max" [this_column]+args
            make_op this_column "ROW_MAX" args new_name

    is_nothing_implementation (this_column : Column & DB_Column) =
        new_name = (naming_helper this_column).concat [(naming_helper this_column).to_expression_text this_column, "is Nothing"]
        make_unary_op this_column "IS_NULL" new_name

    is_nan (this_column : Column & DB_Column) = Value_Type.expect_numeric this_column <|
        new_name = (naming_helper this_column).function_name "is_nan" [this_column]
        make_unary_op this_column "IS_NAN" new_name

    is_infinite (this_column : Column & DB_Column) = Value_Type.expect_numeric this_column <|
        new_name = (naming_helper this_column).function_name "is_infinite" [this_column]
        make_unary_op this_column "IS_INF" new_name

    is_finite (this_column : Column & DB_Column) = Value_Type.expect_numeric this_column <|
        new_name = (naming_helper this_column).function_name "is_finite" [this_column]
        make_unary_op this_column "IS_FINITE" new_name

    is_empty (this_column : Column & DB_Column) = Value_Type.expect_text this_column <|
        new_name = (naming_helper this_column).concat [(naming_helper this_column).to_expression_text this_column, "is empty"]
        make_unary_op this_column "IS_EMPTY" new_name

    is_present (this_column : Column & DB_Column) =
        new_name = (naming_helper this_column).function_name "is_present" [this_column]
        this_column.is_nothing.not . rename new_name

    is_blank (this_column : Column & DB_Column) treat_nans_as_blank:Boolean =
        new_name = (naming_helper this_column).function_name "is_blank" [this_column]
        self_type = this_column.value_type
        is_blank = case self_type.is_text of
            True -> this_column.is_empty
            False -> this_column.is_nothing
        result = case treat_nans_as_blank && self_type.is_floating_point && this_column.connection.dialect.flagged ..Supports_Separate_NaN of
            True -> is_blank || this_column.is_nan
            False -> is_blank
        result.rename new_name

    fill_nothing (this_column : Column & DB_Column) (default : Column | Previous_Value | Any) =
        if Previous_Value == default then Error.throw (Unsupported_Database_Operation.Error "Previous_Value argument") else
            common_type = Value_Type_Helpers.find_common_type_for_arguments [this_column, default]
            common_type.if_not_error <|
                op_result = make_binary_op this_column "FILL_NULL" default this_column.name
                adapt_unified_column op_result common_type

    fill_empty (this_column : Column & DB_Column) (default : Column | Previous_Value | Any) =
        if Previous_Value == default then Error.throw (Unsupported_Database_Operation.Error "The Previous_Value argument") else
            Value_Type.expect_text this_column <| Value_Type.expect_text default <|
                result = this_column.is_empty.iif default this_column
                result.rename this_column.name

    offset (this_column : Column & DB_Column) n:Integer fill_with:Fill_With =
        _ = [this_column, n, fill_with]
        Error.throw (Unsupported_Database_Operation.Error "offset")

    rename (this_column : Column & DB_Column) name:Text = (naming_helper this_column).ensure_name_is_valid name <|
        DB_Column.new name this_column.connection this_column.sql_type_reference this_column.expression this_column.context

    sort (this_column : Column & DB_Column) order:Sort_Direction missing_last:Boolean by =
        if Nothing != by then
            Error.throw (Unsupported_Database_Operation.Error "Using `by` argument in `sort`")
        if missing_last != True then
            Error.throw (Unsupported_Database_Operation.Error "Using `missing_last` argument in `sort`")
        this_column.to_table.sort [..Index 0 order] . at 0

    take (this_column : Column & DB_Column) (range : Index_Sub_Range | Range | Integer) = this_column.to_table.take range . at 0

    drop (this_column : Column & DB_Column) (range : Index_Sub_Range | Range | Integer) = this_column.to_table.drop range . at 0

    starts_with (this_column : Column & DB_Column) (other : Column | Text | Any) case_sensitivity:Case_Sensitivity =
        new_name = (naming_helper this_column).function_name "starts_with" [this_column, other]
        make_text_case_op this_column "STARTS_WITH" other case_sensitivity new_name

    ends_with (this_column : Column & DB_Column) (other : Column | Text | Any) case_sensitivity:Case_Sensitivity =
        new_name = (naming_helper this_column).function_name "ends_with" [this_column, other]
        make_text_case_op this_column "ENDS_WITH" other case_sensitivity new_name

    text_length (this_column : Column & DB_Column) =
        Value_Type.expect_text this_column <|
            new_name = (naming_helper this_column).function_name "text_length" [this_column]
            make_unary_op this_column "LENGTH" new_name

    text_left this_column  n:Column|Integer =
        Value_Type.expect_text this_column <|
            new_name = (naming_helper this_column).function_name "text_left" [this_column, n]
            (this_column : Text_Column) . left n . rename new_name

    text_right this_column n:Column|Integer =
        Value_Type.expect_text this_column <|
            new_name = (naming_helper this_column).function_name "text_right" [this_column, n]
            (this_column : Text_Column) . right n . rename new_name

    text_mid this_column (start : Column | Any) (length : Column | Any) =
        Value_Type.expect_text this_column <|
            new_name = (naming_helper this_column).function_name "text_mid" [this_column, start, length]
            (this_column : Text_Column) . mid start length . rename new_name

    contains (this_column : Column & DB_Column) (other : Column | Text | Any) case_sensitivity:Case_Sensitivity =
        new_name = (naming_helper this_column).function_name "contains" [this_column, other]
        make_text_case_op this_column "CONTAINS" other case_sensitivity new_name

    like (this_column : Column & DB_Column) (pattern : Column | Text | Any) =
        Value_Type.expect_text this_column <|
            Value_Type.expect_text pattern <|
                new_name = (naming_helper this_column).binary_operation_name "like" this_column pattern
                make_binary_op this_column "LIKE" pattern new_name

    regex_match (this_column : Column & DB_Column) (pattern : Column | Text | Regex) =
        string_pattern = case pattern of
            Regex.Value _ _ -> pattern.pattern
            _ -> pattern
        Value_Type.expect_text this_column <| Value_Type.expect_text string_pattern <|
            ## regex_match is a match if it matches the entire string. So we wrap in ^ and $.
            pattern_with_start_end = "^" + string_pattern + "$"
            new_name = (naming_helper this_column).binary_operation_name "regex_match" this_column pattern
            if this_column.connection.dialect.is_operation_supported "REGEX_MATCH" then make_binary_op this_column "REGEX_MATCH" pattern_with_start_end new_name else
                Error.throw (Unsupported_Database_Operation.Error ("regex_match"))


    trim (this_column : Column & DB_Column) where:Location=..Both (what : Column | Text) =
        Value_Type.expect_text this_column <| Value_Type.expect_text what <|
            new_name = (naming_helper this_column).function_name "trim" [this_column]
            operator = case where of
                Location.Both -> "TRIM"
                Location.Left -> "LTRIM"
                Location.Right -> "RTRIM"
            if this_column.connection.dialect.is_operation_supported operator then make_binary_op this_column operator what new_name else
                Error.throw (Unsupported_Database_Operation.Error ("`trim "+where.to_text+"`"))

    @new_text (Text_Input display=..Always)
    text_replace (this_column : Column & DB_Column) (term : Text | Regex | Column) (new_text : Text | Column) case_sensitivity:Case_Sensitivity only_first:Boolean =
        Value_Type.expect_text this_column <| case_sensitivity.disallow_non_default_locale <|
            input_type = if term.is_error then term else Meta.type_of term
            params = Replace_Params.Value input_type case_sensitivity only_first
            this_column.connection.dialect.if_replace_params_supports params <|
                new_name = (naming_helper this_column).function_name "replace" [this_column, term, new_text]
                raw_term = case term of
                    _ : Regex -> term.pattern
                    _ -> term
                make_op this_column "REPLACE" [raw_term, new_text] new_name [term, params]

    text_cleanse (this_column : Column & DB_Column) (remove : Vector Named_Pattern) =
      remove.map (Text_Cleanse.Value _) . fold this_column (current-> tc-> tc.apply current)

    year (this_column : Column & DB_Column) = Value_Type.expect_has_date this_column <|
        make_unary_op this_column "year"

    month (this_column : Column & DB_Column) = Value_Type.expect_has_date this_column <|
        make_unary_op this_column "month"

    day (this_column : Column & DB_Column) = Value_Type.expect_has_date this_column <|
        make_unary_op this_column "day"

    day_of_year (this_column : Column & DB_Column) = Value_Type.expect_has_date this_column <|
        make_unary_op this_column "day_of_year"

    day_of_week (this_column : Column & DB_Column) = Value_Type.expect_has_date this_column <|
        make_unary_op this_column "day_of_week"

    hour (this_column : Column & DB_Column) = Value_Type.expect_has_time this_column <|
        make_unary_op this_column "hour"

    minute (this_column : Column & DB_Column) = Value_Type.expect_has_time this_column <|
        make_unary_op this_column "minute"

    second (this_column : Column & DB_Column) = Value_Type.expect_has_time this_column <|
        make_unary_op this_column "second"

    date_part (this_column : Column & DB_Column) (period : Date_Period | Time_Period) =
        Date_Time_Helpers.make_date_part_function this_column period (column->op_name-> make_unary_op column op_name) (naming_helper this_column)

    date_diff (this_column : Column & DB_Column) (end : Column | Date | Date_Time | Time_Of_Day) (period : Date_Period | Time_Period) =
        Value_Type.expect_type this_column .is_date_or_time "date/time" <|
            my_type = this_column.inferred_precise_value_type
            Value_Type.expect_type end (== my_type) my_type.to_display_text <|
                aligned_period = Date_Time_Helpers.align_period_with_value_type my_type period
                aligned_period.if_not_error <|
                    new_name = (naming_helper this_column).function_name "date_diff" [this_column, end, period]
                    metadata = this_column.connection.dialect.prepare_metadata_for_period aligned_period my_type
                    make_op this_column "date_diff" [end] new_name metadata

    date_add (this_column : Column & DB_Column) (amount : Column | Integer) (period : Date_Period | Time_Period) =
        Value_Type.expect_type this_column .is_date_or_time "date/time" <|
            my_type = this_column.inferred_precise_value_type
            Helpers.expect_specific_integer_type this_column amount <|
                aligned_period = Date_Time_Helpers.align_period_with_value_type my_type period
                aligned_period.if_not_error <|
                    new_name = (naming_helper this_column).function_name "date_add" [this_column, amount, period]
                    metadata = this_column.connection.dialect.prepare_metadata_for_period aligned_period my_type
                    make_op this_column "date_add" [amount] new_name metadata

    is_in (this_column : Column & DB_Column) (vector : Column | Vector | Array) =
        new_name = (naming_helper this_column).binary_operation_name "in" this_column vector
        case vector of
            _ : Vector ->
                ## This is slightly hacky - we don't provide operand types as we want to
                   allow any type to get through and currently we do not have a mapping
                   from Enso types to SQL types (it may be available in the future). So
                   we just rely on Nothing resolving to the current column type. That
                   type may not always match the operands, but the current
                   implementation uses this type only for two purposes: generated SQL
                   visualization (so the color will be consistent with the column type
                   and not the value type - that can be confusing, we probably want to
                   fix it later) and setting up the query - but at the set up this only
                   applies to adding nulls - setting any other object does not check the
                   type at this level anyway.
                result = make_op this_column "IS_IN" operands=vector new_name=new_name
                result.rename new_name
            _ : Array -> this_column.is_in (Vector.from_polyglot_array vector)
            column : Column -> if Helpers.check_connection this_column column . not then (Error.throw (Integrity_Error.Error "Column "+column.name)) else
                in_subquery = SQL_IR_Statement.Select [Pair.new column.name (column:DB_Column).expression] (column:DB_Column).context
                new_expr = SQL_IR_Expression.Operation "IS_IN_COLUMN" [this_column.expression, in_subquery]
                # This mapping should never be imprecise, if there are errors we need to amend the implementation.
                sql_type = this_column.connection.type_mapping.value_type_to_sql Value_Type.Boolean Problem_Behavior.Report_Error
                new_type_ref = SQL_Type_Reference.from_constant sql_type . catch Inexact_Type_Coercion _->
                    Error.throw (Illegal_State.Error "The dialect "+this_column.connection.dialect.name+" does not support a boolean type. The implementation of `is_in` should be revised to account for this. This is an internal issue with the Database library.")
                DB_Column.new new_name this_column.connection new_type_ref new_expr this_column.context

    @format (make_format_chooser include_number=False)
    parse (this_column : Column & DB_Column) (type : Value_Type | Auto) (format : Text | Data_Formatter) on_problems:Problem_Behavior =
        if type == Auto then Error.throw (Unsupported_Database_Operation.Error "`Auto` parse type") else
            if format != "" then Error.throw (Unsupported_Database_Operation.Error "Custom formatting") else
                if this_column.value_type.is_same_type type then this_column else
                    Value_Type.expect_text this_column <|
                        ## In the future we may have some specific logic, for example
                           allowing to support formatting settings. For now, the
                           Database parse just boils down to a simple CAST.
                        internal_do_cast this_column type on_problems


    @format (this_column-> Widget_Helpers.make_format_chooser_for_type this_column.value_type)
    format (this_column : Column & DB_Column) (format : Text | Date_Time_Formatter | Column) locale:Locale =
        _ = [this_column, format, locale]
        Error.throw <| Unsupported_Database_Operation.Error "format"

    cast (this_column : Column & DB_Column) value_type:Value_Type on_problems:Problem_Behavior =
        check_cast_compatibility this_column.value_type value_type <|
            internal_do_cast this_column value_type on_problems

    auto_cast (this_column : Column & DB_Column) shrink_types:Boolean =
        _ = [this_column, shrink_types]
        Error.throw <| Unsupported_Database_Operation.Error "auto_cast"

    map (this_column : Column & DB_Column) (function : Any -> Any) skip_nothing:Boolean (expected_value_type : Value_Type | Auto) =
        _ = [this_column, function, skip_nothing, expected_value_type]
        Error.throw <| Unsupported_Database_Operation.Error "map"

    zip (this_column : Column & DB_Column) (right : Column | Table) (keep_unmatched : Boolean | Report_Unmatched) (right_prefix : Text) on_problems:Problem_Behavior =
        _ = [this_column, right, keep_unmatched, right_prefix, on_problems]
        Error.throw <| Unsupported_Database_Operation.Error "zip"

    as_internal (this_column : Column & DB_Column) = Internal_Column.Value this_column.name this_column.sql_type_reference this_column.expression

    to_text_implementation (this_column : Column & DB_Column) = "(Database Column "+this_column.name.to_text+")"

    default_row_limit_for_read = ..First_With_Warning 1000

naming_helper this_column = (this_column:DB_Column).connection.base_connection.column_naming_helper

## ---
   private: true
   ---
   Helper for case case_sensitivity based text operations
make_text_case_op left op other case_sensitivity new_name =
    result = Value_Type.expect_text left <| Value_Type.expect_text other <| case case_sensitivity of
        Case_Sensitivity.Default -> make_binary_op left op other
        Case_Sensitivity.Sensitive ->
            make_sensitive column =
                make_unary_op column "MAKE_CASE_SENSITIVE" "MAKE_CASE_SENSITIVE"
            cs_other = if other.is_a Column then make_sensitive other else other
            make_binary_op (make_sensitive left) op cs_other
        Case_Sensitivity.Insensitive locale -> Helpers.assume_default_locale locale <|
            fold_case column =
                make_unary_op column "FOLD_CASE" "FOLD_CASE"
            ci_other = if other.is_a Column then fold_case other else other.to_case Case.Lower
            make_binary_op (fold_case left) op ci_other
    result.rename new_name

## ---
   private: true
   ---
make_equality_check_with_floating_point_handling column other op =
    other_name = case other of
        other_column : Column -> "["+other_column.name+"]"
        _ -> other.to_text
    location = "["+column.name+"] "+op+" "+other_name
    Java_Problems.with_map_operation_problem_aggregator location Problem_Behavior.Report_Warning problem_builder->
        if column.value_type.is_floating_point then
            problem_builder.reportFloatingPointEquality -1
        case other of
            other_column : Column ->
                if other_column.value_type.is_floating_point then
                    problem_builder.reportFloatingPointEquality -1
            _ : Float ->
                problem_builder.reportFloatingPointEquality -1
            _ -> Nothing
        make_binary_op column op other

adapt_unified_column (column : Column & DB_Column) expected_type =
    dialect = column.connection.dialect
    mapping = column.connection.type_mapping
    infer_return_type expression =
        SQL_Type_Reference.new column.connection column.context expression
    adapted = dialect.adapt_unified_column (Internal_Column.from column) expected_type infer_return_type mapping
    DB_Column.new column.name column.connection adapted.sql_type_reference adapted.expression column.context

make_op : Column & DB_Column -> Text -> Vector Text -> (Text | Nothing) -> (Any | Nothing) -> Column
make_op this_column op_kind operands new_name metadata=Nothing =
    if this_column.connection.dialect.is_operation_supported op_kind . not then Error.throw (Unsupported_Database_Operation.Error op_kind)

    prepare_operand operand = case operand of
        other_column : Column ->
            if Helpers.check_integrity this_column other_column then (other_column:DB_Column).expression else
                Error.throw (Integrity_Error.Error "Column "+other_column.name)
        sql_expression : SQL_IR_Expression -> sql_expression
        constant -> SQL_IR_Expression.Constant constant

    expressions = operands.map prepare_operand
    new_expr = SQL_IR_Expression.Operation op_kind ([this_column.expression] + expressions) metadata

    mapping = this_column.connection.type_mapping
    infer_from_database_callback expression =
        SQL_Type_Reference.new this_column.connection this_column.context expression
    new_type_ref = mapping.infer_return_type infer_from_database_callback op_kind [this_column]+operands new_expr
    DB_Column.new new_name this_column.connection new_type_ref new_expr this_column.context

make_binary_op : Column & DB_Column -> Text -> Text -> (Text | Nothing) -> Column
make_binary_op this_column op_kind operand new_name=Nothing =
    effective_new_name = new_name.if_nothing <|
        (naming_helper this_column).binary_operation_name op_kind this_column operand
    make_op (this_column : Column & DB_Column) op_kind [operand] effective_new_name

make_unary_op : Column & DB_Column -> Text -> Text|Nothing -> Column
make_unary_op this_column op_kind new_name=Nothing =
    effective_new_name = new_name.if_nothing <|
        (naming_helper this_column).function_name op_kind [this_column]
    make_op (this_column : Column & DB_Column) op_kind [] effective_new_name

internal_do_cast : Column & DB_Column -> Value_Type -> Problem_Behavior -> Column
internal_do_cast this_column value_type on_problems:Problem_Behavior =
    mapping = this_column.connection.type_mapping
    target_sql_type = mapping.value_type_to_sql value_type on_problems
    target_sql_type.if_not_error <|
        infer_from_database new_expression =
            SQL_Type_Reference.new this_column.connection this_column.context new_expression
        new_column = this_column.connection.dialect.make_cast (Internal_Column.from this_column) mapping target_sql_type infer_from_database
        DB_Column.new new_column.name this_column.connection new_column.sql_type_reference new_column.expression this_column.context

should_use_builtin_round : Column & DB_Column -> Integer -> Boolean -> Boolean
should_use_builtin_round this_column decimal_places rounding_mode =
    # Don't use for banker's rounding (unless the dialect has a builtin for it)
    bankers_ok = this_column.connection.dialect.flagged ..Use_Builtin_Bankers || rounding_mode != Rounding_Mode.Bankers
    # Don't use for negative decimal places, if the backend doesn't support it
    negative_dp_ok = decimal_places >= 0 || this_column.connection.dialect.flagged ..Supports_Negative_Decimal_Places
    # Don't use for floating-point inputs if decimal_places != 0, for Postgres
    dp_param_ok = decimal_places == 0 || this_column.value_type.is_floating_point.not || this_column.connection.dialect.flagged ..Supports_Float_Decimal_Places
    bankers_ok && negative_dp_ok && dp_param_ok

round_builtin : Column & DB_Column -> Integer -> Boolean -> Column
round_builtin this_column decimal_places rounding_mode =
    new_name = (naming_helper this_column).function_name "round" [this_column]
    case rounding_mode of
        Rounding_Mode.Bankers ->
                make_binary_op this_column "ROUND_BANKERS" (SQL_IR_Expression.Literal decimal_places.to_text) new_name
        Rounding_Mode.Half_Up ->
            case decimal_places == 0 of
                True ->
                    make_unary_op this_column "ROUND" new_name
                False ->
                    make_binary_op this_column "ROUND" (SQL_IR_Expression.Literal decimal_places.to_text) new_name

round_float : Column & DB_Column -> Integer -> Boolean -> Column
round_float this_column decimal_places rounding_mode =
    new_name = (naming_helper this_column).function_name "round" [this_column]
    scale = 10 ^ decimal_places
    scaled = this_column * scale

    (scaled:DB_Column).let "scaled" scaled->
        round_base = scaled.floor
        (round_base:DB_Column).let "round_base" round_base->
            round_midpoint = (round_base + 0.5) / scale
            (round_midpoint:DB_Column).let "round_midpoint" round_midpoint->
                # The intermediate variable `scaled_truncate_mod_2_equals_0` is a workaround for bug #13282
                scaled_truncate_mod_2_equals_0 = (((scaled.truncate % 2) == 0) : DB_Column)
                scaled_truncate_mod_2_equals_0.let "scaled_truncate_mod_2_equals_0" scaled_truncate_mod_2_equals_0->
                    even_is_up = (this_column >= 0).iif scaled_truncate_mod_2_equals_0.not scaled_truncate_mod_2_equals_0
                    half_goes_up = if rounding_mode == Rounding_Mode.Bankers then even_is_up else this_column >= 0
                    do_round_up = (half_goes_up:DB_Column).let "half_goes_up" x-> x.iif (this_column >= round_midpoint) (this_column > round_midpoint)
                    result = (do_round_up:DB_Column).let "do_round_up" x-> x.iif ((round_base + 1.0) / scale) (round_base / scale)
                    result.rename new_name

round_decimal : Column & DB_Column -> Integer -> Boolean -> Column
round_decimal this_column decimal_places rounding_mode =
    # Construct a constant Decimal column.
    k x = this_column.const x . cast Value_Type.Decimal
    new_name = (naming_helper this_column).function_name "round" [this_column]
    scale = 10 ^ decimal_places
    scaled = this_column * scale
    (scaled:DB_Column).let "scaled" scaled->
        round_base = scaled.floor
        (round_base:DB_Column).let "round_base" round_base->
            round_midpoint = decimal_div (round_base + k 0.5) scale
            (round_midpoint:DB_Column).let "round_midpoint" round_midpoint->
                (((decimal_mod scaled.truncate (k 2)) != k 0) : DB_Column).let "scaled_truncate_mod_2_equals_0" scaled_truncate_mod_2_equals_0->
                    even_is_up = (this_column >= k 0).iif scaled_truncate_mod_2_equals_0.not scaled_truncate_mod_2_equals_0
                    half_goes_up = if rounding_mode == Rounding_Mode.Bankers then even_is_up else this_column >= k 0
                    do_round_up = (half_goes_up:DB_Column).let "half_goes_up" x-> x.iif (this_column >= round_midpoint) (this_column > round_midpoint)
                    result = (do_round_up:DB_Column).let "do_round_up" x-> x.iif (decimal_div (round_base + k 1) scale) (decimal_div round_base scale)
                    result.rename new_name

decimal_div (this_column : Column & DB_Column) other =
    Value_Type.expect_numeric this_column <| Value_Type.expect_numeric other <|
        new_name = (naming_helper this_column).function_name "decimal_div" [this_column, other]
        make_binary_op this_column "DECIMAL_DIV" other new_name

decimal_mod (this_column : Column & DB_Column) other =
    Value_Type.expect_numeric this_column <| Value_Type.expect_numeric other <|
        new_name = (naming_helper this_column).function_name "decimal_mod" [this_column, other]
        make_binary_op this_column "DECIMAL_MOD" other new_name

round_integer this_column decimal_places rounding_mode =
    new_name = (naming_helper this_column).function_name "round" [this_column]
    scale = 10 ^ -decimal_places
    halfway = scale / 2
    remainder = this_column % scale
    (remainder:DB_Column).let "remainer" remainder->
        scaled_down = (this_column / scale).truncate . cast Value_Type.Integer
        (scaled_down:DB_Column).let "scaled_down" scaled_down->
            result_unnudged = scaled_down * scale
            (result_unnudged:DB_Column).let "result_unnudged" result_unnudged->
                if_non_neg =
                    half_goes_up = if rounding_mode == Rounding_Mode.Bankers then (scaled_down % 2) != 0 else this_column >= 0
                    round_up = (half_goes_up:DB_Column).let "half_goes_up" x-> x.iif (remainder >= halfway) (remainder > halfway)
                    (round_up:DB_Column).let "round_up" x-> x.iif (result_unnudged + scale) result_unnudged
                if_neg =
                    half_goes_up = if rounding_mode == Rounding_Mode.Bankers then (scaled_down % 2) == 0 else this_column >= 0
                    round_up = (half_goes_up:DB_Column).let "half_goes_up" x-> x.iif (remainder < -halfway) (remainder <= -halfway)
                    (round_up:DB_Column).let "round_up" x-> x.iif (result_unnudged - scale) result_unnudged

                result = ((this_column >= 0):DB_Column).let "self_gt_0" x-> x.iif if_non_neg if_neg
                result.cast Value_Type.Float . rename new_name

short_circuit_special_floating_point (this_column : Column & DB_Column) exp =
    if this_column.value_type.is_floating_point.not then exp else
        (this_column.is_finite.not.iif this_column exp).rename exp.name

## ---
   private: true
   ---
   This conversion is defined in a `private` module and is never exported.
   It is only available inside of this implementation to allow the `(this_column
   : Column & DB_Column)` type refinement to work.
   It will always succeed, because `DB_Column_Implementation` is only called on
   `DB_Column` columns.
   It is needed, because the base API in `Column` calls this implementation with
   `self` and the `self` loses all the intersection types - so it becomes a 'raw'
   `Column`, losing the `& DB_Column` part. This hidden conversion allows to
   'regain' that part.
DB_Column.from (that : Column) = get_underlying_from_column that
