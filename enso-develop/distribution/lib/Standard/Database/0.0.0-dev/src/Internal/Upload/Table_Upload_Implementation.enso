## These imports bring the type class implementation conversions for
   In_Memory_Table and DB_Table into scope.
   Any external Table implementation that also wants to support this, should
   define its conversion next to its type definition as that is the only way to
   ensure its conversion will be resolved.

from Standard.Base import all
import Standard.Base.Errors.Common.No_Such_Conversion
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument

from Standard.Table import Table
from Standard.Table.Internal.Table_Type_Helpers import get_underlying_from_table

import project.Update_Action.Update_Action
from project.Internal.Upload.DB_Table_Upload_Implementation import all
from project.Internal.Upload.In_Memory_Table_Upload_Implementation import all

## ---
   private: true
   ---
type Table_Upload_Implementation
    private Value implementation

    private resolve table:Table operation_name:Text -> Table_Upload_Implementation =
        handle_no_conversion _ =
            Error.throw (Illegal_Argument.Error "Table."+operation_name+" is not supported for "+table.to_text+".")
        Panic.catch No_Such_Conversion (Table_Upload_Implementation.from (get_underlying_from_table table)) handle_no_conversion

    ## ---
       private: true
       ---
       Call onto the implementation of select_into_database_table.
    select_into_database_table self target_table connection (table_name : Text) primary_key=[] temporary=False on_problems:Problem_Behavior=..Report_Warning =
        self.implementation.select_into_database_table target_table connection table_name primary_key temporary on_problems

    ## ---
       private: true
       ---
       Call onto the implementation of update_rows.
    update_rows self target_table (source_table : Table) (update_action : Update_Action = Update_Action.Update_Or_Insert) (key_columns : Vector | Nothing = Nothing) (error_on_missing_columns : Boolean = False) (on_problems : Problem_Behavior = ..Report_Warning) =
        self.implementation.update_rows target_table source_table update_action key_columns error_on_missing_columns on_problems

    ## ---
       private: true
       ---
       Call onto the implementation of delete_rows.
    delete_rows self target_table (key_values_to_delete : Table) (key_columns=[]) (allow_duplicate_matches : Boolean = False) =
        self.implementation.delete_rows target_table key_values_to_delete key_columns allow_duplicate_matches

## ---
   private: true
   ---
table_upload_from_implementation value implementation =
    _ = value
    Table_Upload_Implementation.Value implementation

