from Standard.Base import all

import Standard.Table.Internal.Java_Problems
import Standard.Table.Internal.Storage
from Standard.Table import Table, Value_Type
from Standard.Table.In_Memory_Table import from_java_table

import project.SQL.SQL_Type

polyglot java import java.sql.ResultSet
polyglot java import org.enso.database.fetchers.ColumnFetcher # necessary for reflection metadata
polyglot java import org.enso.database.fetchers.ColumnFetcherFactory
polyglot java import org.enso.table.data.column.storage.type.AnyObjectType
polyglot java import org.enso.table.data.column.storage.type.DateTimeType

## ---
   private: true
   ---
   Converts a ResultSet into a Table.
result_set_to_table : ResultSet -> Any -> (SQL_Type -> Value_Type | Nothing) -> (Vector (SQL_Type | Nothing) | Nothing) -> Boolean -> Integer -> Table
result_set_to_table result_set column_fetcher_factory sql_type_to_value_type=(_->Nothing) type_overrides=Nothing last_row_only=False row_limit=-1 =
    storageTypeMapper metadata index =
        sql_type = type_overrides.get index . if_nothing <|
            SQL_Type.from_metadata metadata index+1
        value_type = sql_type_to_value_type sql_type
        case value_type of
            Nothing -> AnyObjectType.INSTANCE
            Value_Type.Binary _ _ -> AnyObjectType.INSTANCE
            Value_Type.Unsupported_Data_Type _ _ -> AnyObjectType.INSTANCE
            Value_Type.Mixed -> AnyObjectType.INSTANCE
            Value_Type.Date_Time True -> DateTimeType.INSTANCE_NO_TZ
            _       -> Storage.closest_storage_type value_type

    aggregator = column_fetcher_factory.getAggregatorClass . static
    Java_Problems.with_problem_aggregator problem_aggregator=aggregator Problem_Behavior.Report_Warning java_problem_aggregator->
        column_fetcher = column_fetcher_factory.getColumnFetcherClass . static
        java_table = if last_row_only then column_fetcher.readLastRow result_set java_problem_aggregator storageTypeMapper column_fetcher_factory else
            column_fetcher.readResultSet result_set row_limit java_problem_aggregator storageTypeMapper column_fetcher_factory
        from_java_table java_table
