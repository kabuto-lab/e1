from project.DB_Table import DB_Table, make_literal_table, MAX_LITERAL_ELEMENT_COUNT
from project.Errors import Integrity_Error, SQL_Error, Unsupported_Database_Operation
from project.Internal.DB_Column_Implementation import make_unary_op
from project.Internal.Type_Refinements.DB_Table_Conversions import all

type DB_Table_Implementation
    name (this_table : Table & DB_Table) = this_table.internal_name

    pretty_implementation (this_table : Table & DB_Table) =
        data = this_table.columns.map c->("[" + c.name.pretty + ", " + c.to_vector.pretty + "]") . join ", "
        "DB_Table.new [" + data + "]"

    display (this_table : Table & DB_Table) show_rows:Integer format_terminal:Boolean =
        data_fragment_with_warning = this_table.read (..First_With_Warning show_rows)
        has_more_rows = data_fragment_with_warning.has_warnings warning_type=Not_All_Rows_Downloaded
        data_fragment_cleared = data_fragment_with_warning.remove_warnings Not_All_Rows_Downloaded
        # `row_count` means another Database query is performed, so we only do it if we need to.
        all_rows_count = if has_more_rows then this_table.row_count else data_fragment_cleared.row_count
        Display_Helpers.display_table table=data_fragment_cleared add_row_index=False max_rows_to_show=show_rows all_rows_count=all_rows_count format_terminal=format_terminal

    print (this_table : Table & DB_Table) show_rows:Integer =
        IO.println (this_table.display show_rows format_terminal=True)
        IO.println ''

    to_js_object_implementation (this_table : Table & DB_Table) = case this_table.internal_columns.is_empty of
        True -> JS_Object.from_pairs [["query", Nothing], ["message", "The table has no columns so a query cannot be generated."]]
        False -> this_table.to_sql.to_js_object

    at (this_table : Table & DB_Table) (selector : Integer | Text) =
        case selector of
            _ : Integer -> this_table.make_column (this_table.internal_columns.at selector)
            _ -> this_table.get selector (Error.throw (No_Such_Column.Error selector))

    get (this_table : Table & DB_Table) (selector : Integer | Text) ~if_missing:Any =
        internal_column = case selector of
            _ : Integer -> this_table.internal_columns.get selector if_missing=Nothing
            _ : Text -> this_table.internal_columns.find (p -> p.name == selector) if_missing=Nothing
        if internal_column.is_nothing then if_missing else this_table.make_column internal_column

    get_value (this_table : Table & DB_Table) (selector : Text | Integer) index:Integer ~if_missing:Any =
        Feature.Column_Operations.if_supported_else_throw this_table.connection.dialect "get_value" <|
            col = this_table.get selector if_missing=Nothing
            if Nothing == col then if_missing else col.get index if_missing

    get_row (this_table : Table & DB_Table) index:Integer ~if_missing:Any =
        Feature.Sample.if_supported_else_throw this_table.connection.dialect "get_row" <|
            real_row = (if index < 0 then index + this_table.row_count else index)
            if real_row < 0 then if_missing else
                this_table.rows real_row+1 . get real_row if_missing

    first_value (this_table : Table & DB_Table) =
        Feature.Column_Operations.if_supported_else_throw this_table.connection.dialect "first_value" <|
            this_table.at 0 . at 0

    last_value (this_table : Table & DB_Table) =
        Feature.Column_Operations.if_supported_else_throw this_table.connection.dialect "last_value" <|
            this_table.last_row . at -1

    first_column (this_table : Table & DB_Table) =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "first_column" <|
            this_table.at 0

    last_column (this_table : Table & DB_Table) =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "last_column" <|
            this_table.at -1

    column_count (this_table : Table & DB_Table) = this_table.internal_columns.length

    select_columns (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type) | Text | Integer | Regex | By_Type) reorder:Boolean case_sensitivity:Case_Sensitivity error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "select_columns" <|
            new_columns = this_table.columns_helper.select_columns columns case_sensitivity reorder error_on_missing_columns on_problems
            this_table.updated_columns (new_columns.map (Internal_Column.from _))

    select_columns_by_type (this_table : Table & DB_Table) (types:Vector Value_Type) strict:Boolean =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "select_columns_by_type" <|
            new_columns = this_table.columns_helper.select_by_type types strict
            result = this_table.updated_columns (new_columns.map (Internal_Column.from _))
            Warning.attach (Deprecated.Warning "Standard.Database.DB_Table.DB_Table" "select_columns_by_type" "Deprecated: use `select_columns` with a `By_Type` instead.") result

    remove_columns (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type) | Text | Integer | Regex | By_Type) case_sensitivity:Case_Sensitivity error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "remove_columns" <|
            new_columns = this_table.columns_helper.remove_columns columns case_sensitivity error_on_missing_columns=error_on_missing_columns on_problems=on_problems
            this_table.updated_columns (new_columns.map (Internal_Column.from _))

    remove_columns_by_type (this_table : Table & DB_Table) (types:Vector Value_Type) strict:Boolean =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "remove_columns_by_type" <|
            new_columns = this_table.columns_helper.remove_by_type types strict
            result = this_table.updated_columns (new_columns.map (Internal_Column.from _))
            Warning.attach (Deprecated.Warning "Standard.Database.DB_Table.DB_Table" "remove_columns_by_type" "Deprecated: use `remove_columns` with a `By_Type` instead.") result

    select_blank_columns (this_table : Table & DB_Table) when:Blank_Selector treat_nans_as_blank:Boolean =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "select_blank_columns" <|
            new_columns = this_table.columns_helper.select_blank_columns_helper when treat_nans_as_blank
            this_table.updated_columns new_columns

    remove_blank_columns (this_table : Table & DB_Table) when:Blank_Selector treat_nans_as_blank:Boolean =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "remove_blank_columns" <|
            new_columns = this_table.columns_helper.select_blank_columns_helper when treat_nans_as_blank invert_selection=True
            this_table.updated_columns new_columns

    reorder_columns (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type) | Text | Integer | Regex | By_Type) position:Position case_sensitivity:Case_Sensitivity error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "reorder_columns" <|
            new_columns = this_table.columns_helper.reorder_columns columns position case_sensitivity error_on_missing_columns on_problems
            this_table.updated_columns (new_columns.map (Internal_Column.from _))

    sort_columns (this_table : Table & DB_Table) order:Sort_Direction text_ordering:Text_Ordering =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "sort_columns" <|
            new_columns = Table_Helpers.sort_columns internal_columns=this_table.internal_columns order text_ordering
            this_table.updated_columns new_columns

    rename_columns (this_table : Table & DB_Table) (column_map : Table | Dictionary (Text | Integer | Regex) Text | Vector Text | Vector Vector) case_sensitivity:Case_Sensitivity error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "rename_columns" <|
            case column_map of
                _ : Table ->
                    resolved = Table_Helpers.read_name_mapping_from_table column_map
                    this_table.rename_columns resolved case_sensitivity error_on_missing_columns on_problems
                _ ->
                    new_names = Table_Helpers.rename_columns this_table.column_naming_helper this_table.internal_columns column_map case_sensitivity error_on_missing_columns on_problems
                    Warning.with_suspended new_names names->
                        this_table.updated_columns (this_table.internal_columns.map c-> c.rename (names.at c.name))

    use_first_row_as_names (this_table : Table & DB_Table) on_problems:Problem_Behavior =
        _ = [this_table, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "use_first_row_as_names")

    resolve (this_table : Table & DB_Table) column =
        Feature.Select_Columns.if_supported_else_throw this_table.connection.dialect "resolve" <|
            case column of
                _ : Text -> Panic.rethrow (this_table.at column)
                _ ->
                    if Helpers.check_integrity this_table column then column else
                        Panic.throw (Integrity_Error.Error "DB_Column "+column.name)

    filter (this_table : Table & DB_Table) (column : Column | Expression | Text | Integer) (filter : Filter_Condition | (Any -> Boolean)) on_problems:Problem_Behavior =
        Feature.Filter.if_supported_else_throw this_table.connection.dialect "filter" <|
            case column of
                _ : Column ->
                    mask filter_column = case Helpers.check_integrity this_table (filter_column:DB_Column) of
                        False ->
                            Error.throw (Integrity_Error.Error "DB_Column "+filter_column.name)
                        True ->
                            new_filters = this_table.context.where_filters + [(filter_column:DB_Column).expression]
                            new_ctx = this_table.context.set_where_filters new_filters
                            this_table.updated_context new_ctx

                    filter_condition = Filter_Condition.resolve_auto_scoped filter
                    case filter_condition of
                        Filter_Condition.Predicate _ ->
                            Error.throw (Unsupported_Database_Operation.Error "Filtering with a custom predicate")
                        _ : Filter_Condition ->
                            resolved = (this_table:Table_Ref).resolve_condition filter_condition
                            mask (make_filter_column column resolved on_problems)
                _ : Expression -> this_table.filter (this_table.evaluate_expression column on_problems) filter on_problems
                _ ->
                    table_at = this_table.at column
                    this_table.filter table_at filter on_problems

    filter_by_expression (this_table : Table & DB_Table) expression:Text on_problems:Problem_Behavior =
        Feature.Filter.if_supported_else_throw this_table.connection.dialect "filter_by_expression" <|
            column = this_table.evaluate_expression (Expression.Value expression) on_problems
            result = this_table.filter column ..Is_True
            Warning.attach (Deprecated.Warning "Standard.Database.DB_Table.DB_Table" "filter_by_expression" "Deprecated: use `filter` with an `Expression` instead.") result

    take (this_table : Table & DB_Table) (range : Index_Sub_Range | Range | Integer) =
        Feature.Sample.if_supported_else_throw this_table.connection.dialect "take" <|
            Ordering_Helpers.require_ordering this_table "take" <|
                Take_Drop_Helpers.take_drop_helper ..Take this_table range

    drop (this_table : Table & DB_Table) (range : Index_Sub_Range | Range | Integer) =
        Feature.Sample.if_supported_else_throw this_table.connection.dialect "drop" <|
            Ordering_Helpers.require_ordering this_table "drop" <|
                Take_Drop_Helpers.take_drop_helper ..Drop this_table range

    remove_all_rows (this_table : Table & DB_Table) =
        Feature.Filter.if_supported_else_throw this_table.connection.dialect "remove_all_rows" <|
            this_table.filter (Expression.Value "0==1")

    add_row_number (this_table : Table & DB_Table) name:Text from:Integer step:Integer (group_by : Vector (Text | Integer | Regex) | Text | Integer | Regex) (order_by : Vector (Text | Sort_Column) | Text) on_problems:Problem_Behavior =
        Feature.Add_Row_Number.if_supported_else_throw this_table.connection.dialect "add_row_number" <|
            problem_builder = Problem_Builder.new error_on_missing_columns=True
            grouping_columns = _resolve_grouping_columns this_table.columns_helper group_by problem_builder
            ordering = Table_Helpers.resolve_order_by this_table.columns order_by problem_builder
            problem_builder.attach_problems_before on_problems <|
                order_descriptors = _resolve_order_descriptors this_table ordering "add_row_number"
                grouping_expressions = (grouping_columns.map (Internal_Column.from _)).map .expression

                new_expr = Row_Number_Helpers.make_row_number from step order_descriptors grouping_expressions

                mapping = this_table.connection.type_mapping
                infer_from_database_callback expression =
                    SQL_Type_Reference.new this_table.connection this_table.context expression
                new_type_ref = mapping.infer_return_type infer_from_database_callback "ROW_NUMBER" [] new_expr

                new_column = Internal_Column.Value name new_type_ref new_expr

                rebuild_table columns =
                    this_table.updated_columns (columns.map (Internal_Column.from _))
                renamed_table = Add_Row_Number.rename_columns_if_needed this_table name on_problems rebuild_table
                updated_table = renamed_table.updated_columns (renamed_table.internal_columns + [new_column])
                updated_table.as_subquery

    add_group_number (this_table : Table & DB_Table) grouping_method:Grouping_Method name:Text from:Integer step:Integer on_problems:Problem_Behavior =
        Feature.Add_Group_Number.if_supported_else_throw this_table.connection.dialect "add_group_number" <|
            problem_builder = Problem_Builder.new error_on_missing_columns=True
            case grouping_method of
                Grouping_Method.Unique group_by ->
                    if group_by.is_empty then
                        Error.throw (Illegal_Argument.Error "..Unique requires a non-empty 'group_by'")
                    grouping_columns = _resolve_grouping_columns this_table.columns_helper group_by problem_builder
                    problem_builder.attach_problems_before on_problems <|
                        grouping_expressions = (grouping_columns.map (Internal_Column.from _)).map .expression

                        new_expr = Group_Number_Helpers.make_group_number from step grouping_expressions

                        mapping = this_table.connection.type_mapping
                        infer_from_database_callback expression =
                            SQL_Type_Reference.new this_table.connection this_table.context expression
                        new_type_ref = mapping.infer_return_type infer_from_database_callback "GROUP_NUMBER" [] new_expr

                        new_column = Internal_Column.Value name new_type_ref new_expr

                        rebuild_table columns =
                            this_table.updated_columns (columns.map (Internal_Column.from _))
                        renamed_table = Add_Row_Number.rename_columns_if_needed this_table name on_problems rebuild_table
                        updated_table = renamed_table.updated_columns (renamed_table.internal_columns + [new_column])
                        updated_table.as_subquery
                Grouping_Method.Equal_Count group_count order_by ->
                    if group_count < 1 then
                        Error.throw (Illegal_Argument.Error "group_count must be at least 1")
                    ordering = Table_Helpers.resolve_order_by this_table.columns order_by problem_builder
                    problem_builder.attach_problems_before on_problems <|
                        order_descriptors = _resolve_order_descriptors this_table ordering "add_group_number"

                        new_expr = Group_Number_Helpers.make_group_number_equal_count from step group_count order_descriptors

                        mapping = this_table.connection.type_mapping
                        infer_from_database_callback expression =
                            SQL_Type_Reference.new this_table.connection this_table.context expression
                        new_type_ref = mapping.infer_return_type infer_from_database_callback "GROUP_NUMBER_EQUAL_COUNT" [] new_expr

                        new_column = Internal_Column.Value name new_type_ref new_expr

                        rebuild_table columns =
                            this_table.updated_columns (columns.map (Internal_Column.from _))
                        renamed_table = Add_Row_Number.rename_columns_if_needed this_table name on_problems rebuild_table
                        updated_table = renamed_table.updated_columns (renamed_table.internal_columns + [new_column])
                        updated_table.as_subquery
                Grouping_Method.Equal_Sum on group_count order_by ->
                    if group_count < 1 then
                        Error.throw (Illegal_Argument.Error "group_count must be at least 1")
                    ordering = Table_Helpers.resolve_order_by this_table.columns order_by problem_builder
                    problem_builder.attach_problems_before on_problems <|
                        order_descriptors = _resolve_order_descriptors this_table ordering "add_group_number"
                        sum_columns = this_table.columns_helper.select_columns_helper [on] Case_Sensitivity.Default True problem_builder
                        if sum_columns.is_empty then
                            Error.throw (No_Such_Column.Error on.to_text)
                        sum_column = sum_columns.at 0

                        sum_expression = Internal_Column.from sum_column . expression

                        new_expr = Group_Number_Helpers.make_group_number_equal_sum from step sum_expression group_count order_descriptors

                        mapping = this_table.connection.type_mapping
                        infer_from_database_callback expression =
                            SQL_Type_Reference.new this_table.connection this_table.context expression
                        new_type_ref = mapping.infer_return_type infer_from_database_callback "GROUP_NUMBER_EQUAL_SUM" [] new_expr

                        new_column = Internal_Column.Value name new_type_ref new_expr

                        rebuild_table columns =
                            this_table.updated_columns (columns.map (Internal_Column.from _))
                        renamed_table = Add_Row_Number.rename_columns_if_needed this_table name on_problems rebuild_table
                        updated_table = renamed_table.updated_columns (renamed_table.internal_columns + [new_column])
                        updated_table.as_subquery
                Grouping_Method.Standard_Deviation on population ->
                    problem_builder.attach_problems_before on_problems <|
                        stddev_columns = this_table.columns_helper.select_columns_helper [on] Case_Sensitivity.Default True problem_builder
                        if stddev_columns.is_empty then
                            Error.throw (No_Such_Column.Error on.to_text)
                        stddev_column = stddev_columns.at 0

                        stddev_expression = Internal_Column.from stddev_column . expression

                        new_expr = Group_Number_Helpers.make_group_number_standard_deviation from step stddev_expression population

                        mapping = this_table.connection.type_mapping
                        infer_from_database_callback expression =
                            SQL_Type_Reference.new this_table.connection this_table.context expression
                        op = if population then "GROUP_NUMBER_STANDARD_DEVIATION_POPULATION" else "GROUP_NUMBER_STANDARD_DEVIATION_SAMPLE"
                        new_type_ref = mapping.infer_return_type infer_from_database_callback op [] new_expr

                        new_column = Internal_Column.Value name new_type_ref new_expr

                        rebuild_table columns =
                            this_table.updated_columns (columns.map (Internal_Column.from _))
                        renamed_table = Add_Row_Number.rename_columns_if_needed this_table name on_problems rebuild_table
                        updated_table = renamed_table.updated_columns (renamed_table.internal_columns + [new_column])
                        updated_table.as_subquery

    find_group_number (this_table : Table & DB_Table) predicate over group_row name:Text from:Integer step:Integer on_problems:Problem_Behavior =
        _ = [this_table, predicate, over, group_row, name, from, step, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "find_group_number")

    set (this_table : Table & DB_Table) (value : Column | Text | Expression | Constant_Column | Simple_Expression | SQL_Function) as:Text set_mode:Set_Mode on_problems:Problem_Behavior =
        problem_builder = Problem_Builder.new
        unique = this_table.column_naming_helper.create_unique_name_strategy
        unique.mark_used this_table.column_names

        resolved = case value of
            _ : Text -> this_table.make_constant_column value
            _ : Expression -> this_table.evaluate_expression value on_problems
            _ : Column ->
                if Helpers.check_integrity this_table value then value else
                    Error.throw (Integrity_Error.Error "Column "+value.name)
            _ : Constant_Column -> this_table.make_constant_column value.value
            _ : Simple_Expression -> value.evaluate this_table (set_mode==Set_Mode.Update && as=="") on_problems
            _ : SQL_Function -> _resolve_sql_function this_table value

        ## If `as` was specified, use that. Otherwise, if `value` is a
          `DB_Column`, use its name. In these two cases, do not make it unique.
          Otherwise, make it unique. If set_mode is Update, however, do not
          make it unique.
        new_column_name = if as != "" then as else
            if value.is_a DB_Column || set_mode==Set_Mode.Update || set_mode==Set_Mode.Add_Or_Update then resolved.name else unique.make_unique resolved.name
        renamed = resolved.rename new_column_name
        renamed.if_not_error <| this_table.column_naming_helper.check_ambiguity this_table.column_names renamed.name <|
            index = this_table.internal_columns.index_of (c -> c.name == renamed.name)
            check_add = case set_mode of
                Set_Mode.Add_Or_Update -> True
                Set_Mode.Add -> if index.is_nothing then True else Error.throw (Existing_Column.Error renamed.name)
                Set_Mode.Update -> if index.is_nothing then Error.throw (Missing_Column.Error renamed.name) else True
            new_table = check_add.if_not_error <|
                new_col = Internal_Column.from renamed
                new_cols = if index.is_nothing then this_table.internal_columns + [new_col] else
                    Vector.new this_table.column_count i-> if i == index then new_col else this_table.internal_columns.at i
                this_table.updated_columns new_cols

            problem_builder.report_unique_name_strategy unique
            problem_builder.attach_problems_after on_problems new_table

    make_table_from_dictionary (this_table : Table & DB_Table) dict key_column_name value_column_name =
        Feature.Make_Table_From.if_supported_else_throw this_table.connection.dialect "make_table_from_dictionary" <|
            total_size = dict.size * 2

            if dict.is_empty then Error.throw (Illegal_Argument.Error "Dictionary cannot be empty") else
                if total_size > MAX_LITERAL_ELEMENT_COUNT then Error.throw (Illegal_Argument.Error "Dictionary is too large ("+dict.size.to_text+" entries): materialize a table into the database instead") else
                    keys_and_values = dict.to_vector
                    this_table.make_table_from_vectors [keys_and_values.map .first, keys_and_values.map .second] [key_column_name, value_column_name]

    make_table_from_vectors (this_table : Table & DB_Table) column_vectors column_names =
        Feature.Make_Table_From.if_supported_else_throw this_table.connection.dialect "make_table_from_vectors" <|
            literal_table_name = this_table.connection.base_connection.table_naming_helper.generate_random_table_name "enso-literal-"
            make_literal_table this_table.connection column_vectors column_names literal_table_name

    make_constant_column (this_table : Table & DB_Table) value =
        if Column.is_column value then Error.throw (Illegal_Argument.Error "A constant value may only be created from a scalar, not a DB_Column") else
            mapping = this_table.connection.type_mapping
            argument_value_type = Value_Type_Helpers.find_argument_type value
            sql_type = case argument_value_type of
                Nothing -> SQL_Type.null
                _ -> mapping.value_type_to_sql argument_value_type Problem_Behavior.Ignore
            expr = SQL_IR_Expression.Constant value
            new_type_ref = SQL_Type_Reference.from_constant sql_type
            base_column = Internal_Column.Value value.pretty new_type_ref expr
            needs_cast = argument_value_type.is_nothing.not && this_table.connection.dialect.needs_literal_table_cast argument_value_type
            result_internal_column = if needs_cast.not then base_column else
                infer_type_from_database new_expression =
                    SQL_Type_Reference.new this_table.connection this_table.context new_expression
                this_table.connection.dialect.make_cast base_column mapping sql_type infer_type_from_database
            this_table.make_column result_internal_column

    make_temp_column_name (this_table : Table & DB_Table) = this_table.column_naming_helper.make_temp_column_name this_table.column_names

    columns (this_table : Table & DB_Table) =
        Vector.from_polyglot_array <|
            Array_Proxy.new this_table.internal_columns.length i->
                this_table.make_column (this_table.internal_columns.at i)

    column_names (this_table : Table & DB_Table) = Vector.from_polyglot_array <|
        Array_Proxy.new this_table.internal_columns.length i->
            this_table.internal_columns.at i . name

    rows (this_table : Table & DB_Table) (max_rows : Rows_To_Read) =
        this_table.read max_rows . rows

    first_row (this_table : Table & DB_Table) =
        this_table.read (..First 1) . rows . first

    last_row (this_table : Table & DB_Table) =
        if this_table.internal_columns.is_empty then Error.throw (Illegal_Argument.Error "Cannot create a table with no columns.") else
            sql = this_table.to_sql
            column_types = this_table.internal_columns.map .sql_type_reference
            table = this_table.connection.base_connection.read_statement sql column_types last_row_only=True
            table.rows.first

    sort (this_table : Table & DB_Table) (columns : Vector Sort_Column | Sort_Column) text_ordering:Text_Ordering error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        Feature.Sort.if_supported_else_throw this_table.connection.dialect "sort" <|
            problem_builder = Problem_Builder.new error_on_missing_columns=error_on_missing_columns types_to_always_throw=[No_Input_Columns_Selected]
            columns_for_ordering = Table_Helpers.prepare_order_by this_table.columns columns problem_builder
            problem_builder.attach_problems_before on_problems <|
                new_order_descriptors = columns_for_ordering.map selected_column->
                    column = selected_column.column
                    associated_selector = selected_column.associated_selector
                    effective_text_ordering = if column.value_type.is_text then text_ordering else Nothing
                    this_table.connection.dialect.prepare_order_descriptor column:Internal_Column associated_selector.direction effective_text_ordering
                new_ctx = this_table.context.add_orders new_order_descriptors
                this_table.updated_context new_ctx

    order_by (this_table : Table & DB_Table) (columns : Vector (Text | Sort_Column) | Text) text_ordering:Text_Ordering error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        result = this_table.sort columns text_ordering error_on_missing_columns on_problems
        Warning.attach (Deprecated.Warning "Standard.Database.Table.Table" "order_by" "Deprecated: use `sort` instead.") result

    distinct (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex) | Text | Integer | Regex) case_sensitivity:Case_Sensitivity on_problems:Problem_Behavior =
        Feature.Distinct.if_supported_else_throw this_table.connection.dialect "distinct" <|
            key_columns = this_table.columns_helper.select_columns columns Case_Sensitivity.Default reorder=True error_on_missing_columns=True on_problems=on_problems . catch No_Output_Columns _->
                Error.throw No_Input_Columns_Selected
            key_columns.if_not_error <|
                problem_builder = Problem_Builder.new
                new_table = this_table.connection.dialect.prepare_distinct this_table key_columns case_sensitivity problem_builder
                problem_builder.attach_problems_before on_problems new_table

    duplicates (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex) | Text | Integer | Regex) case_sensitivity:Case_Sensitivity on_problems:Problem_Behavior =
        _ = [this_table, columns, case_sensitivity, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "duplicates")

    join (this_table : Table & DB_Table) (right : Table) join_kind:Join_Kind (on : Join_Condition | Text | Vector (Join_Condition | Text)) (right_prefix : Text) on_problems:Problem_Behavior =
        Feature.Join.if_supported_else_throw this_table.connection.dialect "join" <|
            if right.is_error then right
            if right.is_a DB_Table . not then Error.throw (Illegal_Argument.Error 'To join an in-memory table, load to the database connection first.')
            _join_or_cross_join this_table (right : Table & DB_Table) join_kind on right_prefix on_problems

    cross_join (this_table : Table & DB_Table) (right : Table) (right_row_limit : Row_Limit) (right_prefix : Text) on_problems:Problem_Behavior =
        Feature.Cross_Join.if_supported_else_throw this_table.connection.dialect "cross_join" <|
            row_limit = case right_row_limit of
                Row_Limit.No_Limit -> Nothing
                Row_Limit.Limit limit -> limit
            limit_problems = if row_limit.is_nothing || (right.row_count < row_limit) then [] else
                [Cross_Join_Row_Limit_Exceeded.Error row_limit right.row_count]
            on_problems.attach_problems_before limit_problems <|
                if right.is_error then right
                if right.is_a DB_Table . not then Error.throw (Illegal_Argument.Error 'To join an in-memory table, load to the database connection first.')
                _join_or_cross_join this_table (right : Table & DB_Table) join_kind=Join_Kind_Cross on=[] right_prefix on_problems

    merge (this_table : Table & DB_Table) (lookup_table : Table) (key_columns : Vector (Integer | Text | Regex) | Text | Integer | Regex) add_new_columns:Boolean allow_unmatched_rows:Boolean on_problems:Problem_Behavior =
        Feature.Merge.if_supported_else_throw this_table.connection.dialect "merge" <|
            if lookup_table.is_error then lookup_table
            if lookup_table.is_a DB_Table . not then Error.throw (Illegal_Argument.Error 'To merge an in-memory table, load to the database connection first.')
            if key_columns == [] then
                Error.throw (Missing_Argument.throw "key_columns")

            Helpers.ensure_same_connection "table" [this_table, lookup_table] <|
                Lookup_Query_Helper.build_lookup_query this_table lookup_table:(Table & DB_Table) key_columns add_new_columns allow_unmatched_rows on_problems

    replace (this_table : Table & DB_Table) (lookup_table : Table | Dictionary) (columns : Vector (Integer | Text | Regex | By_Type) | Text | Integer | Regex | By_Type) (from_column : Text | Integer | Nothing) (to_column : Text | Integer | Nothing) allow_unmatched_rows:Boolean on_problems:Problem_Behavior =
        Feature.Replace.if_supported_else_throw this_table.connection.dialect "replace" <|
            Replace_Helpers.replace this_table lookup_table columns from_column to_column allow_unmatched_rows on_problems

    zip (this_table : Table & DB_Table) (right : Table) (keep_unmatched : Boolean | Report_Unmatched) (right_prefix : Text) on_problems:Problem_Behavior =
        _ = [this_table, right, keep_unmatched, right_prefix, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "zip")

    union (this_table : Table & DB_Table) (tables : Table | Vector Table) columns_to_keep:Columns_To_Keep match_columns:Match_Columns on_problems:Problem_Behavior =
        Feature.Union.if_supported_else_throw this_table.connection.dialect "union" <|
            table_vector = Vector.unify_vector_or_element tables
            if table_vector.any t-> t.is_error then tables.find t-> t.is_error
            if table_vector.any t-> t.is_a DB_Table . not then Error.throw (Illegal_Argument.Error 'To union an in-memory table, load to the database connection first.')
            all_tables = [this_table] + (table_vector.map t-> (t : Table & DB_Table))
            Helpers.ensure_same_connection "table" all_tables <|
                ## We keep separate problem builders, because if we are reporting `No_Output_Columns`,
                  we only want to add a cause coming from unification; matching reports problems that would not fit this error.
                problem_builder_for_matching = Problem_Builder.new
                problem_builder_for_unification = Problem_Builder.new
                matched_column_sets = Match_Columns_Helpers.match_columns all_tables match_columns columns_to_keep problem_builder_for_matching
                dialect = this_table.connection.dialect
                mapping = this_table.connection.type_mapping
                merged_columns = matched_column_sets.map column_set->
                    sql_type_from_value_type value_type =
                        mapping.value_type_to_sql value_type Problem_Behavior.Report_Error . catch Inexact_Type_Coercion error->
                            Panic.throw <|
                                Illegal_State.Error "Unexpected inexact type coercion in Union. The union logic should only operate in types supported by the given backend. This is a bug in the Database library. The coercion was: "+error.to_display_text cause=error
                    case Table_Helpers.unify_result_type_for_union column_set all_tables problem_builder_for_unification of
                        Union_Result_Type.Common_Type common_type ->
                            [column_set, sql_type_from_value_type common_type, common_type]
                        Union_Result_Type.Fallback_To_Text ->
                            [column_set, sql_type_from_value_type Value_Type.Char, Value_Type.Char]
                        Union_Result_Type.No_Types_To_Unify ->
                            ## If the column is all nulls, we still need to give it some type.
                              For DB `Mixed` is not available, so a portable type to use is `Char`.
                            [column_set, SQL_Type.null, Value_Type.Char]

                problem_builder_for_matching.attach_problems_before on_problems <| problem_builder_for_unification.attach_problems_before on_problems <|
                    if merged_columns.is_empty then problem_builder_for_unification.raise_no_output_columns_with_cause else
                        queries = all_tables.map_with_index i-> t->
                            columns_to_select = merged_columns.map description->
                                column_set  = description.at 0
                                sql_type    = description.at 1
                                result_type = description.at 2
                                column_name = column_set.name
                                ## We assume that the type for this expression will never be queried - it is
                                  just used internally to build the Union operation and never exposed externally.
                                infer_return_type _ = SQL_Type_Reference.null
                                case column_set.column_indices.at i of
                                    corresponding_column_index : Integer ->
                                        column = t.at corresponding_column_index
                                        internal_named_column = Internal_Column.from column . rename column_name
                                        ## We cast if the result type is different.
                                          This is a bit on the safe side. In some cases the cast is not needed
                                          (for example, most databases will allow union of int2 and int4 without casts; or SQLite does not need casts at all).
                                          However, we do this for simplicity as determining the rules when the cast is needed or not is adding a lot of complication.
                                          This is a possible future improvement to make queries lighter, but the benefit is unlikely to be worth it.
                                        needs_cast = column.value_type != result_type
                                        if needs_cast.not then internal_named_column else
                                            dialect.make_cast internal_named_column mapping sql_type infer_return_type
                                    Nothing ->
                                        typ = SQL_Type_Reference.from_constant SQL_Type.null
                                        expr = SQL_IR_Expression.Literal "NULL"
                                        null_column = Internal_Column.Value column_name typ expr
                                        if sql_type == SQL_Type.null then null_column else
                                            dialect.make_cast null_column mapping sql_type infer_return_type
                            pairs = columns_to_select.map c->
                                [c.name, c.expression]
                            SQL_IR_Statement.Select pairs t.context

                        table_name_deduplicator = this_table.connection.base_connection.table_naming_helper.create_unique_name_strategy
                        table_name_deduplicator.mark_used (all_tables.map .name)
                        union_alias = table_name_deduplicator.make_unique <|
                            all_tables.map .name . join "_"
                        new_from = SQL_IR_From_Part.Union queries union_alias
                        new_ctx = SQL_IR_Source.for_subquery new_from
                        ## TODO [RW] The result type is currently fetched
                          independently for each column, instead we should fetch it
                          for all columns at once.
                          See #6118.
                        infer_return_type expression =
                            SQL_Type_Reference.new this_table.connection new_ctx expression
                        new_columns = merged_columns.map description->
                            column_set = description.first
                            result_type = description.at 2
                            name = column_set.name
                            expression = SQL_IR_Expression.Column union_alias name
                            input_column = Internal_Column.Value name (infer_return_type expression) expression
                            dialect.adapt_unified_column input_column result_type infer_return_type mapping

                        DB_Table.new union_alias this_table.connection new_columns new_ctx

    aggregate (this_table : Table & DB_Table) (group_by : Vector (Integer | Text | Regex | Aggregate_Column) | Text | Integer | Regex) (columns : Vector Aggregate_Column) error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        Feature.Aggregate.if_supported_else_throw this_table.connection.dialect "aggregate" <|
            Aggregate_Helper.aggregate this_table group_by columns error_on_missing_columns on_problems

    transpose (this_table : Table & DB_Table) (key_columns : Vector (Integer | Text | Regex) | Text | Integer | Regex) attribute_column_name:Text value_column_name:Text error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        ## Avoid unused arguments warning. We cannot rename arguments to `_`,
           because we need to keep the API consistent with the in-memory table.
        _ = [this_table, key_columns, attribute_column_name, value_column_name, error_on_missing_columns, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "transpose")

    cross_tab (this_table : Table & DB_Table) (group_by : Vector (Integer | Text | Regex | Aggregate_Column) | Text | Integer | Regex) (names : Text | Integer) (values : Aggregate_Column | Vector Aggregate_Column) on_problems:Problem_Behavior =
        ## Avoid unused arguments warning. We cannot rename arguments to `_`,
           because we need to keep the API consistent with the in-memory table.
        _ = [this_table, group_by, names, values, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "cross_tab")

    parse (this_table : Table & DB_Table) (columns : Vector (Text | Integer | Regex) | Text | Integer | Regex) (type : Value_Type | Auto) (format : Text | Data_Formatter) error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        selected = this_table.columns_helper.select_columns columns Case_Sensitivity.Default reorder=False error_on_missing_columns=error_on_missing_columns on_problems=on_problems error_on_empty=False . map this_table.make_column
        selected.fold this_table table-> column_to_parse->
            column_value_type = column_to_parse.value_type
            already_parsed = Auto != type && column_value_type.is_same_type type
            if already_parsed then table else
                new_column = column_to_parse.parse type format on_problems
                table.set new_column as=column_to_parse.name set_mode=Set_Mode.Update

    format (this_table : Table & DB_Table) (columns : Vector (Text | Integer | Regex | By_Type) | Text | Integer | Regex | By_Type) (format : Text | Date_Time_Formatter | DB_Column) locale:Locale error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        _ = [this_table, columns, format, locale, error_on_missing_columns, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "format")

    split_to_columns (this_table : Table & DB_Table) (column : Text | Integer) (delimiter : Text | Vector) column_count:Columns_To_Add on_problems:Problem_Behavior =
        _ = [this_table, column, delimiter, column_count.columns_to_split, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "split_to_columns")

    split_to_rows (this_table : Table & DB_Table) (column : Text | Integer) (delimiter : Text | Vector) =
        _ = [this_table, column, delimiter]
        Error.throw (Unsupported_Database_Operation.Error "split_to_rows")

    tokenize_to_columns (this_table : Table & DB_Table) (column : Text | Integer) pattern:Text case_sensitivity:Case_Sensitivity column_count:Columns_To_Add on_problems:Problem_Behavior =
        _ = [this_table, column, pattern, case_sensitivity, column_count, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "tokenize_to_columns")

    tokenize_to_rows (this_table : Table & DB_Table) (column : Text | Integer) (pattern : Text) case_sensitivity:Case_Sensitivity at_least_one_row:Boolean =
        _ = [this_table, column, pattern, case_sensitivity, at_least_one_row]
        Error.throw (Unsupported_Database_Operation.Error "tokenize_to_rows")

    parse_to_columns (this_table : Table & DB_Table) (column : Text | Integer) (pattern : Text | Regex) case_sensitivity:Case_Sensitivity parse_values:Boolean on_problems:Problem_Behavior =
        _ = [this_table, column, pattern, case_sensitivity, parse_values, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "parse_to_columns")

    expand_column (this_table : Table & DB_Table) (column : Text | Integer) (fields : (Vector Text) | Nothing) prefix:Prefix_Name =
            _ = [this_table, column, fields, prefix]
            Error.throw (Unsupported_Database_Operation.Error "expand_column")

    expand_to_rows (this_table : Table & DB_Table) (column : Text | Integer) at_least_one_row:Boolean =
        _ = [this_table, column, at_least_one_row]
        Error.throw (Unsupported_Database_Operation.Error "expand_to_rows")

    cast (this_table : Table & DB_Table) (columns : Vector (Text | Integer | Regex | By_Type) | Text | Integer | Regex | By_Type) (value_type:Value_Type) error_on_missing_columns:Boolean on_problems:Problem_Behavior = columns.if_not_error <|
        selected = this_table.columns_helper.select_columns columns Case_Sensitivity.Default reorder=False error_on_missing_columns=error_on_missing_columns on_problems=on_problems error_on_empty=False . map this_table.make_column
        selected.fold this_table table-> column_to_cast->
            new_column = column_to_cast.cast value_type on_problems
            table.set new_column as=column_to_cast.name set_mode=Set_Mode.Update

    auto_cast (this_table : Table & DB_Table) (columns : Vector (Text | Integer | Regex | By_Type) | Text | Integer | Regex | By_Type) shrink_types:Boolean error_on_missing_columns:Boolean on_problems:Problem_Behavior =
        _ = [this_table, columns, shrink_types, error_on_missing_columns, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "auto_cast")

    filter_blank_rows (this_table : Table & DB_Table) when:Blank_Selector treat_nans_as_blank:Boolean =
        Table_Helpers.filter_blank_rows this_table when treat_nans_as_blank

    row_count (this_table : Table & DB_Table) = if this_table.internal_columns.is_empty then 0 else
        expr = SQL_IR_Expression.Operation "COUNT_ROWS" []
        column_name = "row_count"
        ## We need to keep some column in the subquery which will determine if
           the query is performing regular selection or aggregation. To avoid
           computing too much we do not pass all the columns but only the first
           one.
        setup = this_table.context.as_subquery this_table.name [[this_table.internal_columns.first]]
        new_ctx = SQL_IR_Source.for_subquery setup.subquery
        query = SQL_IR_Statement.Select [[column_name, expr]] new_ctx
        sql = this_table.connection.dialect.generate_sql query
        table = this_table.connection.base_connection.read_statement sql
        table.at column_name . at 0

    default_max_rows = Rows_To_Read.First_With_Warning 1000

    read (this_table : Table & DB_Table) (max_rows : Rows_To_Read) =
        if this_table.internal_columns.is_empty then Error.throw (Illegal_Argument.Error "Cannot create a table with no columns.") else
            limit = max_rows.rows_to_read
            preprocessed = if limit.is_nothing then this_table else this_table.limit limit

            sql = preprocessed.to_sql
            column_types = preprocessed.internal_columns.map .sql_type_reference
            materialized_table = this_table.connection.base_connection.read_statement sql column_types . catch SQL_Error sql_error->
                Error.throw (this_table.connection.type_mapping.error_mapper.transform_custom_errors sql_error)

            warnings_builder = Builder.new
            expected_types = this_table.columns.map .value_type
            actual_types = materialized_table.columns.map .value_type
            expected_types.zip actual_types expected_type-> actual_type->
                if expected_type == actual_type then Nothing else
                    if this_table.connection.type_mapping.should_warn_on_materialize expected_type actual_type then
                        warnings_builder.append (Inexact_Type_Coercion.Warning expected_type actual_type)

            result = max_rows.attach_warning materialized_table
            with_problems = Problem_Behavior.Report_Warning.attach_problems_before warnings_builder.to_vector result
            with_problems.if_not_error <|
                Telemetry.log "DB_Table.read" "Materialize Table: connection_type={}, output={}, row_count={}, column_count={}" [this_table.connection.to Meta.Type . name, "Table", result.row_count, result.column_count]
                with_problems

    column_info (this_table : Table & DB_Table) =
        cols = this_table.internal_columns
        count_query =
            ## Performing a subquery is the most robust way to handle both
               regular columns and aggregates.
               Naively wrapping each column in a `COUNT(...)` will not
               always work as aggregates cannot be nested.
            setup = this_table.context.as_subquery this_table.name [this_table.internal_columns]
            new_ctx = SQL_IR_Source.for_subquery setup.subquery
            new_columns = setup.new_columns.first.map column->
                [column.name, SQL_IR_Expression.Operation "COUNT" [column.expression]]
            query = SQL_IR_Statement.Select new_columns new_ctx
            this_table.connection.dialect.generate_sql query
        count_table = this_table.connection.base_connection.read_statement count_query
        counts = if cols.is_empty then [] else count_table.columns.map c-> c.at 0
        mapping = this_table.connection.type_mapping
        types = cols.map col->
            mapping.sql_type_to_value_type col.sql_type_reference.get
        Table.new [["Column", cols.map .name], ["Items Count", counts], ["Value Type", types]]

    ## ---
       private: true
       ---
    columns_helper (this_table : Table & DB_Table) =
        Table_Helpers.Table_Column_Helper.Value this_table.columns this_table.internal_columns this_table.make_column this_table .read

    ## ---
       private: true
       ---
    column_naming_helper (this_table : Table & DB_Table) = this_table.connection.base_connection.column_naming_helper

    to_text (this_table : Table & DB_Table) = "(Database Table "+this_table.name.to_text+")"

    write (this_table : Table & DB_Table) (path : Writable_File) format on_existing_file:Existing_File_Behavior match_columns:Match_Columns on_problems:Problem_Behavior = path.if_not_error <|
        row_limit = 100000

        ## Read one extra row to check if the table is too large.
        materialized = this_table.read (..First row_limit+1)
        if materialized.row_count <= row_limit then materialized.write path format on_existing_file match_columns on_problems else
            Error.throw (Illegal_Argument.Error "DB_Table contains more than 100,000 rows. Use `read` to materialize first.")

    fill_nothing (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type) | Text | Integer | Regex | By_Type) (default : DB_Column | Column_Ref | Expression | Previous_Value | Any) =
        resolved_default = (this_table:Table_Ref).resolve default
        transformer col = col.fill_nothing resolved_default
        Table_Helpers.replace_columns_with_transformed_columns this_table columns transformer

    fill_empty (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type) | Text | Integer | Regex | By_Type) (default : DB_Column | Column_Ref | Expression | Previous_Value | Any) =
        resolved_default = (this_table:Table_Ref).resolve default
        transformer col = col.fill_empty resolved_default
        Table_Helpers.replace_columns_with_transformed_columns this_table columns transformer

    text_replace (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type) | Text | Integer | Regex | By_Type) (term : Text | Column | Column_Ref | Expression | Regex) (new_text : Text | Column | Column_Ref | Expression) case_sensitivity:Case_Sensitivity only_first:Boolean =
        table_ref = Table_Ref.from this_table
        resolved_term = table_ref.resolve term
        resolved_new_text = table_ref.resolve new_text
        transformer col = col.text_replace resolved_term resolved_new_text case_sensitivity only_first
        Table_Helpers.replace_columns_with_transformed_columns this_table columns transformer

    text_cleanse (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type)) (remove : Vector Named_Pattern) =
        Feature.Text_Cleanse.if_supported_else_throw this_table.connection.dialect "text_cleanse" <|
            transformer col = col.text_cleanse remove
            Table_Helpers.replace_columns_with_transformed_columns this_table columns transformer

    running (this_table : Table & DB_Table) statistic:Statistic (of : Text | Integer) as:Text set_mode:Set_Mode (group_by : Vector (Text | Integer | Regex) | Text | Integer | Regex) (order_by : Vector (Text | Sort_Column) | Text) on_problems:Problem_Behavior =
        _ = [this_table, statistic, of, as, set_mode, group_by, order_by, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "running")

    offset (this_table : Table & DB_Table) (columns : Vector (Integer | Text | Regex | By_Type)) n:Integer fill_with:Fill_With (group_by : Vector | Text | Integer | Regex) (order_by : Vector | Text) set_mode:Set_Mode on_problems:Problem_Behavior =
        Feature.Offset.if_supported_else_throw this_table.connection.dialect "offset" <|
            problem_builder = Problem_Builder.new error_on_missing_columns=True
            grouping_columns = _resolve_grouping_columns this_table.columns_helper group_by problem_builder
            ordering = Table_Helpers.resolve_order_by this_table.columns order_by problem_builder
            resolved_columns = this_table.columns_helper.select_columns_helper columns Case_Sensitivity.Default True problem_builder
            problem_builder.attach_problems_before on_problems <| if columns.is_empty then this_table else
                order_descriptors = _resolve_order_descriptors this_table ordering "offset"
                grouping_expressions = (grouping_columns.map (Internal_Column.from _)).map .expression
                
                offset_expr c -> SQL_IR_Expression =
                    Offset_Helpers.make_offset n (Internal_Column.from c) order_descriptors grouping_expressions fill_with
                new_column_name c:Column -> Text =
                    if set_mode==Set_Mode.Add then this_table.column_naming_helper.function_name "offset" [c, n, fill_with] else c.name
                
                new_columns = resolved_columns.map c->(Internal_Column.Value (new_column_name c) (c:DB_Column).sql_type_reference (offset_expr c))

                updated_table = new_columns.fold this_table t-> col->
                    t.set (this_table.make_column col)
                (updated_table:DB_Table).as_subquery

    generate_rows (this_table : Table & DB_Table) over:Generate_Rows_Range as:Text on_problems:Problem_Behavior =
        _ = [this_table, over, as, on_problems]
        Error.throw (Unsupported_Database_Operation.Error "generate_rows")

    spatial_columns (this_table : Table & DB_Table) = if this_table.connection.dialect.is_feature_supported ..Spatial . not then [] else
        this_table.columns.filter c-> case c.value_type of
            Value_Type.Unsupported_Data_Type type_name _ ->
                this_table.connection.dialect.spatial_types.contains type_name
            _ -> False

    as_spatial_column (this_table : Table & DB_Table) (column : Column) =
        dialect = this_table.connection.dialect
        if dialect.is_feature_supported ..Spatial . not then Panic.throw (Type_Error.Error Spatial_Column column "Spatial functions are not currently implemented for "+dialect.name+".")
        is_spatial = case column.value_type of
            Value_Type.Unsupported_Data_Type type_name _ -> dialect.spatial_types.contains type_name
            _ -> False
        if is_spatial then Spatial_Column.Value column this_table else
            Panic.throw (Type_Error.Error Spatial_Column column "The column '"+column.name+"' is not a spatial column.")

    spatial_point (this_table : Table & DB_Table) (longitude : Column) (latitude : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_point" <| Value_Type.expect_numeric longitude <| Value_Type.expect_numeric latitude <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_Point" [longitude, latitude])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_point" [longitude, latitude]
            this_table.set new_column as=new_name

    spatial_geometry_type (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_geometry_type" <| expect_spatial_type column this_table.connection.dialect <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_GeometryType" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_geometry_type" [column]
            this_table.set new_column as=new_name

    spatial_longitude (this_table : Table & DB_Table) (column : Column) (value : Lat_Long_Type) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_longitude" <| expect_spatial_type column this_table.connection.dialect <|
            used_column = case value of
                Lat_Long_Type.Default -> _resolve_sql_function this_table (SQL_Function.SQL "ST_Centroid" [column])
                _ -> column
            function_name = case value of
                Lat_Long_Type.Default -> "ST_X"
                Lat_Long_Type.Minimum -> "ST_XMin"
                Lat_Long_Type.Maximum -> "ST_XMax"
            new_column = _resolve_sql_function this_table (SQL_Function.SQL function_name [used_column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_longitude" [column]
            this_table.set new_column as=new_name

    spatial_latitude (this_table : Table & DB_Table) (column : Column) (value : Lat_Long_Type) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_latitude" <| expect_spatial_type column this_table.connection.dialect <|
            used_column = case value of
                Lat_Long_Type.Default -> _resolve_sql_function this_table (SQL_Function.SQL "ST_Centroid" [column])
                _ -> column
            function_name = case value of
                Lat_Long_Type.Default -> "ST_Y"
                Lat_Long_Type.Minimum -> "ST_YMin"
                Lat_Long_Type.Maximum -> "ST_YMax"
            new_column = _resolve_sql_function this_table (SQL_Function.SQL function_name [used_column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_latitude" [column]
            this_table.set new_column as=new_name

    spatial_extent (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_extent" <| expect_spatial_type column this_table.connection.dialect <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_Extent" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_extent" [column]
            this_table.set new_column as=new_name

    spatial_centroid (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_centroid" <| expect_spatial_type column this_table.connection.dialect <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_Centroid" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_centroid" [column]
            this_table.set new_column as=new_name

    spatial_perimeter (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_perimeter" <| expect_spatial_type column this_table.connection.dialect <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_Perimeter_Spheroid" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_perimeter" [column]
            this_table.set new_column as=new_name

    spatial_area (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_area" <| expect_spatial_type column this_table.connection.dialect <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_Area_Spheroid" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_area" [column]
            this_table.set new_column as=new_name

    spatial_distance (this_table : Table & DB_Table) (from_column : Column) (to_column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_distance" <| expect_spatial_type from_column this_table.connection.dialect <| expect_spatial_type to_column this_table.connection.dialect <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_Distance_Spheroid" [from_column, to_column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_distance" [from_column, to_column]
            this_table.set new_column as=new_name

    spatial_length (this_table : Table & DB_Table) (from_column : Column) (to_column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_length" <|
            line_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_MakeLine" [from_column, to_column])
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_Length_Spheroid" [line_column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_length" [from_column, to_column]
            this_table.set new_column as=new_name

    spatial_intersection (this_table : Table & DB_Table) (columns : Vector Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_intersection" <|
            if columns.is_empty then Error.throw (Missing_Argument.throw "columns")
            expect_spatial_type columns.first this_table.connection.dialect <|
                new_column = if columns.length == 1 then columns.first else
                    columns.fold columns.first cur->col->
                        expect_spatial_type col this_table.connection.dialect <|
                            _resolve_sql_function this_table (SQL_Function.SQL "ST_Intersection" [cur, col])
                new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_intersection" columns
                this_table.set new_column as=new_name

    spatial_union (this_table : Table & DB_Table) (columns : Vector Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_union" <|
            if columns.is_empty then Error.throw (Missing_Argument.throw "columns")
            expect_spatial_type columns.first this_table.connection.dialect <|
                new_column = if columns.length == 1 then columns.first else
                    columns.fold columns.first cur->col->
                        expect_spatial_type col this_table.connection.dialect <|
                            _resolve_sql_function this_table (SQL_Function.SQL "ST_Union" [cur, col])
                new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_union" columns
                this_table.set new_column as=new_name

    spatial_to_geojson (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_to_geojson" <| expect_spatial_type column this_table.connection.dialect <|
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_to_geojson" [column]
            new_column = make_unary_op column "ST_ASGEOJSON" new_name
            this_table.set new_column as=new_name

    spatial_from_geojson (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_from_geojson" <| Value_Type.expect_text column <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_GeomFromGeoJSON" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_from_geojson" [column]
            this_table.set new_column as=new_name

    spatial_to_wkt (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_to_wkt" <| expect_spatial_type column this_table.connection.dialect <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_AsText" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_to_wkt" [column]
            this_table.set new_column as=new_name

    spatial_from_wkt (this_table : Table & DB_Table) (column : Column) (as : Text) =
        Feature.Spatial.if_supported_else_throw this_table.connection.dialect "st_from_wkt" <| Value_Type.expect_text column <|
            new_column = _resolve_sql_function this_table (SQL_Function.SQL "ST_GeomFromText" [column])
            new_name = if as!="" then as else this_table.column_naming_helper.function_name "st_from_wkt" [column]
            this_table.set new_column as=new_name

## ---
   private: true
   ---
private _resolve_grouping_columns columns_helper:Table_Column_Helper group_by:Vector problem_builder:Problem_Builder -> Vector =
    grouping_columns = columns_helper.select_columns_helper group_by Case_Sensitivity.Default True problem_builder
    grouping_columns.each column->
        if column.value_type.is_floating_point then
            problem_builder.report_other_warning (Floating_Point_Equality.Error column.name)
    grouping_columns

## ---
   private: true
   ---
private _resolve_order_descriptors table ordering operation_name:Text =
    Ordering_Helpers.require_ordering table operation_name ordering=ordering <|
        dialect = table.connection.dialect
        default_ordering = table.default_ordering
        case ordering.is_empty of
            False -> ordering.map element->
                column = element.column
                associated_selector = element.associated_selector
                dialect.prepare_order_descriptor column:Internal_Column associated_selector.direction text_ordering=Nothing
            True -> default_ordering

_join_or_cross_join (this_table : Table & DB_Table) (right : Table & DB_Table) join_kind on right_prefix on_problems =
    can_proceed = Helpers.ensure_same_connection "table" [this_table, right] <|
        join_conditions_ok = join_kind != Join_Kind_Cross || on == []
        if join_conditions_ok . not then Error.throw (Illegal_Argument.Error "Cross join does not allow join conditions") else
            True
    can_proceed.if_not_error <|
        left = this_table
        table_name_deduplicator = this_table.connection.base_connection.table_naming_helper.create_unique_name_strategy
        table_name_deduplicator.mark_used [left.name, right.name]
        new_table_name = table_name_deduplicator.make_unique <|
            left.name + "_" + right.name

        needed_indicators = case join_kind of
            Join_Kind.Left_Exclusive  -> Pair.new False True
            Join_Kind.Right_Exclusive -> Pair.new True False
            _ -> Pair.new False False
        subquery_setups = Database_Join_Helper.prepare_subqueries this_table.connection left right needed_indicators.first needed_indicators.second
        left_setup = subquery_setups.first
        right_setup = subquery_setups.second

        problem_builder = Problem_Builder.new
        join_resolution = Database_Join_Helper.make_join_helpers left right left_setup.column_mapping right_setup.column_mapping . resolve on on_problems
        right_columns_to_drop = if join_kind == Join_Kind.Inner then join_resolution.redundant_column_names else []

        column_naming_helper = this_table.connection.base_connection.column_naming_helper
        result_columns = Database_Join_Helper.select_columns_for_join column_naming_helper join_kind left_setup.new_columns right_setup.new_columns right_columns_to_drop right_prefix problem_builder

        ## TODO proper equality of nulls in join conditions, see:
            https://www.pivotaltracker.com/story/show/184109759
        on_expressions = join_resolution.conditions

        where_expressions = case join_kind of
            Join_Kind.Left_Exclusive  ->
                is_right_missing = SQL_IR_Expression.Operation "IS_NULL" [right_setup.indicator_column.expression]
                [is_right_missing]
            Join_Kind.Right_Exclusive ->
                is_left_missing = SQL_IR_Expression.Operation "IS_NULL" [left_setup.indicator_column.expression]
                [is_left_missing]
            _ -> []

        sql_join_kind = case join_kind of
            Join_Kind.Inner           -> SQL_Join_Kind.Inner
            Join_Kind.Left_Outer      -> SQL_Join_Kind.Left
            Join_Kind.Right_Outer     -> SQL_Join_Kind.Right
            Join_Kind.Full            -> SQL_Join_Kind.Full
            Join_Kind.Left_Exclusive  -> SQL_Join_Kind.Left
            Join_Kind.Right_Exclusive -> SQL_Join_Kind.Right
            Join_Kind_Cross           -> SQL_Join_Kind.Cross

        problem_builder.attach_problems_before on_problems <|
            new_from = SQL_IR_From_Part.Join sql_join_kind left_setup.subquery right_setup.subquery on_expressions
            new_ctx = SQL_IR_Source.for_subquery new_from . set_where_filters where_expressions
            DB_Table.new new_table_name this_table.connection result_columns new_ctx

private expect_spatial_type column:Column dialect ~action =
    is_valid = case column.value_type of
        Value_Type.Unsupported_Data_Type type_name _ -> dialect.spatial_types.contains type_name
        _ -> False
    if is_valid then action else
        Error.throw (Illegal_Argument.Error "Column "+column.name+" is not of a spatial type.")

private _resolve_sql_function this_table:(Table & DB_Table) function:SQL_Function =
    ## Resolve Arguments
    in_table_column = this_table.columns.first
    expressions = function.arguments.map arg->
        case Table_Ref.from this_table . resolve arg of
            column : Column ->
                if Helpers.check_integrity in_table_column column then (column:DB_Column).expression else
                    Error.throw (Integrity_Error.Error "Column "+column.name)
            _ : Function -> Error.throw (Illegal_Argument.Error "Cannot use a function as argument to SQL function "+function.name)
            constant -> SQL_IR_Expression.Constant constant

    ## Create Expression
    new_expr = SQL_IR_Expression.Operation "CUSTOM_SQL" [SQL_IR_Expression.Literal function.function_name]+expressions

    ## Compute the return type
    mapping = this_table.connection.type_mapping
    infer_from_database_callback expression =
        SQL_Type_Reference.new this_table.connection this_table.context expression
    new_type_ref = mapping.infer_return_type infer_from_database_callback "CUSTOM_SQL" Nothing new_expr

    ## Create Column
    DB_Column.new function.function_name this_table.connection new_type_ref new_expr this_table.context
