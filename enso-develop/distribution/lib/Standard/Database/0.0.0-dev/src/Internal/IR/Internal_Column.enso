from Standard.Base import all

from Standard.Table import Column

import project.DB_Column.DB_Column
import project.Internal.IR.SQL_IR_Expression.SQL_IR_Expression
import project.Internal.SQL_Type_Reference.SQL_Type_Reference

type Internal_Column
    ## ---
       private: true
       ---
       An internal column structure.

       ## Arguments
        - `name`: The column name.
        - `sql_type_reference`: Lazily computed SQL type of the column.
        - `expression`: An expression for applying to the column.
    Value name:Text sql_type_reference:SQL_Type_Reference expression:SQL_IR_Expression

    ## ---
       private: true
       ---
       Rename the internal column.

       ## Arguments
        - `new_name`: The new name for the column.
    rename : Text -> Internal_Column
    rename self new_name = Internal_Column.Value new_name self.sql_type_reference self.expression

## ---
   private: true
   ---
Internal_Column.from (that : DB_Column) =
    Internal_Column.Value (that:Column).name that.sql_type_reference that.expression

## ---
   private: true
   ---
Internal_Column.from (that : Column) =
    Internal_Column.from (that : DB_Column)
