from Standard.Base import all

from project.Errors import Unsupported_Database_Operation

## ---
   private: true
   ---
type Feature
    ## ---
       private: true
       ---
       select, remove, reorder, and rename columns.
    Select_Columns

    ## ---
       private: true
       ---
       filter rows in a table.
    Filter

    ## ---
       private: true
       ---
       aggregate values in a table.
    Aggregate

    ## ---
       private: true
       ---
       sort rows in a table.
    Sort

    ## ---
       private: true
       ---
       join tables.
    Join

    ## ---
       private: true
       ---
       combine the results of two queries.
    Union

    ## ---
       private: true
       ---
       remove duplicate rows from a table.
    Distinct

    ## ---
       private: true
       ---
       cleanse text data.
    Text_Cleanse

    ## ---
       private: true
       ---
       Catch all for tests that haven't yet been categorized correctly or use
       multiple features.
    Integration_Tests

    ## ---
       private: true
       ---
       add a group number column to a table.
    Add_Group_Number

    ## ---
       private: true
       ---
       add a row number column to a table.
    Add_Row_Number

    ## ---
       private: true
       ---
       create a table from a dictionary or vectors.
    Make_Table_From

    ## ---
       private: true
       ---
       currently blocks getting a DB_Column from a DB_Table, but will soon refine
       to operations on DB_Column.
    Column_Operations

    ## ---
       private: true
       ---
       get_row, take, drop, limit
    Sample

    ## ---
       private: true
       ---
       replace values in a table.
    Replace

    ## ---
       private: true
       ---
       merge two tables.
    Merge

    ## ---
       private: true
       ---
       cross join two tables.
    Cross_Join

    ## ---
       private: true
       ---
       offset one or more columns
    Offset

    ## ---
       private: true
       ---
       generate rows from a range
    Generate_Rows

    ## ---
       private: true
       ---
       spatial operations
    Spatial

    ## ---
       private: true
       ---
       Check if a feature is supported by a dialect, and throw an error if it is
       not.
    if_supported_else_throw self dialect:Any error_name:Text ~action = 
        if dialect.is_feature_supported self then action else
            Error.throw (Unsupported_Database_Operation.Error error_name)
