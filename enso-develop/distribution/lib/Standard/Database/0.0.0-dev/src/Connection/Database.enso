from Standard.Base import all
import Standard.Base.Metadata.Display
import Standard.Base.Metadata.Widget
from Standard.Base.Metadata.Choice import Option
from Standard.Base.Metadata.Widget import Single_Choice

import project.Connection.Connection.Connection
import project.Connection.Connection_Details.Connection_Details
import project.Connection.Connection_Options.Connection_Options
import project.Internal.Telemetry
from project.Errors import SQL_Error

## ---
   macros:
    - postgres: details=Postgres.Server
    - sqlite: details=SQLite.From_File
    - sql_server: details=..SQLServer
    - snowflake: details=..Snowflake
    - duckdb: details=DuckDB.From_File
   group: Standard.Base.Database
   icon: drive
   suggested: 5
   ---
   Connects to database.

   ## Arguments
    - `details`: `Connection_Details` specifying the database to connect to.
    - `options`: Additional custom connection options for the JDBC connection.
@details connection_details_widget
@options Connection_Options.default_widget
connect : Connection_Details -> Connection_Options -> Connection ! SQL_Error
connect details options:Connection_Options=..Value =
    result = case details of
        _ : Function -> (Database_Connection_Details_SPI.resolve_constructor details) . connect options
        _ -> details.connect options
    result.if_not_error <|
        Telemetry.log "Database.connect" "Database connection opened: connection_type={}" [result.to Meta.Type . name]
        result

## ---
   private: true
   ---
connection_details_widget : Widget
connection_details_widget =
    default_constructors =
        Database_Connection_Details_SPI.get_default_constructors False
    choices = default_constructors.map pair->
        name = pair.first
        code = pair.second
        Option name code
    Single_Choice display=Display.Always values=choices

## ---
   private: true
   ---
type Database_Connection_Details_SPI
    private Single typ name:Text code:Text

    private Few arr:(Vector Database_Connection_Details_SPI)

    ## ---
       private: true
       ---
       Creates a new registration for a database connection details type.

       ## Arguments
        - `name` - The user facing name of the connection.
        - `code` - Default code that can be used to construct a default instance of the connection details.
    new typ name:Text code:Text =
        Database_Connection_Details_SPI.Single typ name code

    ## Joins two registrations together
    + self that:Database_Connection_Details_SPI =
        Database_Connection_Details_SPI.Few self.to_vector+that.to_vector

    private to_vector self = case self of
        Database_Connection_Details_SPI.Few arr -> arr
        single -> [single]

    private resolve_constructor constructor:Function =
        types = Database_Connection_Details_SPI.get_types False
        try_next idx =
            if idx >= types.length then constructor else
                db_type = types.at idx
                resolved = db_type.resolve constructor
                if resolved.is_nothing then @Tail_Call try_next (idx + 1) else resolved
        try_next 0

    private get_simple_regs b:Boolean  -> Vector Database_Connection_Details_SPI =
        _ = b
        reg = Meta.lookup_services Database_Connection_Details_SPI
        arr = reg.map .to_vector
        arr.flatten

    private get_types b:Boolean -> Vector =
        flat = Database_Connection_Details_SPI.get_simple_regs b
        flat.map .typ

    ## Returns an array of pairs, where the first element is the user facing
       connection name and the second element is a string representing the code
       to insert to create a default connection instance. That code may contain
       `_` placeholders for expected arguments.
    private get_default_constructors b:Boolean =
        flat = Database_Connection_Details_SPI.get_simple_regs b
        flat.map \r -> Pair.new r.name r.code
