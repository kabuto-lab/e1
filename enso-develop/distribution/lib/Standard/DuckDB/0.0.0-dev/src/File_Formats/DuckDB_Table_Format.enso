from Standard.Base import all
import Standard.Base.Errors.Common.Type_Error
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument
import Standard.Base.Runtime.Context
import Standard.Base.System.File.Generic.Writable_File.Writable_File
import Standard.Base.System.File_Format.File_Name_Pattern
import Standard.Base.System.File_Format_Metadata.File_Format_Metadata
import Standard.Base.System.Input_Stream.Input_Stream
from Standard.Base.Metadata.Choice import Option

from Standard.Table import Match_Columns, Table

import project.DuckDB.DuckDB
import project.DuckDB_Format.DuckDB_Format
import project.Internal.Telemetry
from project.File_Formats.Parquet_Format import _read_file

## Read a file into Enso using DuckDB.
type DuckDB_Table_Format
    ## Read a file into using DuckDB

       ## Arguments:
        - `format`: The format of the file to read. Default is Auto.
        - `in_memory`: Whether to load the data into an in-memory table or
           use as a DuckDB table. Default is False.
    DuckDB_Table format:DuckDB_Format=..Auto in_memory:Boolean=False

    ## ---
       private: true
       ---
       Resolve an unresolved constructor to the actual type.
    resolve : Function -> DuckDB_Table_Format | Nothing
    resolve constructor =
        Panic.catch Type_Error (constructor:DuckDB_Table_Format) _->Nothing

    ## ---
       private: true
       advanced: true
       ---
       If the File_Format supports reading from the file, return a configured
       instance.
    for_read : File_Format_Metadata -> DuckDB_Table_Format | Nothing
    for_read file:File_Format_Metadata =
        _ = file
        Nothing

    ## ---
       private: true
       ---
       If this File_Format should be used for writing to that file, return a
       configured instance.
    for_file_write : Writable_File -> DuckDB_Table_Format | Nothing
    for_file_write file = DuckDB_Table_Format.for_read file

    ## ---
       private: true
       ---
    get_dropdown_options : Vector Option
    get_dropdown_options = [Option "DuckDB Table" "..DuckDB_Table"]

    ## ---
       private: true
       ---
    get_name_patterns -> Vector File_Name_Pattern =
        []

    ## ---
       private: true
       advanced: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any
    read self file on_problems:Problem_Behavior =
        _ = on_problems
        db_table = _read_file file self.format
        result = if self.in_memory then db_table.read ..All_Rows else db_table
        result.if_not_error <|
            Telemetry.log "File_Format.read" "Read file: format={}, output={}, row_count={}, column_count={}" ["DuckDB_Table_Format", "Table", (if self.in_memory then result.row_count else -1), result.column_count]
            result

    ## ---
       private: true
       ---
       Implements decoding the format from a stream.
    read_stream : Input_Stream -> File_Format_Metadata -> Any
    read_stream self stream:Input_Stream (metadata : File_Format_Metadata = File_Format_Metadata.no_information) =
        _ = metadata

        ## Auto cannot be used for stream reading
        if self.format == DuckDB_Format.Auto then Error.throw (Illegal_Argument.Error "DuckDB cannot read streams using Auto format, specify a format.")

        ## Stream must be materialized to a file for DuckDB Parquet reading
        tmp_file = File.create_temporary_file "duckdb" ".tmp"

        ## Write stream to temporary file
        write_result = Context.Output.with_enabled <|
            inner = Panic.catch Any (stream.write_to_file tmp_file) caught_panic-> Error.throw caught_panic.payload
            if inner.is_error then tmp_file.delete
            inner
        Error.return_if_error write_result

        ## Read the Parquet file using DuckDB
        result = self.read tmp_file ..Ignore

        ## Clean up temporary file
        Context.Output.with_enabled <|
            Panic.catch Any (tmp_file.delete) _->Nothing

        result

    ## ---
       private: true
       advanced: true
       ---
       Implements the `Table.write` for this `File_Format`.
    write_table : File -> Table -> Existing_File_Behavior -> Match_Columns -> Problem_Behavior -> File
    write_table self file table on_existing_file match_columns on_problems:Problem_Behavior =
        _ = [match_columns, on_problems]
        connection = DuckDB.In_Memory.connect

        db_table = connection.bulk_load table "temp_table"
        Error.return_if_error db_table

        connection.write_file db_table file self.to_duckdb_format on_existing_file
