import project.Data.Text.Text
import project.Metadata.Display
import project.Metadata.Widget
from project.Metadata.Choice import Option
from project.Metadata.Widget import Single_Choice

polyglot java import org.enso.base.text.Case as Java_Case

## Specifies the casing options for text conversion.
type Case
    ## All letters in lower case.
    Lower

    ## All letters in upper case.
    Upper

    ## First letter of each word in upper case, rest in lower case.
    Proper

    ## ---
       private: true
       deprecated: true
       ---
       Deprecated use `Proper` instead.
    Title

    ## ---
       private: true
       ---
       Convert Case to a Java enum.
    to_java : Java_Case
    to_java self -> Java_Case = case self of
        Case.Lower -> Java_Case.LOWER
        Case.Upper -> Java_Case.UPPER
        Case.Proper -> Java_Case.PROPER
        Case.Title -> Java_Case.PROPER

    ## ---
       private: true
       ---
    to_text self -> Text = case self of
        Case.Lower -> "Lowercase"
        Case.Upper -> "Uppercase"
        Case.Proper -> "Proper Case"
        Case.Title -> "Proper Case"

    ## ---
       private: true
       ---
       Gets the default drop down option for Case.
    default_widget display:Display=..When_Modified -> Widget =
        values = [Option "..Lower", Option "..Upper", Option "..Proper"]
        Single_Choice values=values display=display
