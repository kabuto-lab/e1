from project.Data.Json import JS_Object

## Type for generating the visualisation data for the "Table" visualisation
   IMPORTANT - The types here must be kept in sync with those in
   TableVisualisationTypes.ts if you want your type to support this visualisation
   type you should provide a conversion to this type e.g.

   ```
       ## ---
          private: true
          ---
       Table_Viz_Data.from (that:MyType) =
   ```
type Table_Viz_Data
    ## Temporary constructor for viz types that have not yet moved to this model
    Value js_object:JS_Object

    ## Table Viz for errors
    Error error_display_text

    ## Table Viz for a generic grid
    GenericGrid headers data

    ## produces the JS Object to send across to the ts visualisation code
    get_js_object self -> JS_Object =
        case self of    
            Table_Viz_Data.Value _ -> self.js_object
            Table_Viz_Data.Error _ -> _make_js_object_for_error self.error_display_text
            Table_Viz_Data.GenericGrid _ _ -> _make_js_object_for_generic_grid self.headers self.data

type Table_Viz_Header
    ## Column with links to create child nodes.
    Link name tooltip action

    ## Column with a label.
    Label name

private _make_js_object_for_generic_grid headers data =
    JS_Object.from_pairs [["type", "Generic_Grid"], ["data", data], ["headers", headers.map _make_js_object_for_header]]

private _make_js_object_for_header header = case header of
    Table_Viz_Header.Label _ -> JS_Object.from_pairs [["visualization_header", header.name]]
    Table_Viz_Header.Link _ _ _ -> JS_Object.from_pairs [["visualization_header", header.name], ["child_label", header.tooltip], ["get_child_node_action", header.action]]

private _make_js_object_for_error error_display_text =
    pairs = [["type", "Error"], ["error", error_display_text]]
    JS_Object.from_pairs pairs
