import project.Data.Dictionary.Dictionary
import project.Data.Text.Text
import project.Nothing.Nothing
import project.Runtime.State

polyglot java import java.lang.System as Java_System

## ---
   aliases: [read environment]
   icon: system
   ---
   Returns a value of a specified environment variable or Nothing if such
   variable is not defined.

   ## Arguments
    - `key`: The name of the environment variable to look up.
    - `if_missing`: The default fallback value.

   ## Examples
   ### Look up the value of the `PATH` environment variable.

   ```
         import Standard.Base.System.Environment

         example_get = Environment.get "PATH"
   ```
get key:Text ~if_missing:Text|Nothing=Nothing -> (Text|Nothing) =
    mock_dict = State.get Environment if_missing=Nothing
    mock_value = if mock_dict == Nothing then Nothing else
        (mock_dict:Dictionary).get key
    value = if mock_value != Nothing then mock_value else
        Java_System.getenv key
    if value != Nothing then value else
        if_missing
