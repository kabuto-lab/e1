## ---
   private: true
   ---
   Gets the first format not returning Nothing from the callback
get_format : Function -> Any | Nothing
get_format callback =
    types = File_Format_SPI.get_types
    reader idx =
        if idx >= types.length then Nothing else
            format = callback (types.at idx)
            if format.is_nothing.not then format else
                @Tail_Call reader (idx + 1)
    reader 0

## Automatically detects the file format based on the file extension or mime-type.
type Auto_Detect
    ## ---
       private: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any ! File_Error
    read self file on_problems:Problem_Behavior =
        metadata = File_Format_Metadata.from file
        reader = Auto_Detect.get_reading_format metadata
        if reader == Nothing then Error.throw (File_Error.Unsupported_Type file) else
            reader.read file on_problems

    ## ---
       private: true
       ---
       Finds a matching format for reading the file.
       It assumes that `file` already exists.
    get_reading_format : File_Format_Metadata -> Any | Nothing
    get_reading_format file:File_Format_Metadata =
        get_format f-> f.for_read file

    ## ---
       private: true
       ---
       Finds a matching format for reading the file.
       It may not assume that the `file` exists, so it must only rely on the file
       path (extension in particular), but not the contents.
    get_writing_format : File -> Any | Nothing
    get_writing_format file =
        get_format f-> f.for_file_write file

    ## ---
       private: true
       ---
    get_dropdown_options : Vector Option
    get_dropdown_options = [Option "Auto Detect" (Auto_Detect.to Meta.Type . qualified_name)]

    ## ---
       private: true
       ---
       Returns the union of name patterns of all currently loaded formats, since
       `Auto_Detect` should be able to read any of the loaded formats.
    get_name_patterns -> Vector File_Name_Pattern =
        [File_Name_Pattern.Value "All known formats" File_Format.all_known_name_patterns]

## Interface for all file formats.
type File_Format
    ## ---
       private: true
       advanced: true
       ---
       Gets all the currently available file formats.
       The available file formats are ones provided by libraries which are
       imported within the current project. Importing an new library may cause
       more entries to show up on this list.
    all : Vector
    all = [Auto_Detect] + File_Format_SPI.get_types

    ## ---
       private: true
       ---
       Resolve an unresolved constructor to the actual type.
    resolve : Function -> File_Format
    resolve constructor = case constructor of
        _ : Function ->
            arr = File_Format_SPI.get_types
            try_next idx =
                if idx >= arr.length then Error.throw (Illegal_Argument.Error "Expected a file format, but got a function.") else
                    format = arr.at idx
                    resolved = format.resolve constructor
                    if resolved.is_nothing then @Tail_Call try_next (idx + 1) else resolved
            try_next 0
        _ -> constructor

    ## ---
       private: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any
    read self file on_problems:Problem_Behavior =
        _ = [file, on_problems]
        Unimplemented.throw "This is an interface only."

    ## ---
       private: true
       ---
       Implements decoding the format from a stream.
    read_stream : Input_Stream -> File_Format_Metadata -> Any
    read_stream self stream:Input_Stream (metadata : File_Format_Metadata) =
        _ = [stream, metadata]
        Unimplemented.throw "This is an interface only."

    ## ---
       private: true
       ---
       A static method on each format that returns a vector of options that can
       be displayed in format selectors that allow choosing this file format.
       A single format instance can provide multiple options to choose, or none
       at all.
    get_dropdown_options : Vector Option
    get_dropdown_options = Unimplemented.throw "This is an interface only."

    ## ---
       private: true
       ---
       A static method on each format that returns a vector of name pattern
       options that can be displayed in the `name_filter_widget`.
    get_name_patterns -> Vector File_Name_Pattern = Unimplemented.throw "This is an interface only."

    ## ---
       private: true
       ---
       Returns a list of all name patterns of all known file formats.
    all_known_name_patterns -> Vector Text =
        File_Format_SPI.get_types.flat_map .get_name_patterns . flat_map .patterns . distinct

    ## ---
       private: true
       ---
    default_widget display:Display=..When_Modified -> Widget =
        options = ([Auto_Detect]+File_Format_SPI.get_types).flat_map .get_dropdown_options
        Single_Choice display=display values=options

    ## ---
       private: true
       ---
       Builds a widget intended to be used for `name_filter` of `File.list` and
       its siblings that allows to filter file names by file format.
    name_filter_widget -> Widget =
        known_patterns = File_Format.all.flat_map .get_name_patterns
        options = [Option "Any file" '""'] + known_patterns.map file_name_pattern->
            value = (_combine_patterns file_name_pattern.patterns) . pretty
            Option file_name_pattern.display_name value
        Single_Choice display=Display.When_Modified values=options

## Combines a set of file name patterns into a single pattern that will match any
   of them.
   It is compatible with the `name_filter` format of `File.list`.
private _combine_patterns (patterns : Vector Text) -> Text =
    Runtime.assert (patterns.length > 0)
    Runtime.assert message="The name patterns cannot contain {a,b} patterns to be mergeable." <|
        contains_cases_regex = ".*[{},].*"
        patterns.all (p-> p.match contains_cases_regex . not)
    patterns.join prefix="{" separator="," suffix="}"

## A file format for plain text files.
type Plain_Text_Format
    ## A file format for plain text files with the specified encoding.

       ## Arguments
        - `encoding`: The encoding to use. If the encoding is set to `Infer`, it
          will be inferred from metadata if available, falling back to the
          default encoding (UTF-8 with Windows-1252 fallback). For writing, UTF-8
          is used as default, unless overridden.
    @encoding Encoding.default_widget
    Plain_Text (encoding : Encoding | Infer = Infer)

    ## ---
       private: true
       ---
       Resolve an unresolved constructor to the actual type.
    resolve : Function -> Plain_Text_Format | Nothing
    resolve constructor =
        Panic.catch Type_Error (constructor:Plain_Text_Format) _->Nothing

    ## ---
       private: true
       ---
       If the File_Format supports reading from the file, return a configured
       instance.
    for_read : File_Format_Metadata -> Plain_Text_Format | Nothing
    for_read file:File_Format_Metadata =
        content_type = file.interpret_content_type
        from_content_type = content_type.if_not_nothing <|
            case content_type.base_type of
                "text/plain" ->
                    effective_encoding = content_type.encoding.if_nothing Encoding.default
                    Plain_Text_Format.Plain_Text effective_encoding
                _ -> Nothing
        from_content_type.if_nothing <| case file.guess_extension of
            ".txt" -> Plain_Text_Format.Plain_Text Encoding.default
            ".log" -> Plain_Text_Format.Plain_Text Encoding.default
            _ -> Nothing

    ## ---
       private: true
       ---
       If this File_Format should be used for writing to that file, return a
       configured instance.
    for_file_write : Writable_File -> Plain_Text_Format | Nothing
    for_file_write file = Plain_Text_Format.for_read file

    ## ---
       private: true
       ---
    get_dropdown_options : Vector Option
    get_dropdown_options = [Option "Plain Text" "..Plain_Text"]

    ## ---
       private: true
       ---
    get_name_patterns -> Vector File_Name_Pattern =
        [File_Name_Pattern.Value "Plain Text" ["*.txt"], File_Name_Pattern.Value ".log files as Plain Text" ["*.log"]]

    ## ---
       private: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any
    read self file on_problems:Problem_Behavior =
        result = file.read_text (self.resolve_encoding file) on_problems
        result.if_not_error <|
            Telemetry.log "File_Format.read" "Read file: format={}, output={}" ["Plain_Text", "Text"]
            result

    ## ---
       private: true
       ---
       Implements decoding the format from a stream.
    read_stream : Input_Stream -> File_Format_Metadata -> Any
    read_stream self stream:Input_Stream (metadata : File_Format_Metadata = File_Format_Metadata.no_information) =
        Text.from_bytes (stream.read_all_bytes) (self.resolve_encoding metadata)

    ## ---
       private: true
       ---
    resolve_encoding : File_Format_Metadata -> Encoding
    resolve_encoding self (metadata : File_Format_Metadata) =
        if self.encoding != Infer then self.encoding else
            content_type = metadata.interpret_content_type
            resolved_encoding = content_type.if_not_nothing <| content_type.encoding
            resolved_encoding.if_nothing Encoding.default

## A file format for reading or writing files as a sequence of bytes.
type Bytes
    ## ---
       private: true
       ---
       Resolve an unresolved constructor to the actual type.
    resolve : Function -> Bytes | Nothing
    resolve constructor =
        _ = constructor
        Nothing

    ## ---
       private: true
       ---
       If the File_Format supports reading from the file, return a configured
       instance.
    for_read : File_Format_Metadata -> Bytes | Nothing
    for_read file:File_Format_Metadata =
        case file.guess_extension of
            ".dat" -> Bytes
            _ -> Nothing

    ## ---
       private: true
       ---
       If this File_Format should be used for writing to that file, return a
       configured instance.
    for_file_write : Writable_File -> Bytes | Nothing
    for_file_write file = Bytes.for_read file

    ## ---
       private: true
       ---
    get_dropdown_options : Vector Option
    get_dropdown_options = [Option "Bytes" (Bytes.to Meta.Type . qualified_name)]

    ## ---
       private: true
       ---
    get_name_patterns -> Vector File_Name_Pattern =
        [File_Name_Pattern.Value ".dat Binary Data" ["*.dat"]]

    ## ---
       private: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any
    read self file on_problems:Problem_Behavior =
        _ = [on_problems]
        result = file.read_bytes
        result.if_not_error <|
            Telemetry.log "File_Format.read" "Read file: format={}, output={}, length={}" ["Bytes", "Vector", result.length]
            result

    ## ---
       private: true
       ---
       Implements decoding the format from a stream.
    read_stream : Input_Stream -> File_Format_Metadata -> Any
    read_stream self stream:Input_Stream (metadata : File_Format_Metadata = File_Format_Metadata.no_information) =
        _ = metadata
        stream.read_all_bytes

## A file format for reading and writing files as JSON.
type JSON_Format
    ## ---
       private: true
       ---
       Resolve an unresolved constructor to the actual type.
    resolve : Function -> JSON_Format | Nothing
    resolve constructor =
        _ = constructor
        Nothing

    ## ---
       private: true
       ---
       If the File_Format supports reading from the file, return a configured
       instance.
    for_read : File_Format_Metadata -> JSON_Format | Nothing
    for_read file:File_Format_Metadata =
        content_type = file.interpret_content_type
        from_content_type = content_type.if_not_nothing <|
            case content_type.base_type of
                "application/json" -> JSON_Format
                _ -> Nothing
        from_content_type.if_nothing <| case file.guess_extension of
            ".json" -> JSON_Format
            ".geojson" -> JSON_Format
            _ -> Nothing

    ## ---
       private: true
       ---
       If this File_Format should be used for writing to that file, return a
       configured instance.
    for_file_write : Writable_File -> JSON_Format | Nothing
    for_file_write file = JSON_Format.for_read file

    ## ---
       private: true
       ---
    get_dropdown_options : Vector Option
    get_dropdown_options = [Option "JSON" (JSON_Format.to Meta.Type . qualified_name)]

    ## ---
       private: true
       ---
    get_name_patterns -> Vector File_Name_Pattern =
        [File_Name_Pattern.Value "JSON" ["*.json", "*.geojson"]]

    ## ---
       private: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any
    read self file on_problems:Problem_Behavior =
        _ = [on_problems]
        text = file.read_text
        result = Json.parse text . catch Invalid_JSON error->
            Error.throw (File_Error.Corrupted_Format file error.to_display_text error)
        result.if_not_error <|
            Telemetry.log "File_Format.read" "Read file: format={}, output={}" ["JSON", result.to Meta.Type . name]
            result

    ## ---
       private: true
       ---
       Implements decoding the format from a stream.
    read_stream : Input_Stream -> File_Format_Metadata -> Any
    read_stream self stream:Input_Stream (metadata : File_Format_Metadata) =
        _ = metadata
        Text.from_bytes (stream.read_all_bytes) Encoding.utf_8 . parse_json

## ---
   private: true
   ---
JSON_Format.from (that : JS_Object) =
    _ = that
    JSON_Format

## A file format for reading and writing files as JSON Lines (i.e. a JSON object per line).
   https://jsonlines.org/
type JSON_Lines_Format
    ## ---
       private: true
       ---
       Resolve an unresolved constructor to the actual type.
    resolve : Function -> JSON_Lines_Format | Nothing
    resolve constructor =
        _ = constructor
        Nothing

    ## ---
       private: true
       ---
       If the File_Format supports reading from the file, return a configured
       instance.
    for_read : File_Format_Metadata -> JSON_Lines_Format | Nothing
    for_read file:File_Format_Metadata =
        content_type = file.interpret_content_type
        from_content_type = content_type.if_not_nothing <|
            case content_type.base_type of
                "application/x-ndjson" -> JSON_Lines_Format
                "application/jsonl" -> JSON_Lines_Format
                _ -> Nothing
        from_content_type.if_nothing <| case file.guess_extension of
            ".jsonl" -> JSON_Lines_Format
            _ -> Nothing

    ## ---
       private: true
       ---
       If this File_Format should be used for writing to that file, return a
       configured instance.
    for_file_write : Writable_File -> JSON_Lines_Format | Nothing
    for_file_write file = JSON_Lines_Format.for_read file

    ## ---
       private: true
       ---
    get_dropdown_options : Vector Option
    get_dropdown_options = [Option "JSON Lines" (JSON_Lines_Format.to Meta.Type . qualified_name)]

    ## ---
       private: true
       ---
    get_name_patterns -> Vector File_Name_Pattern =
        [File_Name_Pattern.Value "JSON Lines" ["*.jsonl"]]

    ## ---
       private: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any
    read self file on_problems:Problem_Behavior =
        text = file.read_text
        self.read_text text on_problems file

    ## ---
       private: true
       ---
       Implements decoding the format from a stream.
    read_stream : Input_Stream -> File_Format_Metadata -> Any
    read_stream self stream:Input_Stream (metadata : File_Format_Metadata) =
        _ = metadata
        text = Text.from_bytes (stream.read_all_bytes) Encoding.utf_8
        self.read_text text Problem_Behavior.Report_Warning Nothing

    private read_text text on_problems file =
        warnings = Ref.new []
        result = text.lines.map_with_index on_problems=No_Wrap.Value i->l->
            parsed = l.parse_json
            if parsed.is_error.not then parsed else case on_problems of
                Problem_Behavior.Ignore -> Nothing
                Problem_Behavior.Report_Warning ->
                    warnings.put (warnings.get + [File_Error.Corrupted_Format file ("Malformed JSON line ("+i.to_text+"): "+l.to_display_text)])
                    Nothing
                Problem_Behavior.Report_Error ->
                    Error.throw (File_Error.Corrupted_Format file ("Malformed JSON line ("+i.to_text+"): "+l.to_display_text))
        result.if_not_error <|
            Telemetry.log "File_Format.read" "Read file: format={}, output={}" ["JSON Lines", result.to Meta.Type . name]
            warnings.get.reverse.fold result (r->w-> Warning.attach w r)

## ---
   private: true
   ---
JSON_Lines_Format.from (that : JS_Object) =
    _ = that
    JSON_Lines_Format

## A setting to infer the default behaviour of some option.
type Infer

## ---
   private: true
   ---
   A helper for parsing the JSON representation of `Boolean | Infer`.
   It defaults to `Infer` if the value was `Nothing`.
parse_boolean_with_infer (field_name : Text) (value : Boolean | Text | Nothing) -> Boolean | Infer = case value of
    True -> True
    False -> False
    Nothing -> Infer
    headers_text : Text -> case headers_text.to_case Case.Lower of
        "infer" -> Infer
        "true" -> True
        "false" -> False
        _ -> Error.throw (Illegal_Argument.Error ("The field `"+field_name+"` must be a boolean or the string `infer`."))

## ---
   private: true
   ---
type File_Name_Pattern
    ## ---
       private: true
       ---
       Represents a single file pattern entry.
       It may still contain multiple patterns that are related to a single type
       of file.
       Each pattern should comply with the format expected by `name_filter` in
       `File.list`, however, the patterns should not use the `{a,b}` syntax, as
       it will be used by the `File_Format` to merge patterns and nesting it
       would not be allowed.
    Value display_name:Text (patterns : Vector Text)

## ---
   private: true
   ---
   Service provide interface to implement and register to expand capabilities
   of `File_Format` recognition. Define singleton type in a `private`
   module in your library:
   ```
   type Your_Providers
   File_Format_SPI.from (_:YourProviders) =
       File_Format_SPI.new "your info"
   ```
   and then add a registration into `package.yaml` of your library.
type File_Format_SPI
    private Single typ data_link_format_name:Text|Nothing

    private Few arr:(Vector File_Format_SPI)

    ## ---
       private: true
       ---
       Creates new file format service provider registration

       ## Arguments
        - `typ`: type implementing the _"file format protocol"_
        - `name`: data link format name
    new typ name:Text|Nothing=Nothing -> File_Format_SPI =
        File_Format_SPI.Single typ name

    ## ---
       private: true
       ---
       Concatenates two registrations together. Allows one conversion to
       register multiple file formats service providers
    + self that:File_Format_SPI = File_Format_SPI.Few self.to_vector+that.to_vector

    private to_vector self -> Vector File_Format_SPI = case self of
        File_Format_SPI.Few arr -> arr
        single -> [single]

    private get_regs b:Boolean=False =
        _ = b
        reg = Meta.lookup_services File_Format_SPI
        reg.map .to_vector . flatten

    ## ---
       private: true
       ---
       Returns all registered file format types.
    get_types b:Boolean=False =
        File_Format_SPI.get_regs b . map .typ

    private find_format_for_data_link sub_type:Text =
        all = File_Format_SPI.get_regs False
        found = all.filter \spi -> spi.data_link_format_name == sub_type
        if found.length > 0 then found.first . typ else
            Error.throw <|
                Illegal_State.Error "Unknown format "+sub_type

