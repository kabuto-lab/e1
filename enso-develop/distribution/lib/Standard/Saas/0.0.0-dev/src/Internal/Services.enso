private

import Standard.Base.Network.Email.Email_Provider.Email_Provider_SPI

import project.Email_Provider_SMTP.Email_Provider_SMTP

## Resgisters the SMTP Email Provider implementation with the Email Provider SPI.
type Email_Provider_SMTP_Service

Email_Provider_SPI.from (that:Email_Provider_SMTP_Service) =
    _ = that
    Email_Provider_SPI.new Email_Provider_SMTP
