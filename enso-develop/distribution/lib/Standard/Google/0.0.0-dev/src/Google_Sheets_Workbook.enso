import Standard.Base.Data.Vector.No_Wrap
import Standard.Base.Errors.Illegal_Argument.Illegal_Argument
import Standard.Base.Metadata.Display
import Standard.Base.Metadata.Widget
from Standard.Base.Enso_Cloud.Enso_Secret import as_credential_reference
from Standard.Base.Metadata import make_single_choice
from Standard.Base.Metadata.Choice import Option
from Standard.Base.Metadata.Widget import Multiple_Choice, Single_Choice
from Standard.Base.Visualization.Table_Viz_Data import Table_Viz_Data, Table_Viz_Header

import Standard.Table.Internal.Java_Problems
import Standard.Table.Return_As_Table.Return_As_Table
import Standard.Table.Rows_To_Read.Rows_To_Read
from Standard.Table import Column, Headers, Table
from Standard.Table.Errors import Empty_Sheet, Invalid_Location, No_Rows
from Standard.Table.In_Memory_Table import from_java_table
from Standard.Table.Internal.Table_Helpers import duplicate_rows

import project.Internal.Telemetry

polyglot java import com.google.api.client.googleapis.json.GoogleJsonResponseException
polyglot java import org.enso.base.enso_cloud.ExternalLibraryCredentialHelper.CredentialReference
polyglot java import org.enso.google.GoogleSheetsForEnso
polyglot java import org.enso.google.GoogleSheetsHeaders.HeaderBehavior
polyglot java import org.enso.google.WrappedGoogleCredentials
polyglot java import org.enso.table.error.EmptySheetException
polyglot java import org.enso.table.problems.ProblemAggregator

## Type representing a Google Sheets workbook.
type Google_Sheets_Workbook
    ## ---
       private: true
       ---
    Value workbook_id:Text java_service

    ## ---
       icon: cloud
       ---
       Initializes the Google Sheets instance using the given credentials file.

       ## Arguments
        - `credentials`: a Cloud secret or a file containing Google Service
          Account credentials to use to access Google services. The credentials
          file can be downloaded from the Google Admin Console when generating a
          key.
    new workbook_id:Text credentials:Enso_Secret =
        service = GoogleSheetsForEnso.create (_wrap_credentials credentials)
        Google_Sheets_Workbook.Value workbook_id service

    ## ---
       aliases: [get, import, load, open, range, sheet, worksheet]
       group: Standard.Base.Input
       icon: data_input
       suggested: 1
       ---
       Read a range into a Table.

       ## Arguments
        - `query`: sheet name, range name or address to read from the workbook.
        - `headers`: whether to use the first row as headers (default is
          `Detect_Headers`).
        - `limit`: the maximum number of rows to read. If set to `Nothing`, all
          rows will be returned.
        - `skip_rows`: the number of rows to skip before starting to read data.
          (Headers are taken after skipping).
    @query self-> _query_widget self
    read self query:(Text|Integer) headers:Headers=..Detect_Headers limit:Rows_To_Read=..All_Rows skip_rows:Integer=0 on_problems:Problem_Behavior=..Report_Warning -> Table =
        java_headers = _make_java_headers headers
        java_limit = limit.rows_to_read
        java_table = Java_Problems.with_problem_aggregator on_problems problem_aggregator=ProblemAggregator java_problem_aggregator-> _handle_exceptions <|
            case query of
                _ : Text -> self.java_service.getSheetRange self.workbook_id query java_headers java_limit skip_rows java_problem_aggregator
                _ : Integer ->
                    names = self.sheet_names
                    if (query < 1 || query > names.length) then Error.throw (Invalid_Location.Error "Sheet "+query.to_text+" is out of range (1 to "+names.length.to_text+" inclusive).") else
                        self.java_service.getSheetRange self.workbook_id (names.at (query - 1)) java_headers java_limit skip_rows java_problem_aggregator
        result = limit.attach_warning (from_java_table java_table)
        result.if_not_error <|
            Telemetry.log "Google_Sheets_Workbook.read" "Read sheet: format={}, output={}, row_count={}, column_count={}" ["Google_Sheets_Format", "Table", result.row_count, result.column_count]
        result

    ## ---
       group: Standard.Base.Input
       icon: data_input
       suggested: 2
       ---
       Reads one or more sheets into a Table.

       ## Arguments
        - `sheet_names`: the names of sheets, ranges or addresses to read.
          Defaults to all sheets. An invalid `sheet_name` will be reported as a
          problem.
        - `headers`: whether to use the first row as headers (default is
          `Detect_Headers`) for each sheet.
        - `return`: how to return the tables. Defaults to `As_Merged_Table`
          meaning the tables are merged into a single table.
        - `on_problems`: how to handle problems during reading. Defaults to
          `Report_Warning`.
    @sheet_names _sheet_selector_widget
    @return make_single_choice Return_As_Table.get_dropdown_options
    read_many self sheet_names:Vector=self.sheet_names headers:Headers=..Detect_Headers return:Return_As_Table=..As_Merged_Table on_problems:Problem_Behavior=..Report_Warning =
        case return of
            Return_As_Table.With_New_Column ->
                tables_or_nothing = sheet_names.map on_problems=on_problems address->
                    self.read address headers on_problems=on_problems
                Table.new [["Sheet Name", sheet_names], ["Table", tables_or_nothing]]
            Return_As_Table.As_Merged_Table columns_to_keep match ->
                names_and_tables = _read_sheets self sheet_names headers on_problems
                only_valid = names_and_tables.filter p-> p.second.is_nothing.not
                if only_valid.is_empty then Error.throw (Illegal_Argument.Error "No valid sheets found.") else
                    valid_names = only_valid.map .first
                    valid_tables = only_valid.map .second
                    unified_tables = Table.from_union valid_tables columns_to_keep=columns_to_keep match_columns=match on_problems=on_problems
                    (_sheet_names_table valid_names valid_tables).zip unified_tables right_prefix="" on_problems=on_problems

    ## ---
       group: Standard.Base.Metadata
       icon: metadata
       suggested: 3
       ---
       Gets the names of all the sheets.
    sheet_names self -> Vector Text = _handle_exceptions <|
        Vector.from_polyglot_array (self.java_service.getSheetNames self.workbook_id)

    ## ---
       group: Standard.Base.Metadata
       icon: metadata
       suggested: 4
       ---
       Gets the names of all the named ranges.
    named_ranges self -> Vector Text = _handle_exceptions <|
        Vector.from_polyglot_array (self.java_service.getRangeNames self.workbook_id) . sort

    ## ---
       group: Standard.Base.Metadata
       icon: metadata
       suggested: 5
       ---
       Gets the number of sheets.
    sheet_count self -> Integer = _handle_exceptions <|
        self.java_service.getNumberOfSheets self.workbook_id

    ## ---
       group: Standard.Base.Metadata
       icon: metadata
       suggested: 6
       ---
       Gets the number of named ranges.
    named_ranges_count self -> Integer = _handle_exceptions <|
        self.java_service.getNumberOfNames self.workbook_id

## ---
   private: true
   ---
Table_Viz_Data.from (that:Google_Sheets_Workbook) = 
    Table_Viz_Data.GenericGrid [Table_Viz_Header.Link "worksheets" "worksheet" "read"] [that.sheet_names.to_vector]

## Error occurred when calling the Google Sheets API
type Google_API_Error
    ## ---
       private: true
       ---
    Error details

    ## ---
       private: true
       ---
       Render the error to text.
    to_display_text self =
        self.details.at 'message'

private _handle_exceptions ~action =
    Panic.catch EmptySheetException handler=(_ -> Error.throw Empty_Sheet.Error)
        Panic.catch GoogleJsonResponseException action caught_panic->
            Error.throw (Google_API_Error.Error caught_panic.payload.getContent.parse_json)

private _wrap_credentials credential:(File|Enso_Secret|Nothing)=Nothing =
    case credential of
        secret : Enso_Secret ->
            WrappedGoogleCredentials.fromCredentialReference (as_credential_reference secret CredentialReference)
        secret_file : File ->
            secret_file.with_input_stream [File_Access.Read] stream->
                stream.with_java_stream java_input_stream->
                    WrappedGoogleCredentials.fromStream java_input_stream
        _ -> Nothing

private _make_java_headers headers:Headers = case headers of
    Headers.Has_Headers -> HeaderBehavior.USE_FIRST_ROW_AS_HEADERS
    Headers.Detect_Headers -> HeaderBehavior.INFER
    Headers.No_Headers -> HeaderBehavior.DEFAULT_COLUMN_NAMES

private _sheet_names_table (sheet_names : Vector Text) (loaded_tables : Vector Table) -> Table =
    table = Column.from_vector "Sheet Name" sheet_names . to_table
    counts = loaded_tables.map t-> t.row_count
    duplicate_rows table counts

private _read_sheets workbook:Google_Sheets_Workbook (sheet_names : Vector Text) headers:Headers on_problems:Problem_Behavior -> Vector (Pair Text (Table | Nothing)) =
    sheet_names.map on_problems=No_Wrap.Value address->
        table = workbook.read address headers on_problems=on_problems
        r = Pair.new address table
        # If in Report_Error mode, we forward the original error without wrapping, otherwise we wrap any warnings.
        if on_problems == Problem_Behavior.Report_Error then r else 
            r.catch Any error->
                on_problems.attach_problem_after (Pair.new address Nothing) <|
                    (No_Rows.Warning "The sheet "+address.to_display_text+" failed to load, so it is not included in the `As_Merged_Table` result of `read_many`. The error was: "+error.to_display_text)


## Creates widget for read_many sheet selector
private _sheet_selector_widget workbook:Google_Sheets_Workbook display:Display=Display.Always -> Widget =
    names = workbook.sheet_names.map n-> Option n n.pretty
    Multiple_Choice display=display values=names


## Creates a query widget for the `read` method.
private _query_widget wb:Google_Sheets_Workbook display:Display=..Always -> Widget =
    options = [Option "<By Index>" "1"] + (wb.sheet_names . to_vector . map t-> Option t t.pretty) + (wb.named_ranges . to_vector . map t-> Option t t.pretty)
    Single_Choice display=display values=options
