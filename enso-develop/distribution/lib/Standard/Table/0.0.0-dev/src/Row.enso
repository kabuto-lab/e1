from Standard.Base import all
import Standard.Base.Data.Array_Proxy.Array_Proxy
import Standard.Base.Errors.Common.Index_Out_Of_Bounds

import project.Errors.No_Such_Column
import project.Internal.Widget_Helpers
from project.Internal.Storage import java_to_enso

polyglot java import org.enso.table.data.table.Row as Java_Row # necessary for reflection metadata

## Represents a single row of some in-memory Table.
type Row
    ## ---
       private: true
       ---
    private Value java_row

    ## ---
       private: true
       ---
       Access the index
    index : Integer
    index self = self.java_row.index

    ## ---
       group: Standard.Base.Metadata
       icon: metadata
       ---
       Gets the set of column column_names
    column_names : Vector Text
    column_names self =
        Vector.from_polyglot_array self.java_row.column_names

    ## ---
       group: Standard.Base.Metadata
       icon: metadata
       ---
       Gets the number of columns in the table.
    length : Integer
    length self = self.java_row.column_count

    ## ---
       icon: parse3
       ---
       Gets the value of the specified column.

       ## Arguments
        - `column`: The name or index of the column being looked up.
        - `if_missing`: The value to use if the column isn't present.
    @column (self -> Widget_Helpers.make_column_name_selector self)
    get : (Integer | Text) -> Any -> Any
    get self (column:(Integer | Text)=0) ~if_missing=Nothing =
        java_to_enso <| self.java_row.get_value column _->if_missing

    ## ---
       group: Standard.Base.Selections
       icon: parse3
       ---
       Gets the value of the specified column.

       ## Arguments
        - `column`: The name or index of the column being looked up.
    @column (self -> Widget_Helpers.make_column_name_selector self)
    at : (Integer | Text) -> Any
    at self (column:(Integer | Text)=0) =
        if_missing column = case column of
            _:Integer -> Error.throw (Index_Out_Of_Bounds.Error column self.length)
            _:Text -> Error.throw (No_Such_Column.Error column)
        java_to_enso <| self.java_row.get_value column if_missing

    ## ---
       group: Standard.Base.Conversions
       icon: convert
       ---
       Gets the row as a Vector.
    to_vector : Vector
    to_vector self = Vector.from_polyglot_array (Array_Proxy.from_proxy_object self)

    ## ---
       group: Standard.Base.Conversions
       icon: convert
       ---
       Gets the row as a Dictionary.
    to_dictionary : Dictionary
    to_dictionary self =
        pairs = self.column_names.map n-> [n, self.get n]
        Dictionary.from_vector pairs

    ## ---
       private: true
       ---
       Converts this row into a JS_Object.
    to_js_object : JS_Object
    to_js_object self =
        pairs = self.column_names.map n-> [n, self.get n]
        JS_Object.from_pairs pairs

    ## ---
       private: true
       ---
       Converts this row into a JSON representation.
    to_json_data : Text
    to_json_data self =
        self.java_row.toJsonData v->v.to_json

## ---
   private: true
   ---
   Conversion method to a Column to a Vector.
Vector.from (that:Row) = that.to_vector

## ---
   private: true
   ---
type Row_Comparator
    ## ---
       private: true
       ---
    compare : Row -> Row -> (Ordering|Nothing)
    compare obj1 obj2 =
        if (obj1.java_row.table.equals obj2.java_row.table) && (obj1.index == obj2.index) then Ordering.Equal else Nothing

    ## ---
       private: true
       ---
    hash : Row -> Integer
    hash obj =
        table_hash = obj.java_row.table.hashCode
        index_hash = obj.index.hashCode
        (53 * table_hash + 31 * index_hash)

## ---
   private: true
   ---
Comparable.from (that:Row) = Comparable.new that Row_Comparator
