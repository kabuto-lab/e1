private

from Standard.Base import all

import project.Column.Column
import project.In_Memory_Column.In_Memory_Column
import project.In_Memory_Table.In_Memory_Table
import project.Internal.Value_Type_Helpers
import project.Refined_Types.Date_Column.Date_Column
import project.Refined_Types.Numeric_Column.Numeric_Column
import project.Refined_Types.Text_Column.Text_Column
import project.Table.Table
import project.Value_Type.Value_Type
from project.Internal.Type_Refinements.Single_Column_Table_Conversions import all
from project.Internal.Type_Refinements.Single_Column_Typed_Table_Conversions import all

refine_table (table : Table & In_Memory_Table) =
    if table . column_count != 1 then (table : Table & In_Memory_Table) else
        column = (table:Table).at 0
        inferred_value_type = column.inferred_precise_value_type
        case inferred_value_type of
            Value_Type.Integer _ -> _refine_numeric_column table column
            Value_Type.Byte -> _refine_numeric_column table column
            Value_Type.Float _ -> _refine_numeric_column table column
            Value_Type.Decimal _ _ -> _refine_numeric_column table column
            Value_Type.Char _ _ -> _refine_text_column table column
            Value_Type.Date -> _refine_date_column table column
            _ -> _refine_other_column table column

private _refine_numeric_column (table : In_Memory_Table) (column : Column & In_Memory_Column) -> Table & In_Memory_Table & Column & In_Memory_Column & Numeric_Column = case column.row_count of
    1 -> case column.at 0 of
        _ : Integer -> table : Table & In_Memory_Table & Column & In_Memory_Column & Numeric_Column & Integer
        _ : Float -> table : Table & In_Memory_Table & Column & In_Memory_Column & Numeric_Column & Float
        _ : Decimal -> table : Table & In_Memory_Table & Column & In_Memory_Column & Numeric_Column & Decimal
        _ -> table : Table & In_Memory_Table & Column & In_Memory_Column & Numeric_Column
    _ -> table : Table & In_Memory_Table & Column & In_Memory_Column & Numeric_Column

private _refine_text_column (table : In_Memory_Table) (column : Column & In_Memory_Column) -> Table & In_Memory_Table & Column & In_Memory_Column & Text_Column = case column.row_count of
    1 -> case column.at 0 of
        _ : Text -> table : Table & In_Memory_Table & Column & In_Memory_Column & Text_Column & Text
        _ -> table : Table & In_Memory_Table & Column & In_Memory_Column & Text_Column
    _ -> table : Table & In_Memory_Table & Column & In_Memory_Column & Text_Column

private _refine_date_column (table : In_Memory_Table) (column : Column & In_Memory_Column) -> Table & In_Memory_Table & Column & In_Memory_Column & Date_Column = case column.row_count of
    1 -> case column.at 0 of
        _ : Date -> table : Table & In_Memory_Table & Column & In_Memory_Column & Date_Column & Date
        _ -> table : Table & In_Memory_Table & Column & In_Memory_Column & Date_Column
    _ -> table : Table & In_Memory_Table & Column & In_Memory_Column & Date_Column

private _refine_other_column (table : In_Memory_Table) (column : Column & In_Memory_Column) -> Table & In_Memory_Table & Column & In_Memory_Column =
    ## We treat a column as single value if it contains a single not-nothing value.
    first_value = if column.row_count == 1 then column.at 0 else Nothing
    case first_value of
        _ : Boolean -> (table : Table & In_Memory_Table & Column & In_Memory_Column & Boolean)
        _ : Date -> (table : Table & In_Memory_Table & Column & In_Memory_Column & Date)
        _ : Time_Of_Day -> (table : Table & In_Memory_Table & Column & In_Memory_Column & Time_Of_Day)
        _ : Date_Time -> (table : Table & In_Memory_Table & Column & In_Memory_Column & Date_Time)
        # Other types are not supported.
        _ -> (table : Table & In_Memory_Table & Column & In_Memory_Column)
