private

## Conversions that are used for type refinements.
   They should never be exported or used elsewhere.

from Standard.Base import all

import project.Column.Column
import project.In_Memory_Column.In_Memory_Column

## This conversion is internal and should never be exported.
Integer.from that:In_Memory_Column -> Integer =
    Runtime.assert (is_single_value that)
    x = (that:Column).at 0
    case x of
        _ : Integer -> x
        _ : Float ->
            Runtime.assert (x % 1.0 == 0.0)
            x.truncate

## This conversion is internal and should never be exported.
Float.from that:In_Memory_Column -> Float =
    Runtime.assert (is_single_value that)
    (that:Column).at 0

## This conversion is internal and should never be exported.
Text.from that:In_Memory_Column -> Text =
    Runtime.assert (is_single_value that)
    (that:Column).at 0

## This conversion is internal and should never be exported.
Boolean.from that:In_Memory_Column -> Boolean =
    Runtime.assert (is_single_value that)
    (that:Column).at 0

## This conversion is internal and should never be exported.
Date.from that:In_Memory_Column -> Date =
    Runtime.assert (is_single_value that)
    (that:Column).at 0

## This conversion is internal and should never be exported.
Time_Of_Day.from that:In_Memory_Column -> Time_Of_Day =
    Runtime.assert (is_single_value that)
    (that:Column).at 0

## This conversion is internal and should never be exported.
Date_Time.from that:In_Memory_Column -> Date_Time =
    Runtime.assert (is_single_value that)
    (that:Column).at 0

## This conversion is internal and should never be exported.
Decimal.from that:In_Memory_Column -> Decimal =
    Runtime.assert (is_single_value that)
    (that:Column).at 0

private is_single_value that:Column =
    that.row_count == 1
