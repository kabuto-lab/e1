from Standard.Base import all

## Specifies a method for grouping rows in `add_group_number`.
type Grouping_Method
    ## Group rows by the specified columns.

       ## Arguments
        - `on`: Rows that have the same values for these columns will be grouped
          together. At least one column must be specified.
    Unique (on:(Vector | Text | Integer | Regex)=(Missing_Argument.throw "on"))

    ## Create the specified number of groups with the same number of rows in each
       group (except possibly the last one).

       ## Arguments
       - `group_count`: The number of groups to divide the table into.
       - `order_by`: (Optional.) Specifies the order in which rows should be
         assigned to groups. Only affects the assignment of group numbers, not
         the ordering of the output rows. Defaults to the order of the rows in
         the table.
    Equal_Count (group_count:Integer=5) (order_by:(Vector | Text)=[])

    ## Create the specified number of groups such that the sum of the values in
       the specified column is approximately equal for each group.
       For k groups and a column whose values sum to N, each group will be at
       least (N/k), except possibly the last one.
       In some cases (if the group subtotals are roughly the size of individual
       values), fewer groups will be created than requested. In this case, a
       warning will be attached.
       ## Arguments
       - `on`: The column whose values should be summed to determine group
         assignment. Must be a numeric column.
       - `group_count`: The number of groups to divide the table into.
       - `order_by`: (Optional.) Specifies the order in which rows should be
         assigned to groups. Only affects the assignment of group numbers, not
         the ordering of the output rows. Defaults to the order of the rows in
         the table.
    Equal_Sum (on:(Text | Integer)=(Missing_Argument.throw "on")) (group_count:Integer=5) (order_by:(Vector | Text)=[])

    ## Group elements by standard deviation.from

       This method takes the standard deviation of the entire column, and then
       groups each element by how much its difference from the mean compares to
       the standard deviation. The set of groups is scaled just enough to
       contain the values that differ the most from the standard deviation.

       ## Arguments
       - `on`: The column whose values should be summed to determine group
         assignment. Must be a numeric column.
       - `population`: Whether to compute the population standard deviation (True)
         or the sample standard deviation (False). Defaults to False.
    Standard_Deviation (on:(Text | Integer)=(Missing_Argument.throw "on")) (population:Boolean=False)

## Specifies the row representing a group.
type Group_Row
    ## The row representing the group is the first row of the group.
    First

    ## The row representing the group is the previous row of the group.
    Previous

## Specify what the predicate is computed over.
type Predicate_Over
    ## The predicate is computed over a Row object.
    Row

    ## The predicate is computed over a column value specified by name.
    Name column:Text

    ## The predicate is computed over a column value specified by index.
    Index index:Integer

## ---
   private: true
   ---
Predicate_Over.from (that:Text) = Predicate_Over.Name that

## ---
   private: true
   ---
Predicate_Over.from (that:Integer) = Predicate_Over.Index that
