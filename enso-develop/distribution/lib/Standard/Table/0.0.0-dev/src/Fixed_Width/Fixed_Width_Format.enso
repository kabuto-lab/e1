polyglot java import org.enso.table.read.FixedWidthReader.Justification

## Read fixed-width files into a Table.
   A fixed-width format defines its columns as fixed column offsets and widths.
   The columns are defined in a `Fixed_Width_Layout` object.
type Fixed_Width_Format
    ## Read fixed-width files into a Table.
       Fixed-width files require have a `Fixed_Width_Layout` that specifies the
       start and width of each column, along with an optional column name. This
       layout can be defined using the `Fixed_Width_Column_Description` type, or
       using a table.
       In a fixed-width file, it is usually the case that every character offset
       of the input data is part of one of the columns, without gaps between
       them. However, the `layout` defined by the `Fixed_Width_Format does not
       have to use every character of every line; it can specify only the columns
       that are needed.

       ## Arguments
        - `layout`: A `Fixed_Width_Layout` object that defines the start and
          width for each column, along with an optional column name.
        - `encoding`: The encoding to use when reading the file.
        - `skip_rows`: The number of rows to skip from the top of the file.
        - `row_limit`: The maximum number of rows to read from the file.
        - `on_invalid_rows`: Specifies how to handle rows that are not short
          enough to cover the columns specified in the layout.
        - line_endings: Sets the line ending style to use. Line endings
          are detected from file contents. Defaults to `Infer`.
        - `on_empty_field`: Specifies whether to convert an empty field to
          `Nothing` or the empty string.
        - `value_formatter`: formatter to parse text values into numbers, dates,
          times, etc. if `nothing` values are left as text.

       ## Examples
       ### Specify a column layout using `Fixed_Width_Column_Description`.

       ```
             descs = [Fixed_Width_Column_Description.Start_And_Width 0 4, Fixed_Width_Column_Description.Width 1]
             layout = Fixed_Width_Layout.from_descriptions descs

       ```

       ### Specify a column layout using a `Table`.

       ```
             table = Table.input [['x', [0, Nothing, Nothing, Nothing]], ['y', [4, 1, 3, 3]]]
             layout = table : Fixed_Width_Layout
       ```

       ## Errors
       If a line of the input data does not have enough characters to cover all
       of the columns specified in the `layout`, the result depends on the value
       of `on_invalid_rows`: `Drop_Invalid_Rows`: short lines are skipped.
       `Keep_Invalid_Rows`: short lines are added to the table. Columns that are
       missing entirely take on the empty string, and columns that are partially
       covered by the input data take on the partial value.
    @layout _make_fixed_width_layout_widget
    Fixed_Width (layout:(Infer_Layout | Fixed_Width_Layout | Vector | Table | Column)=Fixed_Width_Layout.missing_layout_argument) (encoding:Encoding=Encoding.ascii) (skip_rows:Integer=0) (row_limit:Rows_To_Read=..All_Rows) (on_invalid_rows:Invalid_Fixed_Width_Rows=..Keep_Invalid_Rows) (line_endings : Line_Ending_Style | Infer | Custom_Line_Ending | No_Line_Ending = Infer) (on_empty_field:On_Empty_Field=..As_Nothing) (value_formatter:Data_Formatter|Nothing=Data_Formatter.Value)

    ## ---
       private: true
       ---
       Resolve an unresolved constructor to the actual type.
    resolve : Function -> Fixed_Width_Format | Nothing
    resolve constructor =
        Panic.catch Type_Error (constructor:Fixed_Width_Format) _->Nothing

    ## ---
       private: true
       ---
       If the File_Format supports reading from the file, return a configured
       instance.
       We cannot infer the layout from the file metadata or contents.
    for_read : File_Format_Metadata -> Fixed_Width_Format | Nothing
    for_read file:File_Format_Metadata =
        _ = [file]
        Nothing

    ## ---
       private: true
       ---
       If this File_Format should be used for writing to that file, return a
       configured instance.
    for_file_write : Writable_File -> XML_Format | Nothing
    for_file_write file:Writable_File =
        _ = [file]
        Nothing

    ## ---
       private: true
       ---
    get_dropdown_options : Vector Option
    get_dropdown_options = [Option "Fixed_Width" "..Fixed_Width"]

    ## ---
       private: true
       ---
    get_name_patterns -> Vector File_Name_Pattern = []

    ## ---
       private: true
       advanced: true
       ---
       Implements the `File.read` for this `File_Format`
    read : File -> Problem_Behavior -> Any
    read self file on_problems:Problem_Behavior =
        result = Fixed_Width_Reader.read_file self file on_problems
        result.if_not_error <|
            Telemetry.log "File_Format.read" "Read file: format={}, output={}, row_count={}, column_count={}" ["Fixed_Width_Format", "Table", result.row_count, result.column_count]
            result

    ## ---
       private: true
       ---
       Implements decoding the format from a stream.
    read_stream : Input_Stream -> File_Format_Metadata -> Any
    read_stream self stream:Input_Stream (metadata : File_Format_Metadata = File_Format_Metadata.no_information) =
        _ = metadata
        Fixed_Width_Reader.read_stream self stream on_problems=..Report_Warning

## ---
   private: true
   ---
   Specifies a fixed-width column. A column can be specified as a start offset
   and a witdh, or by just a width, starting just after the previous column.
type Fixed_Width_Column_Description
    ## Specify a fixed-width column using a start and width, and an optional
       column name.

       ## Arguments
        - `name`: The name of the column; if `Nothing`, a default name is
          generated.
        - `start`: The first character offset of the column.
        - `width`: The width of the column, in characters.
    Start_And_Width (start:Integer) (width:Integer) (name : Text | Nothing = Nothing)

    ## Specify a fixed-width column using just a width, and an optional column
       name. The start column defaults to the character after the last character
       of the previous column, or 0 if this is the first column.

       ## Arguments
        - `name`: The name of the column; if `Nothing`, a default name is
          generated.
        - `width`: The width of the column, in characters.
    Width (width:Integer) (name : Text | Nothing = Nothing)

## ---
   private: true
   ---
   Specifies a fixed-width column as a start and a width.
type Fixed_Width_Layout_Entry
    ## ---
       private: true
       ---
    Value (start:Integer) (width:Integer) (name:Text)

## ---
   private: true
   ---
   Specifies a set of fixed-width columns.
type Fixed_Width_Layout
    ## ---
       private: true
       ---
    private Value (internal_entries : Vector Fixed_Width_Layout_Entry)

    ## Create a new `Fixed_Width_Layout` from a vector of column descriptions.
    from_descriptions (descs : Vector Fixed_Width_Column_Description) -> Fixed_Width_Layout =
        if descs.is_empty then
            Error.throw (Illegal_Argument.Error "A fixed-width layout must have at least one column.")

        starts = Vector.build builder->
            descs.fold 0 current_offset-> desc->
                if desc.width <= 0 then
                    Error.throw (Illegal_Argument.Error "A fixed-width layout column must have a width of 1 or more.")
                start = case desc of
                    Fixed_Width_Column_Description.Start_And_Width start _ _ ->
                        if desc.start < 0 then
                            Error.throw (Illegal_Argument.Error "A fixed-width layout column start cannot be negative.")
                        if start < current_offset then Error.throw (Illegal_Argument.Error "Entry "+desc.to_text+" must start at column "+current_offset.to_text+" or later") else
                            start
                    Fixed_Width_Column_Description.Width _ _ ->
                        current_offset
                builder.append start
                width = desc.width
                start + width

        namer = Column_Namer.new "Column"
        entries = starts.zip descs start-> desc->
            name = desc.name.if_nothing namer.next
            Fixed_Width_Layout_Entry.Value start desc.width name
        Fixed_Width_Layout.Value entries

    ## ---
       private: true
       ---
    entries self -> Vector = self.internal_entries

    ## ---
       private: true
       ---
    missing_layout_argument =
        Missing_Argument.throw "layout" "A fixed-width table layout can be a Column or Vector of field widths, or a Table with columns called 'start', 'width', and (optionally) 'name'."

    ## ---
       private: true
       ---
    to_js_object : JS_Object
    to_js_object self =
        JS_Object.from_pairs [["type", "Fixed_Width_Layout"], ["entries", self.entries]]

type Infer_Layout
    ## Infer the column layout from the first line, assuming left-justified
       column names.
       Assume that the column name is left-justified in the column. The column
       starts at the first character of the column name, and extends until the
       last character before the start of the next column, or until the last
       column of the line if there is no next column.
       There must be at least one space between each pair of columns, or they
       will be considered a single column.
       If `skip_rows` is also specified, the header line is the first line after
       the skipped lines.

       ## Examples
       ### The layout of a left-justified column header line

         File contents:

       ```
             one  two  three four five   six
             12345abcde234567bcdef3456789cdefg
             82345zbcde834567zcdef8456789zdefg

       ```
         Parsed as:

       ```
            |one  |two  |three |four |five   |six  |
            +-----+-----+------+-----+-------+-----+
            |12345|abcde|234567|bcdef|3456789|cdefg|
            |82345|zbcde|834567|zcdef|8456789|zdefg|
       ```
    Left

    ## Infer the column layout from the first line, assuming right-justified
       column names.
       Assume that the column name is right-justified in the column. The column
       ends at the last character of the column name, and starts at the first
       character after the end of the previous column, or at the first character
       of the line if there is no previous column.
       There must be at least one space between each pair of columns, or they
       will be considered a single column.
       If `skip_rows` is also specified, the header line is the first line after
       the skipped lines.

       ## Examples
       ### The layout of a right-justified column header line

         File contents:

       ```
               one  two three four   five  six
             12345abcde234567bcdef3456789cdefg
             82345zbcde834567zcdef8456789zdefg

       ```
         Parsed as:

       ```
            |  one|  two| three| four|   five|  six|
            +-----+-----+------+-----+-------+-----+
            |12345|abcde|234567|bcdef|3456789|cdefg|
            |82345|zbcde|834567|zcdef|8456789|zdefg|
       ```
    Right

    ## ---
       private: true
       ---
    to_java self -> Justification = case self of
        Infer_Layout.Left -> Justification.LEFT
        Infer_Layout.Right -> Justification.RIGHT

## ---
   private: true
   ---
Fixed_Width_Layout.from (that:Table) =
    columns = find_named_columns that [["names", Regex.compile "names?", False], ["starts", Regex.compile "starts?", False], ["widths", Regex.compile "widths?", True]]
    columns.if_not_error <|
        names_maybe = columns.at 0
        names = names_maybe.if_not_nothing names_maybe.to_vector
        starts_maybe = columns.at 1
        starts = starts_maybe.if_not_nothing starts_maybe.to_vector
        widths = columns.at 2 . to_vector
        descriptions = 0.up_to that.row_count . map i->
            name = names.if_not_nothing <| names.at i
            start = starts.if_not_nothing <| starts.at i
            width = widths.at i
            if start.is_nothing then Fixed_Width_Column_Description.Width width name else
                Fixed_Width_Column_Description.Start_And_Width start width name
        Fixed_Width_Layout.from_descriptions descriptions

## ---
   private: true
   ---
   Find named columns matching patterns. Returns matching columns (or nothings
   for unmatched, non-required columns). If any required column is not found, or
   its matcher matches more than one column, an error is thrown.
   Name matching is case-insensitive.
   On success, the matching columns (or unrequired column Nothings) are returned
   in the order specified by the specs.

   ## Arguments
    - `specs`: list of pairs of the form [Text, Regex, Boolean]. - 0: The
      canonical name for the column - 1: A column name matcher - 2: True if the
      column is required
private find_named_columns table:Table (specs : Vector Vector) -> Vector (Column | Nothing) ! Illegal_Argument =
    columns_or_nothings = specs.map spec->
        matcher = spec.at 1
        cols = table.columns_helper.select_columns matcher Case_Sensitivity.Insensitive True False Problem_Behavior.Ignore False
        if cols.length == 1 then cols.at 0 else Nothing
    # A non-required column is not considered missing
    missing = specs.zip columns_or_nothings . filter x->
        column_or_nothing = x.at 1
        required = x.at 0 . at 2
        (Nothing == column_or_nothing) && required
    if missing.is_empty then columns_or_nothings else
        Error.throw (Illegal_Argument.Error "A fixed-width column specification should have a 'widths' column, and optionally a 'starts' column and a 'names' column.")

## ---
   private: true
   ---
Fixed_Width_Layout.from (that:Column) =
    Fixed_Width_Layout.from that.to_vector

## ---
   private: true
   ---
Fixed_Width_Layout.from (that:Vector) =
    table =
        names = Column.from_vector "names" (Vector.new that.length (_->Nothing))
        starts = Column.from_vector "starts" (Vector.new that.length (_->Nothing))
        widths = Column.from_vector "widths" that
        Table.new [names, starts, widths]
    Fixed_Width_Layout.from table

## ---
   private: true
   ---
Fixed_Width_Layout.from (that : Function) =
    is_unapplied_table_input = (that.to_text.starts_with "Table.type.new") || (that.to_text.starts_with "Table.type.input")
    if is_unapplied_table_input then
        Error.throw (Illegal_Argument.Error "Table has not been populated. A fixed-width column specification must have columns called 'start', 'width', and (optionally) 'name'.")
    Panic.throw (Type_Error.Error Fixed_Width_Layout that "Expected to get a Fixed_Width_Layout or a Table describing it.")

## ---
   private: true
   ---
_make_fixed_width_layout_widget display:Display=..When_Modified -> Widget =
    prepopulated_table = "Table.input [['names', ['column a']], ['starts', ['0']], ['widths', ['10']]]"
    make_single_choice [["Infer (left justified)", "..Left"], ["Infer (right justified)", "..Right"], ["Table", prepopulated_table ]] display=display
