from Standard.Base import all
import Standard.Base.Errors.Common.Type_Error
from Standard.Base.Metadata import Widget

import project.Column as Column_Module
import project.Column.Column
import project.Internal.Expression_Statics as Expression_Statics_Module
import project.Internal.Expression_Statics.Expression_Statics
import project.Refined_Types.Date_Column as Date_Column_Module
import project.Refined_Types.Date_Column.Date_Column
import project.Refined_Types.Numeric_Column as Numeric_Column_Module
import project.Refined_Types.Numeric_Column.Numeric_Column
import project.Refined_Types.Spatial_Column as Spatial_Column_Module
import project.Refined_Types.Spatial_Column.Spatial_Column
import project.Refined_Types.Spatial_Column.Spatial_Input_Column
import project.Refined_Types.Text_Column as Text_Column_Module
import project.Refined_Types.Text_Column.Text_Column
import project.Spatial_Table.Spatial_Table
import project.Table.Table

polyglot java import java.lang.IllegalArgumentException
polyglot java import java.lang.UnsupportedOperationException
polyglot java import org.enso.table.expressions.ExpressionVisitorImpl
polyglot java import org.enso.table.expressions.ExpressionVisitorImpl.MethodResolver
polyglot java import org.enso.table.expressions.ExpressionVisitorImpl.SyntaxErrorException
polyglot java import org.enso.table.expressions.ExpressionVisitorImpl.TypeErrorException

## ---
   icon: column_add
   ---
   Create an expression from a Text value.

   ## Arguments
    - `expression`: the expression to create
@expression Widget.Text_Input syntax="enso-table-expression"
expr : Text -> Expression
expr expression:Text -> Expression = Expression.Value expression

## ---
   private: true
   ---
   Functions for parsing and handling Enso expressions.
type Expression
    ## Creates an expression from a Text value.
    Value expression:Text

    ## ---
       private: true
       advanced: true
       ---
       Evaluates an expression against a table and returns the result

       ## Arguments
        - `expression`: the expression to evaluate
        - `table`: the table to evaluate it against
    evaluate expression:Expression table:Table =
        ## Define callbacks for the java code
        _get_column name = table.at name
        _make_constant_column value = case value of
            _ : Column -> value
            _ -> table.make_constant_column value
        _is_column value = value.is_a Column

        ## Helper for the expression to tell it which functions needs a Vector
        var_args_functions = ['is_in', 'coalesce', 'min', 'max']

        ## Define method resolvers for map functions
        map_functions = ['uuid', 'rand']
        column_map = fn-> table.at 0 . map skip_nothing=False fn

        ## Define which enso types we will look in to resolve methods in the expression
        mr1 = ExpressionVisitorImpl.newMethodResolver Expression_Statics_Module Expression_Statics isStaticMethod=True makeTypedColumn=Nothing
        mr2 = ExpressionVisitorImpl.newMethodResolver Column_Module Column isStaticMethod=False makeTypedColumn=c->c
        mr3 = ExpressionVisitorImpl.newMethodResolver Numeric_Column_Module Numeric_Column isStaticMethod=False makeTypedColumn=c->(c : Numeric_Column)
        mr4 = ExpressionVisitorImpl.newMethodResolver Text_Column_Module Text_Column isStaticMethod=False makeTypedColumn=c->(c : Text_Column)
        mr5 = ExpressionVisitorImpl.newMethodResolver Date_Column_Module Date_Column isStaticMethod=False makeTypedColumn=c->(c : Date_Column)
        mr6 = ExpressionVisitorImpl.newMethodResolver Spatial_Column_Module Spatial_Column isStaticMethod=False makeTypedColumn=c-> (table : Spatial_Table).as_spatial_column c
        mr7 = ExpressionVisitorImpl.newMethodResolver Spatial_Column_Module Spatial_Input_Column isStaticMethod=False makeTypedColumn=c-> Spatial_Input_Column.Value c table
        method_resolvers = [mr1, mr2, mr3, mr4, mr5, mr6, mr7]

        ## Define error handlers to convert java exceptions to Enso errors
        handle_parse_error = Panic.catch SyntaxErrorException handler=(cause-> Error.throw (Expression_Error.Syntax_Error cause.payload.getMessage cause.payload.getLine cause.payload.getColumn))
        handle_unsupported = handle_java_error UnsupportedOperationException Expression_Error.Unsupported_Operation
        handle_arguments = handle_java_error IllegalArgumentException Expression_Error.Argument_Mismatch
        handle_type_error = Panic.catch TypeErrorException handler=(cause-> Error.throw (Expression_Error.Type_Error cause.payload.getMessage))

        handle_parse_error <| handle_unsupported <| handle_arguments <| handle_type_error <|
            ExpressionVisitorImpl.evaluate expression.expression _get_column _make_constant_column _is_column method_resolvers var_args_functions map_functions column_map

type Expression_Error
    ## ---
       private: true
       ---
       The expression supplied could not be parsed due to a syntax error.
    Syntax_Error message:Text line:Integer column:Integer

    ## ---
       private: true
       ---
       Expression error when a function could not be found on the target type.
    Unsupported_Operation name:Text

    ## ---
       private: true
       ---
       Expression error when the number of arguments for a function is incorrect.
    Argument_Mismatch message:Text

    ## ---
       private: true
       ---
       Expression error when the type of arguments for a function is incorrect.
    Type_Error message:Text

    ## ---
       private: true
       ---
       Create a human-readable version of the error.
    to_display_text : Text
    to_display_text self = case self of
        Expression_Error.Syntax_Error _ _ _ -> "Expression.Syntax_Error: " + self.message + " (line " + self.line.to_text + ", column " + self.column.to_text + ")."
        Expression_Error.Unsupported_Operation _ -> "Expression.Unsupported: " + self.name + " is not a supported method."
        Expression_Error.Argument_Mismatch _ -> "Expression.Argument_Mismatch: " + self.message
        Expression_Error.Type_Error _ -> "Expression.Type_Error: " + self.message

## ---
   private: true
   ---
handle_java_error java_type enso_constructor =
    Panic.catch java_type handler=(cause-> Error.throw (enso_constructor cause.payload.getMessage))
