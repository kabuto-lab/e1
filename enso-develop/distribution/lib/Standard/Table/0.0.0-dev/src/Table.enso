    @max_rows Rows_To_Read.default_widget
    rows self max_rows:Rows_To_Read=..All_Rows -> Vector Row =
        self.implementation.rows self.underlying max_rows

    ## ---
       group: Standard.Base.Selections
       icon: select_row
       ---
       Returns the first row of the table.
       In the database backend, it first materializes the table to in-memory.
    first_row self -> Row ! Index_Out_Of_Bounds =
        self.implementation.first_row self.underlying

    ## ---
       group: Standard.Base.Selections
       icon: select_row
       ---
       Returns the last row of the table.
