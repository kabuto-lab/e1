from Standard.Base import all
import Standard.Base.Data.Array_Proxy.Array_Proxy
from Standard.Base.Enso_Cloud.Enso_Secret import as_hideable_value
from Standard.Base.Metadata import Display, make_single_choice, Widget
from Standard.Base.Metadata.Choice import Option
from Standard.Base.Metadata.Widget import Single_Choice, Text_Input, Vector_Editor

import project.Azure_Environment.Azure_Environment
from project.Internal.Azure_Helpers import handle_azure_exceptions

polyglot java import org.enso.base.enso_cloud.HideableValue
polyglot java import org.enso.microsoft.azure.AzureCredential
polyglot java import org.enso.microsoft.azure.AzureResourceManager

## Represents an Azure credential.
type Azure_Credential
    ## Read from the Default Azure credential provider.
    Default

    ## Read the credential from environment variables.
       The required variables are:
       - `AZURE_TENANT_ID`
       - `AZURE_CLIENT_ID`
       - `AZURE_CLIENT_SECRET`
    Environment

    ## Read the credential from the Azure CLI.
    CLI

    ## Read the credential from inputs or Enso Secrets
    Client_Secret (tenant_id : (Text|Enso_Secret) = (Missing_Argument.throw "tenant_id")) (client_id : (Text|Enso_Secret) = (Missing_Argument.throw "client_id")) (client_secret : (Text|Enso_Secret) = (Missing_Argument.throw "client_secret"))

    ## Test method to list accounts from Azure credential
    subscriptions self environment:Azure_Environment=..Default -> Vector Azure_Subscription = handle_azure_exceptions <|
        java_cred = self.to_java
        java_env = environment.to_java
        as_array = AzureResourceManager.subscriptions java_cred java_env
        proxy = Array_Proxy.new as_array.length i-> Azure_Subscription.Value (as_array.get i)
        Vector.from_polyglot_array proxy

    ## Test method to list accounts from Azure credential
    tenants self environment:Azure_Environment=..Default -> Vector Azure_Tenant = handle_azure_exceptions <|
        java_cred = self.to_java
        java_env = environment.to_java
        as_array = AzureResourceManager.tenants java_cred java_env
        proxy = Array_Proxy.new as_array.length i-> Azure_Tenant.Value (as_array.get i)
        Vector.from_polyglot_array proxy

    ## ---
       private: true
       ---
       Converts the Azure_Credential into the Java SDK object
    private to_java self = case self of
        Azure_Credential.Default -> AzureCredential.Default.new
        Azure_Credential.Environment -> AzureCredential.Environment.new
        Azure_Credential.CLI -> AzureCredential.CLI.new
        Azure_Credential.Client_Secret tenant_id client_id client_secret ->
            AzureCredential.ClientSecret.new (as_hideable_value tenant_id factory=HideableValue) (as_hideable_value client_id factory=HideableValue) (as_hideable_value client_secret factory=HideableValue)

## Represents an Azure tenant
type Azure_Tenant
    ## An Azure tenant with associated ID.
    Value id

    ## ---
       private: true
       ---
    to_display_text self -> Text = "Azure Tenant {" + self.id + "}"

## Represents an Azure subscription
type Azure_Subscription
    private Value java_object

    ## The subscription ID.
    id self -> Text = self.java_object.id

    ## The subscription name.
    name self -> Text = self.java_object.name

    ## ---
       private: true
       ---
    to_text self -> Text = self.name + " (" + self.id + ")"

    ## ---
       private: true
       ---
    to_display_text self -> Text = "Azure Sub {" + self.name + " (" + self.id + ")}"

    ## ---
       private: true
       ---
    to_js_object self -> JS_Object =
        id = ["id", self.id]
        name = ["name", self.name]
        JS_Object.from_pairs [["type", "Azure_Subscription"], id, name]

Text.from (that:Azure_Subscription) -> Text = that.id

private make_subscription_selector self_arg cache display:Display=..When_Modified -> Widget  =
    _ = self_arg
    items = Panic.catch Any handler=_->[] <|
        credential = cache.if_not_nothing <| cache "cred"
        credential.if_not_nothing <|
            environment = (cache.if_not_nothing <| cache "environment").if_nothing Azure_Environment.Default
            subscriptions = credential.subscriptions environment
            subscriptions.map (sub-> Option sub.to_text sub.id.pretty)
    item_editor = make_single_choice ([Option "<Default>" "Nothing"] + items.if_nothing [])
    Vector_Editor item_editor=item_editor item_default=item_editor.values.first.value display=display
