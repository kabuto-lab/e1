from Standard.Base import all

import Standard.Database.Connection.Credentials.Credentials

type SQLServer_Credentials
    ## No credentials are passed to SQL Server (unlikely to allow a connection).
    None

    ## Username and password are passed to SQL Server.
    Username_And_Password
        username:(Text|Enso_Secret)=(Missing_Argument.throw "username")
        password:(Text|Enso_Secret)=(Missing_Argument.throw "password")

    ## Active Directory Default authentication.
    Active_Directory_Default

    ## Active Directory Integrated authentication
    Active_Directory_Integrated

    ## Active Directory Username and Password authentication.
    Active_Directory_Password
        username:(Text|Enso_Secret)=(Missing_Argument.throw "username")
        password:(Text|Enso_Secret)=(Missing_Argument.throw "password")

    ## Active Directory Service Principal authentication.
    Active_Directory_Service_Principal
        principal_id:(Text|Enso_Secret)=(Missing_Argument.throw "principal_id")
        principal_secret:(Text|Enso_Secret)=(Missing_Argument.throw "principal_secret")

    ## ---
       private: true
       ---
       Override `to_text` to mask the password field.
    to_text : Text
    to_text self = case self of
        SQLServer_Credentials.None -> 'SQLServer_Credentials <None>'
        SQLServer_Credentials.Username_And_Password _ _ -> 'SQLServer_Credentials ' + self.username + ' *****'
        SQLServer_Credentials.Active_Directory_Default -> 'SQLServer_Credentials <Active_Directory> <Default>'
        SQLServer_Credentials.Active_Directory_Integrated -> 'SQLServer_Credentials <Active_Directory>  <Integrated>'
        SQLServer_Credentials.Active_Directory_Password _ _ -> 'SQLServer_Credentials <ActiveDirectory> ' + self.username + ' *****'
        SQLServer_Credentials.Active_Directory_Service_Principal _ _ -> 'SQLServer_Credentials <ActiveDirectory> <ServicePrincipal> ' + self.principal_id + ' *****'

    ## ---
       private: true
       ---
    to_jdbc_properties : Vector Pair Text Text
    to_jdbc_properties self = case self of
        SQLServer_Credentials.None -> []
        SQLServer_Credentials.Username_And_Password _ _ -> [Pair.new 'user' self.username, Pair.new 'password' self.password]
        SQLServer_Credentials.Active_Directory_Default -> [Pair.new 'authentication' 'ActiveDirectoryDefault']
        SQLServer_Credentials.Active_Directory_Integrated -> [Pair.new 'authentication' 'ActiveDirectoryIntegrated']
        SQLServer_Credentials.Active_Directory_Password _ _ -> [Pair.new 'authentication' 'ActiveDirectoryPassword', Pair.new 'user' self.username, Pair.new 'password' self.password]
        SQLServer_Credentials.Active_Directory_Service_Principal _ _ -> [Pair.new 'authentication' 'ActiveDirectoryServicePrincipal', Pair.new 'username' self.principal_id, Pair.new 'password' self.principal_secret]

SQLServer_Credentials.from (that:Nothing) =
    _ = that
    SQLServer_Credentials.None

SQLServer_Credentials.from (that:Credentials) =
    SQLServer_Credentials.Username_And_Password that.username that.password
