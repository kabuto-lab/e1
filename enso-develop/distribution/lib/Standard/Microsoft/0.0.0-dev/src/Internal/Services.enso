private

import Standard.Base.Enso_Cloud.Data_Link.Data_Link_SPI
import Standard.Base.System.File.File_System_SPI

import Standard.Database.Connection.Database.Database_Connection_Details_SPI

import project.Connection.SQLServer_Details.SQLServer_Details
import project.OneDrive.OneDrive_File
import project.SQLServer_Data_Link.SQLServer_Data_Link

type Impl

Data_Link_SPI.from (that:Impl) =
    _ = that
    Data_Link_SPI.new SQLServer_Data_Link "SQLServer_Connection"

Database_Connection_Details_SPI.from (that:Impl) =
    _ = that
    Database_Connection_Details_SPI.new SQLServer_Details "Microsoft SQL Server" "..SQLServer"

File_System_SPI.from (that:Impl) =
    _ = that
    File_System_SPI.new "onedrive" OneDrive_File
