from Standard.Base import all

import Standard.Table.In_Memory_Table.In_Memory_Table
from Standard.Table import Column, Table

import Standard.Database.DB_Column.DB_Column
import Standard.Database.DB_Table.DB_Table

import project.Helpers
from project.Helpers import time_visualization

## ---
   private: true
   ---
   Gets the x column from a table.
   This is either the column named 'X' or the left most column.
x_column : Table -> Column
x_column table = if table.column_count==1 then Nothing else
    by_name = table.get 'X' (table.get 'x')
    if Nothing != by_name then by_name else
        c = table.at 0
        is_good = (c.value_type.is_numeric || c.value_type.is_date_or_time) && c.name != "Y" && c.name != "y"
        if is_good then c else Nothing

## ---
   private: true
   ---
json_from_table : Table -> Vector Integer | Nothing -> Integer | Nothing -> Text
json_from_table table bounds limit = if table.column_count==1 && table.column_names.first.equals_ignore_case "x" then json_from_table (table.rename_columns ["Value"] . add_row_number "Index" . reorder_columns ["Index","Value"]) bounds limit else
    ## Get the x column
    col_x = x_column table
    if Nothing == col_x then json_from_table (table.add_row_number "x") bounds limit else
        x_value_type = col_x.value_type

        ## Structure the table (X, Color?, Shape?, Label?, Size?, Row_Number, Data)
        col_color = table.select_columns [col_x.name, "color", "colour"] case_sensitivity=..Insensitive error_on_missing_columns=False on_problems=..Ignore . get 1
        col_row_number = table.select_columns [col_x.name, "row_number"] case_sensitivity=..Insensitive error_on_missing_columns=False on_problems=..Ignore . get 1
        base_table = table.select_columns [col_x.name, "shape", "label", "size"] case_sensitivity=..Insensitive error_on_missing_columns=False reorder=True on_problems=..Ignore
        with_color = if Nothing==col_color then base_table else base_table.set col_color "color"
        core_table = if Nothing==col_row_number then with_color.add_row_number "row_number" else with_color.set col_row_number

        ## Find the data columns
        data_columns = table.remove_columns core_table.column_names on_problems=..Ignore . columns . filter c-> c.value_type.is_numeric
        if data_columns.length == 0 then '{"data":[],"axis":{},"is_multi_series":false,"get_row_method":"get_row","x_value_type":"Integer","error_message":"At least one numeric (other than X) must be provided for a scatter plot."}' else
            merged_table = core_table.zip (Table.new data_columns)

            ## Bound Data
            bounded = if bounds.is_nothing then merged_table else
                x_filtered = merged_table.filter col_x (..Between (bounds.at 0) (bounds.at 1))
                if data_columns.length != 1 then x_filtered else
                    x_filtered.filter data_columns.first (..Between (bounds.at 2) (bounds.at 3))

            ## Limit the number of rows to be visualized.
            limited = if limit.is_nothing || bounded.row_count<=limit then bounded else
                bounded.take (..Sample limit seed=15975382)

            ## Create the JSON for the data rows
            field_names = ["x"] + (core_table.column_names.drop 1 . map c-> c.to_case ..Lower) + ["y"] + (1.up_to data_columns.length . map i-> "(y_multi " + (i-1).to_text + ")")
            name_map = merged_table.column_names.zip field_names
            filtered = name_map.take 1 + name_map.drop core_table.column_count
            axes_json = '{' + ((filtered.map p-> p.second.to_json + ':{"label":' + p.first.to_json + '}') . join ',') + '}'

            ## Create the data JSON
            data_json = "[" + (limited.rename_columns name_map . rows . map .to_json_data . join ',') + "]"

            ## Render structure
            '{"data":' + data_json + ',"axis":' + axes_json + ',"is_multi_series":' + (data_columns.length > 1).to_json + ',"get_row_method":"get_row","x_value_type":"' + x_value_type.to_name + '","error_message":null}'

## ---
   private: true
   ---
json_from_vector : Vector Any -> Vector Integer | Nothing -> Integer | Nothing -> Text
json_from_vector vec bounds limit =
    ## Bound Data
    bounded = if bounds.is_nothing then vec else
        x_min = bounds.at 0 . ceil
        x_max = bounds.at 1 . floor
        y_min = bounds.at 2
        y_max = bounds.at 3
        vec . take (x_min . up_to x_max True) . filter (y -> y>=y_min && y<=y_max)

    ## Bound Data
    limited = if limit.is_nothing || bounded.length<=limit then bounded else
        bounded.take (..Sample limit seed=15975382)

    ## Create JSON
    data_json = limited.map_with_index i-> elem-> '{"x":' + i.to_text + ',"y":' + elem.to_json + ',"row_number":' + i.to_text + '}'
    '{"data": [' + (data_json.join ',') + '],"axis":null,"is_multi_series":false,"get_row_method":"at","x_value_type":"Integer","error_message":null}'

## ---
   private: true
   ---
   Default preprocessor for the scatter-plot visualization.
   Generates JSON text describing the scatter-plot visualization.

   ## Arguments
    - `value`: the value to be visualized.
process_to_json_text : Any -> Integer | Nothing -> Integer | Nothing -> Text
process_to_json_text value bounds=Nothing limit=Nothing = time_visualization Scatter_Plot ("process_to_json_text: " + value.to_display_text) <|
    ## If limit is Nothing will use 15,000 for in database operations
    json = case value of
        _ : DB_Table -> json_from_table (value.read (..First (limit.if_nothing 15000))) bounds limit
        _ : DB_Column -> json_from_table (value.to_table.read (..First (limit.if_nothing 15000))) bounds limit
        _ : In_Memory_Table -> json_from_table value bounds limit
        _ : Column -> json_from_table value.to_table bounds limit
        _ : Vector -> json_from_vector value bounds limit
        _ : Array -> json_from_vector value bounds limit
        _ -> json_from_vector value.to_vector bounds limit
    json
