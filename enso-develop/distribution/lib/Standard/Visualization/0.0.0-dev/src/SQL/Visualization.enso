from Standard.Base import all

import Standard.Database.DB_Column.DB_Column
import Standard.Database.DB_Table.DB_Table

import project.Helpers
from project.Helpers import time_visualization

## ---
   private: true
   ---
   Prepares the database table for visualization.

   For each interpolation it provides its value, its actual type name, its
   expected SQL type name and if it was possible to infer it, its expected Enso
   typename.
   Expected Enso types are inferred based on known SQL types and their mapping to
   Enso types.

   ## Arguments
    - `table`: The database table to prepare for visualization.
prepare_visualization : DB_Table -> Text
prepare_visualization table = time_visualization Visualization ("prepare_visualization: " + table.to_display_text) <|
    prepared = (table:DB_Table|DB_Column).to_sql.prepare
    code = prepared.first.replace (regex "::variant, \{'enso-null-replacement-marker'.*?\}::variant") ", NULL"
    interpolations = prepared.second
    mapped = interpolations.map value->
        enso_type = value.to Meta.Type . qualified_name
        used_value = case value of
            _ : Date -> value.to_text
            _ : Time_Of_Day -> value.to_text
            _ : Date_Time -> value.to_text
            _ -> value
        JS_Object.from_pairs [["value", used_value], ["enso_type", enso_type]]
    dialect = (table:DB_Table|DB_Column).dialect_name
    JS_Object.from_pairs [["dialect", dialect], ["code", code], ["interpolations", mapped]] . to_text
