{
  "name": "enso-common",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./src/*": {
      "source": "./src/*.ts",
      "types": "./src/*.ts",
      "import": "./dist/*.js"
    }
  },
  "main": "src/index.ts",
  "scripts": {
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "compile": "tsc",
    "lint": "eslint ./src --cache --max-warnings=0"
  },
  "dependencies": {
    "@internationalized/date": "3.7.0",
    "@types/node": "catalog:",
    "is-network-error": "^1.1.0",
    "vue": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@fast-check/vitest": "catalog:",
    "vitest": "catalog:"
  }
}
