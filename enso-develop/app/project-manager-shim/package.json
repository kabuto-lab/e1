{
  "name": "project-manager-shim",
  "version": "0.1.0",
  "description": "Shared operations and types for project manager shim",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fs": {
      "source": "./src/fs.ts",
      "types": "./dist/fs.d.ts",
      "import": "./dist/fs.js"
    },
    "./handler": {
      "source": "./src/handler/index.ts",
      "types": "./dist/handler/index.d.ts",
      "import": "./dist/handler/index.js"
    },
    "./projectService": {
      "source": "./src/projectService/index.ts",
      "types": "./dist/projectService/index.d.ts",
      "import": "./dist/projectService/index.js"
    }
  },
  "main": "src/index.ts",
  "scripts": {
    "test:unit": "vitest run",
    "compile": "tsc",
    "lint": "eslint . --cache --max-warnings=0",
    "download-engine": "node scripts/download-engine.js"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/tar": "^6.1.13",
    "extract-zip": "^2.0.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "enso-common": "workspace:*",
    "portfinder": "^1.0.32",
    "tar": "^6.2.1",
    "trash": "^9.0.0",
    "yaml": "^2.7.0"
  }
}
