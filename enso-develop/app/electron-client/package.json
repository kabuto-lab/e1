    "create-servers": "3.2.0",
    "electron-dl": "4.0.0",
    "electron-is-dev": "^2.0.0",
    "enso-common": "workspace:*",
    "gunzip-maybe": "^1.4.2",
    "mime-types": "^2.1.35",
    "mkcert": "3.2.0",
    "opener": "^1.5.2",
    "project-manager-shim": "workspace:*",
    "semver": "^7.6.3",
    "tar-fs": "^3.0.9",
    "tar-stream": "^3.1.7",
    "vitest": "catalog:",
    "yargs": "17.6.2",
    "yauzl": "^3.2.0",
    "ydoc-server": "workspace:*",
    "zip-stream": "^7.0.2"
  },
  "devDependencies": {
    "@electron/notarize": "2.1.0",
    "@types/gunzip-maybe": "^1.4.2",
    "@types/mime-types": "^2.1.4",
    "@types/node": "catalog:",
    "@types/opener": "^1.4.3",
    "@types/semver": "^7.5.8",
    "@types/tar": "^6.1.13",
    "@types/tar-fs": "^2.0.4",
    "@types/tar-stream": "^3.1.4",
    "@types/yargs": "^17.0.33",
    "@types/yauzl": "^2.10.3",
    "@types/zip-stream": "^7.0.0",
    "cross-env": "^7.0.3",
    "electron": "37.2.1",
    "electron-builder": "^24.13.3",
    "enso-common": "workspace:*",
    "enso-gui": "workspace:*",
