  "//": [
    "vite is required for the watch script"
  ],
  "scripts": {
    "typecheck": "tsc --build",
    "build": "vite-node bundle.ts",
    "dist": "vite-node dist.ts",
    "lint": "eslint . --cache --max-warnings=0",
    "ide-integration-test": "playwright test",
    "watch:windows": "cross-env ENSO_IDE_VERSION=0.0.0-dev ENSO_IDE_COMMIT_HASH=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa ENSO_BUILD_IDE=%LOCALAPPDATA%\\Temp\\enso\\dist\\ide ENSO_BUILD_BACKEND=%CD%\\..\\..\\dist\\backend ENSO_BUILD_IDE_BUNDLED_ENGINE_VERSION=0 ENSO_POLYGLOT_YDOC_SERVER=wss://localhost:8080 vite-node watch.ts",
    "watch:linux": "ENSO_IDE_VERSION=\"${ENSO_IDE_VERSION:-0.0.0-dev}\" ENSO_IDE_COMMIT_HASH=\"${ENSO_IDE_COMMIT_HASH:-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa}\" ENSO_BUILD_IDE=\"${ENSO_BUILD_IDE:-/tmp/enso/dist/ide}\" ENSO_BUILD_BACKEND=\"${ENSO_BUILD_BACKEND:-\"$(pwd)/../../dist/backend\"}\" ENSO_BUILD_IDE_BUNDLED_ENGINE_VERSION=\"${ENSO_BUILD_IDE_BUNDLED_ENGINE_VERSION:-0}\" ENSO_POLYGLOT_YDOC_SERVER=\"${ENSO_POLYGLOT_YDOC_SERVER:-wss://localhost:8080}\" vite-node watch.ts \"$@\"",
    "watch:macos": "ENSO_IDE_VERSION=\"${ENSO_IDE_VERSION:-0.0.0-dev}\" ENSO_IDE_COMMIT_HASH=\"${ENSO_IDE_COMMIT_HASH:-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa}\" ENSO_BUILD_IDE=\"${ENSO_BUILD_IDE:-/tmp/enso/dist/ide}\" ENSO_BUILD_BACKEND=\"${ENSO_BUILD_BACKEND:-\"$(pwd)/../../dist/backend\"}\" ENSO_BUILD_IDE_BUNDLED_ENGINE_VERSION=\"${ENSO_BUILD_IDE_BUNDLED_ENGINE_VERSION:-0}\" ENSO_POLYGLOT_YDOC_SERVER=\"${ENSO_POLYGLOT_YDOC_SERVER:-wss://localhost:8080}\" vite-node watch.ts \"$@\""
  }
}
