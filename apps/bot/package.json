{
  "name": "@escort/bot",
  "version": "0.0.1",
  "private": true,
  "description": "Lovnge Telegram bot — обслуживает /start link_<token> для web-first линковки (§Q2)",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check-types": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "grammy": "^1.30.0",
    "dotenv": "^16.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  },
  "jest": {
    "rootDir": "src",
    "testEnvironment": "node",
    "moduleFileExtensions": ["ts", "js", "json"],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }]
    }
  },
  "engines": {
    "node": ">=22"
  }
}
