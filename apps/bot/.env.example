# Telegram bot токен от @BotFather
BOT_TOKEN=

# URL NestJS API (dev: http://127.0.0.1:3000, prod: https://api.lovnge.com)
API_URL=http://127.0.0.1:3000

# Shared secret между ботом и API — ДОЛЖЕН совпадать с TELEGRAM_BOT_SECRET в корневом .env
BOT_SECRET=

# Опционально: URL веб-приложения для ссылок из сообщений бота ("иди в ЛК: https://…/cabinet").
# SITE_URL=https://lovnge.com

# Дефолтный язык сообщений (ru|en). Опционально.
DEFAULT_LOCALE=ru

# Режим доставки апдейтов: polling (dev) | webhook (prod/VPS).
# В webhook-режиме Telegram шлёт POST на BOT_WEBHOOK_URL, бот слушает на BOT_PORT.
# secret_token = BOT_SECRET (тот же, что API проверяет в x-bot-secret).
BOT_MODE=polling
# Обязателен при BOT_MODE=webhook. HTTPS URL, публично достижим Telegram'ом.
# Nginx на VPS: proxy_pass http://127.0.0.1:3002; на /bot/webhook.
# BOT_WEBHOOK_URL=https://api.lovnge.com/bot/webhook
# Локальный порт HTTP-сервера бота (webhook-режим). Default 3002.
# BOT_PORT=3002
