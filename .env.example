# Скопируй в .env и заполни секреты. Файл .env в git не попадает (.gitignore).
# На сервере те же переменные правь только в ~/e1/.env вручную или через секреты хостинга.

# ============================================
# DATABASE (PostgreSQL 16) — см. docker-compose.dev.yml
#
# ОБЯЗАТЕЛЬНО: POSTGRES_PASSWORD = тот же пароль, что в DATABASE_URL (после postgres: в URL).
# Docker подставляет POSTGRES_PASSWORD при первом создании тома; URL — чем пользуется API.
# Расхождение → password authentication failed, пока ensure:database не сделает ALTER.
#
# VPS: пароль в DATABASE_URL должен совпадать с паролем роли в уже существующей БД.
# Смена только одного из двух без ALTER / нового тома оставляет БД со старым паролем.
# После правки .env: npm run pm2:reload-api (startOrReload), не «pm2 restart» без перезагрузки ecosystem.
#
# После git pull на VPS из корня репозитория: npm run vps:after-pull
# (сборка + ensure:database: при ошибке пароля и Docker-контейнере escort-postgres пароль выровняется под .env).
# Другой контейнер: POSTGRES_CONTAINER=имя_контейнера
#
# Пустой каталог /models на новом сервере: один раз из корня репозитория (DATABASE_URL в .env):
#   npm run db:bootstrap
# ============================================
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/companion_db

# ============================================
# REDIS (sessions/cache)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# MinIO / S3 (file storage)
# ============================================
MINIO_ENDPOINT=localhost:9000
MINIO_PRESIGN_ENDPOINT=localhost:9000
# Прод: публичный host:port для presigned URL, например 45.9.40.37:9000
MINIO_ACCESS_KEY=companion_minio_admin
MINIO_SECRET_KEY=companion_minio_password
MINIO_BUCKET=escort-media

# For presigned URLs (public access) — API при генерации cdnUrl (должен быть достижен из браузера на VPS)
MINIO_PUBLIC_URL=http://localhost:9000

# Next.js (браузер): переписывает старые ссылки в БД с localhost:9000 на публичный MinIO. Задайте на VPS = MINIO_PUBLIC_URL.
NEXT_PUBLIC_MINIO_PUBLIC_URL=http://localhost:9000

# ============================================
# Auth (JWT) — JWT_SECRET: ровно 64 hex (openssl rand -hex 32)
# ============================================
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_REFRESH_SECRET=fedcba9876543210fedcba9876543210fedcba9876543210fedcba9876543210
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Clerk (optional - if using)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ============================================
# Encryption (32 bytes hex)
# ============================================
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================
# API Server (NestJS)
# ============================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ============================================
# Web Server (Next.js)
# Локально NEXT_PUBLIC_API_URL лучше не задавать — прокси /api в next.config.
# ============================================
# NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ============================================
# Admin Dashboard
# ============================================
# create-admin.ts сейчас хардкодит admin@lovnge.local/Admin123!; переменные ниже не читаются
# кодом и вызывают warning у docker-compose из-за $ в bcrypt-формате. Оставлены закомментированными
# до появления скрипта, который реально их потребляет.
# ADMIN_EMAIL=admin@lovnge.com
# ADMIN_PASSWORD_HASH=$2b$10$YourHashedPasswordHere

# ============================================
# Форма «Контакты» (SMTP)
# Письма уходят на CONTACT_FORM_TO_EMAIL (по умолчанию в коде: index.g0@gmail.com).
#
# --- Вариант A: Mailhog (локальная проверка, письма не в интернет) ---
#   docker compose -f docker-compose.dev.yml up -d mailhog
#   Веб-интерфейс: http://localhost:8025
#   API на хосте (не в Docker): SMTP_HOST=127.0.0.1
#   API в той же docker-сети:    SMTP_HOST=mailhog (если добавите сервис api в compose)
#
# --- Вариант B: Gmail (реальная доставка на index.g0@gmail.com) ---
#   В Google-аккаунте включите 2FA → «Пароли приложений» → сгенерируйте 16 символов.
#   SMTP_USER = тот же Gmail, с которого шлёте. SMTP_FROM лучше совпадать с ним.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#   SMTP_FROM=you@gmail.com
#   CONTACT_FORM_TO_EMAIL=index.g0@gmail.com
#
# Если «отправлено» в UI, но в Gmail пусто — смотрите спам и Mailhog (вариант A).
# ============================================
CONTACT_FORM_TO_EMAIL=index.g0@gmail.com
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@lovnge.local
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# ============================================
# TON USDT escrow (опционально; для POST /escrow/ton/intent)
# ============================================
# TON_NETWORK=ton_testnet
# TON_USDT_JETTON_MASTER=EQ... или -1:hex...
# TON_TREASURY_ADDRESS=UQ... или -1:hex...
# Секрет для POST /escrow/ton/deposit (заголовок x-ton-escrow-ingest), openssl rand -hex 24
# TON_ESCROW_INGEST_SECRET=
#
# Фоновый индексер TonAPI (GET /v2/accounts/{treasury}/events → JettonTransfer + memo)
# TON_INDEXER_ENABLED=true
# TON_INDEXER_POLL_MS=60000
# TON_INDEXER_EVENTS_LIMIT=50
# TONAPI_BASE_URL=https://tonapi.io
# TONAPI_KEY=
# Опционально начальный after_lt без bootstrap по последним N событиям:
# TON_INDEXER_BOOTSTRAP_AFTER_LT=0
#
# Hot wallet (POST …/broadcast-release|refund): WalletContractV4 workchain 0 = TON_TREASURY_ADDRESS
# TON_HOT_WALLET_MNEMONIC=word1 word2 ... word24
# TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
# TON_RPC_API_KEY=
# TON_JETTON_GAS_NANOTONS=150000000
# TON_JETTON_FORWARD_NANOTONS=50000000

# ============================================
# Telegram (web-first linking flow)
# TELEGRAM_BOT_USERNAME — имя бота без @, для deep-link t.me/<name>?start=link_<token>.
# TELEGRAM_LINK_TOKEN_TTL_SEC — дефолт 300 (5 минут).
# TELEGRAM_BOT_SECRET — shared secret (≥24 символа, openssl rand -hex 24) для
#   POST /auth/telegram/consume и /auth/telegram/login. Пока бота нет — этим
#   секретом можно тестировать линковку через Swagger.
# ============================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=lovnge_dev_bot
# TELEGRAM_LINK_TOKEN_TTL_SEC=300
# TELEGRAM_BOT_SECRET=
