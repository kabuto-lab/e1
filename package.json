{
  "name": "escort-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:apps": "concurrently -k -n api,web -c cyan,magenta \"npm run dev --workspace=@escort/api\" \"npm run dev --workspace=@escort/web\"",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "db:bootstrap": "npm run db:migrate --workspace=@escort/db && npm run seed:models --workspace=@escort/api",
    "db:align-password": "node scripts/align-postgres-password-with-env.mjs",
    "clean": "turbo run clean && rm -rf node_modules",
    "arch-map:generate": "node scripts/generate-project-arch-map.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22"
  }
}
